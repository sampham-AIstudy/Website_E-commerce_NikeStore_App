      function detectSizeGroup(sizesStr) {
        if (!sizesStr) return 'shoes';
        const upper = sizesStr.toUpperCase();
        if (/\b(XS|S|M|L|XL|XXL|3XL)\b/.test(upper)) return 'apparel';
        if (/FREE|ONE|N\/A/.test(upper)) return 'accessories';
        return 'shoes';
      }

      function renderSizeChips() {
        const container = document.getElementById('sizeChipsContainer');
        if (!container) return;
        container.innerHTML = '';

        const currentSizes = SIZE_GROUPS[activeSizeGroup] || SIZE_GROUPS.shoes;

        currentSizes.forEach(size => {
          const isSelected = selectedSizesSet.has(size);
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = `px-3.5 py-2 rounded-xl border-2 text-xs font-bold transition-all duration-200 focus:outline-none ${isSelected
            ? 'bg-nike-black border-nike-black text-white shadow-sm scale-105'
            : 'border-gray-200 text-gray-500 hover:border-nike-orange bg-white'
            }`;
          btn.textContent = size;
          btn.onclick = () => {
            if (selectedSizesSet.has(size)) {
              if (selectedSizesSet.size > 1) selectedSizesSet.delete(size);
            } else {
              selectedSizesSet.add(size);
            }
            document.getElementById('prodSizes').value = Array.from(selectedSizesSet).join(',');
            renderSizeChips();
          };
          container.appendChild(btn);
        });
      }

      function renderColorChips() {
        const container = document.getElementById('colorChipsContainer');
        if (!container) return;
        container.innerHTML = '';

        ALL_COLORS.forEach(c => {
          const isSelected = selectedColorsSet.has(c.name);
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = `flex items-center gap-2 px-3 py-2 rounded-xl border-2 text-xs font-bold transition-all duration-200 focus:outline-none ${isSelected
            ? 'bg-nike-black border-nike-black text-white shadow-sm scale-105'
            : 'border-gray-200 text-gray-500 hover:border-nike-orange bg-white'
            }`;

          const dot = document.createElement('span');
          dot.className = `w-4 h-4 rounded-full border ${c.border} flex-shrink-0`;
          dot.style.backgroundColor = c.hex;

          const label = document.createElement('span');
          label.textContent = c.name;

          btn.appendChild(dot);
          btn.appendChild(label);

          btn.onclick = () => {
            if (selectedColorsSet.has(c.name)) {
              if (selectedColorsSet.size > 1) selectedColorsSet.delete(c.name);
            } else {
              selectedColorsSet.add(c.name);
            }
            document.getElementById('prodColor').value = Array.from(selectedColorsSet).join(',');
            renderColorChips();
          };
          container.appendChild(btn);
        });
