      /* ── Voucher Management Logic ──────────────────────────── */
      let currentVoucherPage = 1;
      let voucherPageSize = 10;

      function filterVouchers() {
        const search = document.getElementById('voucherSearchInput').value.toLowerCase();
        const status = document.getElementById('voucherStatusFilter').value;
        const type = document.getElementById('voucherTypeFilter').value;

        const rows = document.querySelectorAll('.voucher-row');
        let visibleRows = [];

        rows.forEach(row => {
          const rowSearch = row.getAttribute('data-search');
          const rowStatus = row.getAttribute('data-status');
          const rowType = row.getAttribute('data-type');

          let matchSearch = search === '' || rowSearch.includes(search);
          let matchStatus = status === '' || rowStatus === status;
          let matchType = type === '' || rowType === type;

          if (matchSearch && matchStatus && matchType) {
            row.style.display = '';
            visibleRows.push(row);
          } else {
            row.style.display = 'none';
          }
        });

        const emptyRow = document.getElementById('emptyVoucherRow');
        if (emptyRow) emptyRow.style.display = visibleRows.length === 0 ? '' : 'none';
        paginateVouchers(visibleRows);

        const selectAll = document.getElementById('selectAllVouchers');
        if (selectAll) selectAll.checked = false;
        checkVoucherSelections();
      }

      function paginateVouchers(visibleRows) {
        if (!visibleRows) {
          visibleRows = Array.from(document.querySelectorAll('.voucher-row')).filter(r => r.style.display !== 'none');
        }

        const totalRows = visibleRows.length;
        const totalPages = Math.ceil(totalRows / voucherPageSize) || 1;

        if (currentVoucherPage > totalPages) currentVoucherPage = totalPages;
        if (currentVoucherPage < 1) currentVoucherPage = 1;

        const start = (currentVoucherPage - 1) * voucherPageSize;
        const end = start + voucherPageSize;

        visibleRows.forEach((row, index) => {
          if (index >= start && index < end) {
            row.classList.remove('hidden');
          } else {
            row.classList.add('hidden');
          }
        });

        renderVoucherPagination(totalPages);
      }

      function renderVoucherPagination(totalPages) {
        const controls = document.getElementById('voucherPageControls');
        if (!controls) return;
        let html = '';

        html += `<button onclick="gotoVoucherPage(${currentVoucherPage - 1})" class="px-2 py-1 border border-gray-200 rounded hover:bg-gray-100 disabled:opacity-50" ${currentVoucherPage === 1 ? 'disabled' : ''}>&lt;</button>`;

        for (let i = 1; i <= totalPages; i++) {
          if (i === currentVoucherPage) {
            html += `<button class="px-2 py-1 border border-nike-orange bg-nike-orange text-white rounded font-bold">${i}</button>`;
          } else {
            html += `<button onclick="gotoVoucherPage(${i})" class="px-2 py-1 border border-gray-200 rounded hover:bg-gray-100">${i}</button>`;
          }
        }

        html += `<button onclick="gotoVoucherPage(${currentVoucherPage + 1})" class="px-2 py-1 border border-gray-200 rounded hover:bg-gray-100 disabled:opacity-50" ${currentVoucherPage === totalPages ? 'disabled' : ''}>&gt;</button>`;

        controls.innerHTML = html;
      }

      function gotoVoucherPage(page) {
        currentVoucherPage = page;
        filterVouchers();
      }

      function changeVoucherPageSize() {
        voucherPageSize = parseInt(document.getElementById('voucherPerPage').value);
        currentVoucherPage = 1;
        filterVouchers();
      }

      // Bulk actions
      function toggleAllVouchers(cb) {
        const isChecked = cb.checked;
        const visibleRows = Array.from(document.querySelectorAll('.voucher-row')).filter(r => r.style.display !== 'none' && !r.classList.contains('hidden'));
        visibleRows.forEach(row => {
          const checkbox = row.querySelector('.voucher-cb');
          if (checkbox) checkbox.checked = isChecked;
        });
        checkVoucherSelections();
      }

      function checkVoucherSelections() {
        const checkedBoxes = document.querySelectorAll('.voucher-cb:checked');
        const actionSelect = document.getElementById('bulkVoucherAction');
        const applyBtn = document.getElementById('applyBulkVoucherBtn');

        if (checkedBoxes.length > 0) {
          actionSelect.classList.remove('hidden');
          applyBtn.classList.remove('hidden');
        } else {
          actionSelect.classList.add('hidden');
          applyBtn.classList.add('hidden');
          const selectAll = document.getElementById('selectAllVouchers');
          if (selectAll) selectAll.checked = false;
        }
      }

      async function applyBulkVoucherActions() {
        const action = document.getElementById('bulkVoucherAction').value;
        if (!action) return alert('Vui lòng chọn thao tác!');

        const checkedBoxes = document.querySelectorAll('.voucher-cb:checked');
        const ids = Array.from(checkedBoxes).map(cb => cb.value);

        if (ids.length === 0) return;

        let confirmMsg = '';
        if (action === 'activate') confirmMsg = `Kích hoạt ${ids.length} mã giảm giá?`;
        if (action === 'deactivate') confirmMsg = `Vô hiệu hóa ${ids.length} mã giảm giá?`;
        if (action === 'delete') confirmMsg = `Xóa vĩnh viễn ${ids.length} mã giảm giá? Hành động này không thể hoàn tác!`;

        if (!confirm(confirmMsg)) return;

        try {
          const response = await fetch('/api/admin/vouchers/bulk', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action, ids })
          });
          const result = await response.json();

          if (result.status === 'success') {
            alert('Thao tác thành công!');
            window.location.reload();
          } else {
            alert('Lỗi: ' + result.message);
          }
        } catch (e) {
          alert('Lỗi kết nối máy chủ');
        }
      }

      // Stats Modal
      function viewVoucherStats(btn) {
        const v = JSON.parse(decodeURIComponent(btn.getAttribute('data-voucher')));
        document.getElementById('statsVoucherCode').textContent = v.code + (v.name && v.name !== v.code ? ` - ${v.name}` : '');
        document.getElementById('statsVoucherUsed').textContent = v.used_count;
        document.getElementById('statsVoucherTotal').textContent = v.usage_limit;

        let infoHtml = `
        <div class="flex justify-between py-1 border-b border-gray-100"><span>Mức giảm:</span> <strong class="text-nike-orange">${v.discount_type === 'percent' ? v.discount_value + '%' : formatPrice(v.discount_value) + ' ₫'}</strong></div>
        <div class="flex justify-between py-1 border-b border-gray-100"><span>Đơn tối thiểu:</span> <strong>${formatPrice(v.min_order_value)} ₫</strong></div>
        <div class="flex justify-between py-1 border-b border-gray-100"><span>Giảm tối đa:</span> <strong>${v.max_discount ? formatPrice(v.max_discount) + ' ₫' : 'Không giới hạn'}</strong></div>
        <div class="flex justify-between py-1 border-b border-gray-100"><span>Giới hạn/User:</span> <strong>${v.limit_per_user} lần</strong></div>
        <div class="flex justify-between py-1"><span>Phạm vi:</span> <strong>${v.apply_scope === 'all' ? 'Toàn sàn' : (v.apply_scope === 'category' ? 'Danh mục (' + v.scope_value + ')' : 'Loại trừ Outlet')}</strong></div>
      `;
        document.getElementById('statsVoucherInfo').innerHTML = infoHtml;

        const overlay = document.getElementById('voucherStatsModalOverlay');
        const modal = document.getElementById('voucherStatsModal');

        overlay.classList.remove('hidden');
        modal.classList.remove('hidden');
        setTimeout(() => {
          overlay.classList.remove('opacity-0');
          modal.classList.remove('opacity-0', 'scale-95');
        }, 10);
      }

      function closeVoucherStats() {
        const overlay = document.getElementById('voucherStatsModalOverlay');
        const modal = document.getElementById('voucherStatsModal');

        overlay.classList.add('opacity-0');
        modal.classList.add('opacity-0', 'scale-95');
        setTimeout(() => {
          overlay.classList.add('hidden');
          modal.classList.add('hidden');
        }, 300);
      }

      // Initialize voucher pagination
      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => filterVouchers(), 500);
      });

      // ══════════════════════════════════════════════════════════
      // ADMIN LIVE CHAT LOGIC
      // ══════════════════════════════════════════════════════════
      let adminSocket = null;
      let adminSocketConnected = false;
      let currentAdminSession = null;
      let adminOnlineSessions = new Set();
      let adminTotalUnread = 0;

      // Patch window.switchAdminTab để init socket khi mở Live Chat tab
      var _origSwitchForLiveChat = window.switchAdminTab;
      window.switchAdminTab = function (tab) {
        if (typeof _origSwitchForLiveChat === 'function') _origSwitchForLiveChat(tab);
        if (tab === 'livechat') {
          initAdminSocket();
          loadAdminSessions();
        }
      };

      function initAdminSocket() {
        if (adminSocketConnected) return;

        adminSocket = io();

        adminSocket.on('connect', function () {
          adminSocketConnected = true;
          adminSocket.emit('admin:join');
          updateAdminSocketStatus(true);
          console.log('👑 Admin socket connected');
        });

        adminSocket.on('disconnect', function () {
          adminSocketConnected = false;
          updateAdminSocketStatus(false);
        });

        // Nhận danh sách session đang online
        adminSocket.on('admin:online-sessions', function (sessions) {
          adminOnlineSessions = new Set(sessions.map(s => s.session_id));
          updateSessionOnlineStatus();
        });

        // Khách kết nối mới
        adminSocket.on('customer:online', function (data) {
          adminOnlineSessions.add(data.session_id);
          updateSessionOnlineStatus();
          // Refresh sessions list
          loadAdminSessions();
        });

        // Khách offline
        adminSocket.on('customer:offline', function (data) {
          adminOnlineSessions.delete(data.session_id);
          updateSessionOnlineStatus();
        });

        // Nhận tin nhắn mới từ khách
        adminSocket.on('admin:new-message', function (msg) {
          // Nếu đang xem session này → hiện tin ngay
          if (currentAdminSession === msg.session_id) {
          appendAdminChatMessage(msg.message, 'customer', msg.created_at, true, msg.type);
            scrollAdminChat();
            // Đánh dấu đã đọc
            adminSocket.emit('admin:mark-read', { sessionId: msg.session_id });
          } else {
            // Tăng badge unread
            adminTotalUnread++;
            updateAdminUnreadBadge();
            // Cập nhật unread trên session item
            const sessionEl = document.querySelector(`[data-session-id="${msg.session_id}"]`);
            if (sessionEl) {
              const badge = sessionEl.querySelector('.session-unread-badge');
              if (badge) {
                badge.classList.remove('hidden');
                const cur = parseInt(badge.textContent) || 0;
                badge.textContent = cur + 1;
              }
            }
          }
          // Refresh sessions
          loadAdminSessions();
        });

        // Tin nhắn admin đã gửi (đồng bộ giữa các tab admin)
        // Tin nhắn admin đã gửi (đồng bộ giữa các tab admin)
        adminSocket.on('admin:message-sent', function (msg) {
          // Đã append trước bằng optimistic UI → không cần thêm
          // Nhưng nếu tab Live Chat đang mở và đúng session → refresh sessions
          if (adminSocketConnected) loadAdminSessions();
        });

        // Read acknowledgement
        adminSocket.on('admin:read-ack', function (data) {
          adminTotalUnread = Math.max(0, adminTotalUnread - 1);
          updateAdminUnreadBadge();
        });

        // ── Khách đang gõ → hiện typing bubble ───────────────────────────────
        adminSocket.on('admin:customer-typing', function (data) {
          if (data.isTyping) {
            showCustomerTypingIndicator(data.sessionId, data.username);
          } else {
            hideCustomerTypingIndicator(data.sessionId);
          }
        });
      }

      function updateAdminSocketStatus(online) {
        const dot = document.getElementById('adminSocketDot');
        const label = document.getElementById('adminSocketStatus');
        if (!dot || !label) return;
        if (online) {
          dot.className = 'w-2 h-2 rounded-full bg-green-500 inline-block animate-pulse';
          label.innerHTML = '<span id="adminSocketDot" class="w-2 h-2 rounded-full bg-green-500 inline-block animate-pulse"></span> Đã kết nối realtime';
          label.className = 'flex items-center gap-1.5 text-[10px] font-bold text-green-600 uppercase';
        } else {
          label.innerHTML = '<span id="adminSocketDot" class="w-2 h-2 rounded-full bg-gray-300 inline-block"></span> Mất kết nối';
          label.className = 'flex items-center gap-1.5 text-[10px] font-bold text-gray-400 uppercase';
        }
      }

      function updateAdminUnreadBadge() {
        const badge = document.getElementById('adminLiveChatBadge');
        if (!badge) return;
        if (adminTotalUnread > 0) {
          badge.classList.remove('hidden');
          badge.textContent = adminTotalUnread > 99 ? '99+' : adminTotalUnread;
        } else {
          badge.classList.add('hidden');
        }
      }

      function updateSessionOnlineStatus() {
        document.querySelectorAll('[data-session-id]').forEach(el => {
          const sid = el.getAttribute('data-session-id');
          const onlineDot = el.querySelector('.session-online-dot');
          if (onlineDot) {
            if (adminOnlineSessions.has(sid)) {
              onlineDot.className = 'session-online-dot w-2 h-2 rounded-full bg-green-500 flex-shrink-0 animate-pulse';
            } else {
              onlineDot.className = 'session-online-dot w-2 h-2 rounded-full bg-gray-300 flex-shrink-0';
            }
          }
        });
        // Cập nhật active chat header
        if (currentAdminSession) {
          const onlineLabel = document.getElementById('adminActiveChatOnline');
          if (onlineLabel) {
            const isOnline = adminOnlineSessions.has(currentAdminSession);
            onlineLabel.textContent = isOnline ? 'Đang trực tuyến' : 'Offline';
            onlineLabel.className = isOnline
              ? 'text-[10px] font-bold text-green-600 bg-green-50 px-2 py-1 rounded-full'
              : 'text-[10px] font-bold text-gray-400 bg-gray-100 px-2 py-1 rounded-full';
          }
        }
      }

      async function loadAdminSessions() {
        try {
          const res = await fetch('/api/livechat/sessions');
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const data = await res.json();
          renderAdminSessions(data.data || []);

          // Tính tổng unread
          adminTotalUnread = (data.data || []).reduce((sum, s) => sum + (s.unread_count || 0), 0);
          updateAdminUnreadBadge();
        } catch (e) {
          console.error('Load sessions error:', e);
          const el = document.getElementById('adminSessionsList');
          if (el) el.innerHTML = '<div class="p-4 text-center text-xs text-red-400">Lỗi tải danh sách</div>';
        }
      }

      function renderAdminSessions(sessions) {
        const el = document.getElementById('adminSessionsList');
        if (!el) return;

        if (sessions.length === 0) {
          el.innerHTML = '<div class="p-6 text-center text-xs text-gray-400">Chưa có cuộc trò chuyện nào</div>';
          return;
        }

        el.innerHTML = sessions.map(s => {
          const isOnline = adminOnlineSessions.has(s.session_id);
          const isActive = s.session_id === currentAdminSession;
          const shortSess = s.session_id.substring(0, 12) + '...';
          const timeAgo = s.last_message_at ? formatTimeAgo(new Date(s.last_message_at)) : '';
          const preview = (s.last_message || '').substring(0, 40) + (s.last_message && s.last_message.length > 40 ? '...' : '');

          return `
          <div data-session-id="${s.session_id}"
            onclick="openAdminSession('${s.session_id}', '${(s.username || 'Khách').replace(/'/g, "\\'")}', ${s.user_id || null})"
            class="p-4 cursor-pointer hover:bg-gray-50 transition-colors ${isActive ? 'bg-orange-50/50 border-l-4 border-orange-500' : ''}">
            <div class="flex items-center gap-3">
              <div class="relative flex-shrink-0">
                <div class="w-9 h-9 rounded-full bg-[#111] text-white text-sm font-bold flex items-center justify-center">
                  ${(s.username || 'K').charAt(0).toUpperCase()}
                </div>
                <span class="session-online-dot absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full border-2 border-white ${isOnline ? 'bg-green-500 animate-pulse' : 'bg-gray-300'}"></span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex justify-between items-center">
                  <p class="font-bold text-xs text-gray-800 truncate">${s.username || 'Khách'}</p>
                  <span class="text-[9px] text-gray-400 flex-shrink-0 ml-2">${timeAgo}</span>
                </div>
                <p class="text-[10px] text-gray-500 truncate mt-0.5">${preview || 'Không có tin nhắn'}</p>
              </div>
              ${s.unread_count > 0 ? `<span class="session-unread-badge flex-shrink-0 min-w-[18px] h-[18px] bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center px-1">${s.unread_count}</span>` : '<span class="session-unread-badge hidden min-w-[18px] h-[18px] bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center px-1"></span>'}
            </div>
          </div>`;
        }).join('');
      }

      async function openAdminSession(sessionId, username, userId) {
        currentAdminSession = sessionId;

        // Update UI
        document.getElementById('adminChatEmpty').style.display = 'none';
        const activeEl = document.getElementById('adminChatActive');
        activeEl.style.display = 'flex';
        activeEl.classList.remove('hidden');

        document.getElementById('adminActiveChatName').textContent = username || 'Khách';
        document.getElementById('adminActiveChatSession').textContent = 'Session: ' + sessionId.substring(0, 20) + '...';
        document.getElementById('adminActiveChatAvatar').textContent = (username || 'K').charAt(0).toUpperCase();

        // Update online status
        const isOnline = adminOnlineSessions.has(sessionId);
        const onlineEl = document.getElementById('adminActiveChatOnline');
        onlineEl.textContent = isOnline ? 'Đang trực tuyến' : 'Offline';
        onlineEl.className = isOnline
          ? 'text-[10px] font-bold text-green-600 bg-green-50 px-2 py-1 rounded-full'
          : 'text-[10px] font-bold text-gray-400 bg-gray-100 px-2 py-1 rounded-full';

        // Highlight active session
        document.querySelectorAll('[data-session-id]').forEach(el => {
          el.classList.remove('bg-orange-50/50', 'border-l-4', 'border-orange-500');
          if (el.getAttribute('data-session-id') === sessionId) {
            el.classList.add('bg-orange-50/50', 'border-l-4', 'border-orange-500');
          }
        });

        // Load messages
        const msgEl = document.getElementById('adminChatMessages');
        msgEl.innerHTML = '<div class="text-center text-xs text-gray-400 py-4">Đang tải tin nhắn...</div>';

        try {
          const res = await fetch('/api/livechat/messages/' + sessionId);
          const data = await res.json();
          msgEl.innerHTML = '';
          if (data.data && data.data.length > 0) {
            data.data.forEach(msg => appendAdminChatMessage(msg.message, msg.sender, msg.created_at, false, msg.type));
          } else {
            msgEl.innerHTML = '<div class="text-center text-xs text-gray-400 py-4">Chưa có tin nhắn nào</div>';
          }
          scrollAdminChat();
        } catch (e) {
          msgEl.innerHTML = '<div class="text-center text-xs text-red-400 py-4">Lỗi tải tin nhắn</div>';
        }

        // Mark read via socket
        if (adminSocket && adminSocketConnected) {
          adminSocket.emit('admin:mark-read', { sessionId });
        }

        // Clear unread badge trên session item
        const sessionEl = document.querySelector(`[data-session-id="${sessionId}"]`);
        if (sessionEl) {
          const badge = sessionEl.querySelector('.session-unread-badge');
          if (badge) badge.classList.add('hidden');
        }

        // Focus reply input
        document.getElementById('adminReplyInput').focus();
      }

      function appendAdminChatMessage(text, sender, timestamp, scroll = true, type = 'text') {
        const container = document.getElementById('adminChatMessages');
        const isCustomer = sender === 'customer';
        const timeStr = timestamp ? new Date(timestamp).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) : '';

        const safeText = escapeHtml(text);

        // Xóa typing bubble khi có tin thật đến
        if (isCustomer) hideCustomerTypingIndicator(currentAdminSession);

        let contentHtml = '';
        if (type === 'image') {
          contentHtml = `<img src="${safeText}" class="max-w-[200px] rounded-lg shadow-sm border border-gray-200">`;
        } else {
          if (isCustomer) {
            contentHtml = `<div class="bg-white px-3 py-2 rounded-2xl rounded-tl-sm shadow-sm text-xs text-gray-700 border border-gray-100 break-words w-full" style="word-break:break-word">${safeText}</div>`;
          } else {
            contentHtml = `<div class="bg-[#111] text-white px-3 py-2 rounded-2xl rounded-tr-sm shadow-sm text-xs break-words w-full" style="word-break:break-word">${safeText}</div>`;
          }
        }

        let html = '';
        if (isCustomer) {
          html = `
          <div class="flex gap-2">
            <div class="w-6 h-6 rounded-full bg-gray-200 text-gray-600 text-[9px] font-bold flex items-center justify-center flex-shrink-0 mt-1">K</div>
            <div class="flex flex-col max-w-[80%]">
              ${contentHtml}
              ${timeStr ? `<span class="text-[9px] text-gray-400 mt-1">${timeStr}</span>` : ''}
            </div>
          </div>`;
        } else {
          html = `
          <div class="flex gap-2 justify-end">
            <div class="flex flex-col items-end max-w-[80%]">
              ${contentHtml}
              ${timeStr ? `<span class="text-[9px] text-gray-400 mt-1">${timeStr}</span>` : ''}
            </div>
            <div class="w-6 h-6 rounded-full bg-orange-500 text-white text-[9px] font-bold flex items-center justify-center flex-shrink-0 mt-1">A</div>
          </div>`;
        }

        container.insertAdjacentHTML('beforeend', html);
        if (scroll) scrollAdminChat();
      }

      function adminSendReply() {
        const input = document.getElementById('adminReplyInput');
        const text = input.value.trim();
        if (!text || !currentAdminSession) return;

        // Optimistic UI
        appendAdminChatMessage(text, 'admin', new Date().toISOString(), true, 'text');
        input.value = '';
        scrollAdminChat();

        if (adminSocket && adminSocketConnected) {
          adminSocket.emit('admin:message', {
            sessionId: currentAdminSession,
            message: text,
            type: 'text'
          });
        } else {
          // REST fallback
          fetch('/api/livechat/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              session_id: currentAdminSession,
              message: text,
              sender: 'admin',
              username: 'Admin',
              type: 'text'
            })
          }).catch(err => console.error('Admin send error:', err));
        }
      }

      // ── Admin Upload Image Logic ──────────────────────────────────────────────────
      async function uploadAdminChatImage(input) {
        if (!input.files || input.files.length === 0 || !currentAdminSession) return;
        const file = input.files[0];
        if (file.size > 25 * 1024 * 1024) {
          alert("Ảnh quá lớn! Vui lòng chọn ảnh dưới 25MB.");
          input.value = '';
          return;
        }

        const formData = new FormData();
        formData.append('image', file);

        try {
          const res = await fetch('/api/livechat/upload', {
            method: 'POST',
            body: formData
          });
          const data = await res.json();
          if (data.status === 'success') {
            // Optimistic UI
            appendAdminChatMessage(data.url, 'admin', new Date().toISOString(), true, 'image');

            if (adminSocket && adminSocketConnected) {
              adminSocket.emit('admin:message', {
                sessionId: currentAdminSession,
                message: data.url,
                type: 'image'
              });
            }
          } else {
            alert(data.message || 'Lỗi khi upload ảnh');
          }
        } catch (err) {
          console.error(err);
          alert('Đã xảy ra lỗi khi upload ảnh');
        } finally {
          input.value = ''; // Reset input
        }
      }

      // ── Admin Emoji Picker Logic ──────────────────────────────────────────────────
      function toggleAdminEmojiPicker() {
        const picker = document.getElementById('adminEmojiPickerWrapper');
        picker.classList.toggle('hidden');
      }

      // Khởi tạo emoji picker cho admin
      document.addEventListener('DOMContentLoaded', () => {
        // Vì element emoji-picker có thể ở trong partials/chat.ejs hoặc được thêm ở đây, ta bind sự kiện cẩn thận.
        const pickers = document.querySelectorAll('emoji-picker');
        pickers.forEach(picker => {
          // Chỉ xử lý cho Emoji picker nằm trong khu vực Admin Chat
          if (picker.closest('#adminEmojiPickerWrapper')) {
            picker.addEventListener('emoji-click', event => {
              const inputEl = document.getElementById('adminReplyInput');
              inputEl.value += event.detail.unicode;
              toggleAdminEmojiPicker();
              inputEl.focus();
            });
          }
        });
      });

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
      }

      function scrollAdminChat() {
        const el = document.getElementById('adminChatMessages');
        if (el) el.scrollTop = el.scrollHeight;
      }

      function formatTimeAgo(date) {
        const now = new Date();
        const diff = Math.floor((now - date) / 1000);
        if (diff < 60) return diff + 'g trước';
        if (diff < 3600) return Math.floor(diff / 60) + 'p trước';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h trước';
        return date.toLocaleDateString('vi-VN');
      }

      // ── Admin typing indicator ──────────────────────────────────────────────
      let adminTypingDebounce = null;
      let customerTypingTimeouts = {}; // Map sessionId → timeout

      function onAdminTyping() {
        if (!adminSocket || !adminSocketConnected || !currentAdminSession) return;

        adminSocket.emit('admin:typing', {
          sessionId: currentAdminSession,
          isTyping: true
        });

        clearTimeout(adminTypingDebounce);
        adminTypingDebounce = setTimeout(function () {
          adminSocket.emit('admin:typing', {
            sessionId: currentAdminSession,
            isTyping: false
          });
        }, 1500);
      }

      function showCustomerTypingIndicator(sessionId, username) {
        // Chỉ hiện nếu đang xem session này
        if (currentAdminSession !== sessionId) return;

        const container = document.getElementById('adminChatMessages');
        if (!container) return;

        // Tránh tạo nhiều lần
        if (document.getElementById('customerTypingBubble')) {
          clearTimeout(customerTypingTimeouts[sessionId]);
          customerTypingTimeouts[sessionId] = setTimeout(() => hideCustomerTypingIndicator(sessionId), 4000);
          return;
        }

        const safeUsername = (username || 'Khách').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        const html = `
        <div id="customerTypingBubble" class="flex gap-2">
          <div class="w-6 h-6 rounded-full bg-gray-200 text-gray-600 text-[9px] font-bold flex items-center justify-center flex-shrink-0 mt-1">${safeUsername.charAt(0).toUpperCase()}</div>
          <div class="flex flex-col">
            <div class="bg-white px-3 py-2.5 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 flex items-center gap-1">
              <span class="w-1.5 h-1.5 bg-gray-400 rounded-full inline-block animate-bounce"></span>
              <span class="w-1.5 h-1.5 bg-gray-400 rounded-full inline-block animate-bounce" style="animation-delay:0.2s"></span>
              <span class="w-1.5 h-1.5 bg-gray-400 rounded-full inline-block animate-bounce" style="animation-delay:0.4s"></span>
            </div>
            <span class="text-[9px] text-gray-400 mt-1">${safeUsername} đang gõ...</span>
          </div>
        </div>`;
        container.insertAdjacentHTML('beforeend', html);
        scrollAdminChat();

        // Auto-hide sau 4 giây
        clearTimeout(customerTypingTimeouts[sessionId]);
        customerTypingTimeouts[sessionId] = setTimeout(() => hideCustomerTypingIndicator(sessionId), 4000);
      }

      function hideCustomerTypingIndicator(sessionId) {
        const el = document.getElementById('customerTypingBubble');
        if (el) el.remove();
        if (sessionId && customerTypingTimeouts[sessionId]) {
          clearTimeout(customerTypingTimeouts[sessionId]);
        }
      }

      // Poll unread count mỗi 30 giây (khi chưa mở tab Live Chat)
      setInterval(async function () {
        try {
          const res = await fetch('/api/livechat/unread-count');
          if (!res.ok) return;
          const data = await res.json();
          adminTotalUnread = data.count || 0;
          updateAdminUnreadBadge();
        } catch (e) { }
      }, 30000);

      // Load unread count ngay khi trang mở
      document.addEventListener('DOMContentLoaded', () => {
        fetch('/api/livechat/unread-count')
          .then(r => r.json())
          .then(data => {
            adminTotalUnread = data.count || 0;
            updateAdminUnreadBadge();
          })
          .catch(() => { });
      });

    </script>


