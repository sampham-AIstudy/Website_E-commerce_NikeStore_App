              class="flex-1 bg-nike-black hover:bg-nike-orange text-white text-center font-bold py-3 px-4 rounded-full text-xs uppercase tracking-wider transition-all duration-300 shadow-md glow-dark hover:glow-orange focus:outline-none">Lưu
              sản phẩm</button>
          </div>
        </form>
      </div>
