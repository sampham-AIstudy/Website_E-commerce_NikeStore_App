        const id = document.getElementById('voucherFormId').value;

        let discountType = document.getElementById('voucherDiscountType').value;
        let discountVal = document.getElementById('voucherDiscountValue').value;
        let maxDiscount = document.getElementById('voucherMaxDiscount').value || null;

        let generatedName = '';
        if (discountType === 'percent') {
          generatedName = `Giảm ${discountVal}%` + (maxDiscount ? ` Giảm tối đa ${maxDiscount}vnd` : '');
        } else {
          generatedName = `Giảm ${discountVal}vnd`;
