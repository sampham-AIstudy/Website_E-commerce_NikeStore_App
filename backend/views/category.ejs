<%- include('partials/header', { title: 'Nike Store - ' + categoryTitle }) %>

<% 
  // Helper to format price in EJS
  function formatPrice(number) {
    let cleanVal = parseFloat(String(number).replace(/[^0-9.-]+/g,""));
    if (isNaN(cleanVal)) return number;
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cleanVal);
  }
%>

  <!-- ========================================== -->
  <!-- CATEGORY BANNER                            -->
  <!-- ========================================== -->
  <div class="bg-gradient-to-r from-zinc-900 to-sky-950 text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(255,84,0,0.1),transparent)]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col justify-center items-center text-center space-y-3">
      <span class="text-nike-orange font-extrabold text-xs uppercase tracking-widest block">Bộ sưu tập Nike</span>
      <h1 class="text-3xl sm:text-5xl font-black uppercase tracking-tight"><%= categoryTitle %></h1>
      <p class="text-xs sm:text-sm text-gray-400 max-w-md font-light leading-relaxed">
        Khám phá toàn bộ sản phẩm Nike chính hãng — giày chạy bộ, áo thể thao, quần jogger, phụ kiện và trang thiết bị tập luyện — dành riêng cho <%= categoryTitle.toLowerCase() %>.
      </p>
    </div>
  </div>

  <!-- ========================================== -->
  <!-- FILTER & PRODUCTS CONTAINER                -->
  <!-- ========================================== -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Top Filter Bar -->
    <% var activeFilters = (typeof filters !== 'undefined') ? filters : { item_type: '', price_range: '', sort: 'default', q: '' }; %>
    <div class="flex flex-col lg:flex-row justify-between items-center bg-white rounded-3xl p-5 border border-gray-100 shadow-sm gap-4 mb-10 relative">
      <!-- Left: Search Box -->
      <div class="relative w-full lg:w-80">
        <input type="text" id="catSearchInput" placeholder="Tìm trong mục này..." value="<%= activeFilters.q || '' %>" class="bg-gray-50 border-0 rounded-full py-2.5 pl-4 pr-10 text-xs focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full font-medium">
        <svg class="w-4 h-4 text-gray-400 absolute right-3.5 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>

      <!-- Right: Filter Button & Count -->
      <div class="flex items-center justify-between w-full lg:w-auto gap-4">
        <span class="text-xs text-gray-400 font-bold hidden lg:inline border-r pr-4 border-gray-200">Trang <span class="text-nike-black font-extrabold"><%= page %></span>/<%= totalPages %> &bull; <span id="visibleProductsCount" class="text-nike-black font-extrabold"><%= totalItems %></span> sản phẩm</span>
        
        <% if (activeFilters.item_type || activeFilters.price_range || activeFilters.q) { %>
          <a href="/<%= categorySlug %>" class="bg-red-50 border-2 border-red-200 hover:border-red-400 text-red-500 font-bold text-xs px-4 py-2.5 rounded-full flex items-center gap-1.5 transition-all shadow-sm">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            Xóa lọc
          </a>
        <% } %>

        <!-- Filter Toggle Button -->
        <button onclick="document.getElementById('catFilterPanel').classList.toggle('hidden')" class="bg-white border-2 border-gray-100 hover:border-nike-orange text-gray-700 hover:text-nike-orange font-bold text-xs px-5 py-2.5 rounded-full flex items-center justify-center gap-2 transition-all shadow-sm focus:outline-none w-full sm:w-auto">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
          Bộ Lọc
        </button>
      </div>

      <!-- Filter Panel (Dropdown) -->
      <div id="catFilterPanel" class="hidden absolute top-[110%] right-0 mt-2 w-full lg:w-[500px] bg-white rounded-3xl border border-gray-100 shadow-2xl p-6 z-[100]">
        <div class="flex justify-between items-center mb-5 border-b border-gray-50 pb-3">
          <h3 class="font-extrabold text-sm uppercase tracking-wider text-nike-black">Tùy chỉnh bộ lọc</h3>
          <button onclick="document.getElementById('catFilterPanel').classList.add('hidden')" class="text-gray-400 hover:text-nike-orange focus:outline-none">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <!-- Item Type Filter -->
          <div class="space-y-2">
            <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Loại sản phẩm</span>
            <select id="catTypeFilter" class="bg-gray-50 border-0 rounded-xl py-3 px-4 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
              <option value="" <%= activeFilters.item_type === '' ? 'selected' : '' %>>Tất cả</option>
              <option value="shoes" <%= activeFilters.item_type === 'shoes' ? 'selected' : '' %>>Giày</option>
              <option value="bags" <%= activeFilters.item_type === 'bags' ? 'selected' : '' %>>Balo/Túi</option>
              <option value="cap" <%= activeFilters.item_type === 'cap' ? 'selected' : '' %>>Mũ/Nón</option>
              <option value="equipment" <%= activeFilters.item_type === 'equipment' ? 'selected' : '' %>>Dụng cụ</option>
              <option value="hoodie" <%= activeFilters.item_type === 'hoodie' ? 'selected' : '' %>>Áo Hoodie</option>
              <option value="jacket" <%= activeFilters.item_type === 'jacket' ? 'selected' : '' %>>Áo khoác</option>
              <option value="pants" <%= activeFilters.item_type === 'pants' ? 'selected' : '' %>>Quần dài</option>
              <option value="shirt" <%= activeFilters.item_type === 'shirt' ? 'selected' : '' %>>Áo thun</option>
              <option value="shorts" <%= activeFilters.item_type === 'shorts' ? 'selected' : '' %>>Quần ngắn</option>
              <option value="socks" <%= activeFilters.item_type === 'socks' ? 'selected' : '' %>>Tất/Vớ</option>
              <option value="accessories" <%= activeFilters.item_type === 'accessories' ? 'selected' : '' %>>Phụ kiện</option>
            </select>
          </div>

          <!-- Price Range Filter -->
          <div class="space-y-2">
            <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Khoảng giá</span>
            <select id="catPriceFilter" class="bg-gray-50 border-0 rounded-xl py-3 px-4 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
              <option value="" <%= activeFilters.price_range === '' ? 'selected' : '' %>>Tất cả mức giá</option>
              <option value="under-1m" <%= activeFilters.price_range === 'under-1m' ? 'selected' : '' %>>Dưới 1.000.000₫</option>
              <option value="1m-2m" <%= activeFilters.price_range === '1m-2m' ? 'selected' : '' %>>1.000.000₫ - 2.000.000₫</option>
              <option value="2m-4m" <%= activeFilters.price_range === '2m-4m' ? 'selected' : '' %>>2.000.000₫ - 4.000.000₫</option>
              <option value="over-4m" <%= activeFilters.price_range === 'over-4m' ? 'selected' : '' %>>Trên 4.000.000₫</option>
            </select>
          </div>

          <!-- Sort Select -->
          <div class="space-y-2 sm:col-span-2 border-t border-gray-50 pt-3">
            <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Sắp xếp theo</span>
            <div class="flex flex-wrap gap-2">
              <button class="catSortBtn flex-1 <%= activeFilters.sort === 'default' || !activeFilters.sort ? 'bg-nike-black text-white shadow-sm active' : 'bg-gray-50 text-gray-600 hover:bg-gray-200' %> py-2 px-3 rounded-xl text-[11px] font-bold transition-colors" data-sort="default">Mặc định</button>
              <button class="catSortBtn flex-1 <%= activeFilters.sort === 'price-asc' ? 'bg-nike-black text-white shadow-sm active' : 'bg-gray-50 text-gray-600 hover:bg-gray-200' %> py-2 px-3 rounded-xl text-[11px] font-bold transition-colors" data-sort="price-asc">Giá Thấp ➡ Cao</button>
              <button class="catSortBtn flex-1 <%= activeFilters.sort === 'price-desc' ? 'bg-nike-black text-white shadow-sm active' : 'bg-gray-50 text-gray-600 hover:bg-gray-200' %> py-2 px-3 rounded-xl text-[11px] font-bold transition-colors" data-sort="price-desc">Giá Cao ➡ Thấp</button>
            </div>
            <input type="hidden" id="catSortSelect" value="<%= activeFilters.sort || 'default' %>">
          </div>
        </div>

        <div class="mt-6">
          <button id="applyFilterBtn" class="w-full bg-nike-orange hover:bg-orange-600 text-white font-bold text-xs py-3 rounded-xl uppercase tracking-wider transition-colors shadow-md">
            Xem kết quả
          </button>
        </div>
      </div>
    </div>

    <!-- Product Grid & Filter View -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" id="categoryProductsGrid">
      <% if (products.length > 0) { %>
        <% products.forEach(product => { %>
          <% 
            let numPrice = parseFloat(product.price);
            let finalPrice = numPrice;
            if (product.discount_percent > 0) {
              finalPrice = numPrice * (1 - product.discount_percent / 100);
            }
            if (finalPrice < 100000) {
              finalPrice = finalPrice * 1000;
            }
          %>
          <div class="cat-product-card group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl border border-gray-100/60 hover:border-nike-orange/15 transition-all duration-300 flex flex-col relative"
               data-title="<%= product.title.toLowerCase() %>"
               data-price="<%= finalPrice %>"
               data-rating="<%= product.rating || 4.5 %>"
               data-sizes="<%= product.sizes %>"
               data-item-type="<%= (product.item_type || 'shoes').toLowerCase() %>">
            
            <!-- Badges (New / Discount) -->
            <div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
              <% if (product.is_new) { %>
                <span class="bg-red-500 text-white font-extrabold text-[9px] uppercase tracking-widest px-2.5 py-1 rounded-full shadow-sm">NEW</span>
              <% } %>
              <% if (product.discount_percent > 0) { %>
                <span class="bg-nike-orange text-white font-extrabold text-[9px] uppercase tracking-widest px-2.5 py-1 rounded-full shadow-sm">SALE -<%= product.discount_percent %>%</span>
              <% } %>
            </div>

            <!-- Like / Wishlist Toggle -->
            <button onclick="toggleWishlist(JSON.parse(decodeURIComponent('<% animate = encodeURIComponent(JSON.stringify(product)) %><%= animate %>')))" class="absolute top-4 right-4 z-20 w-8 h-8 rounded-full bg-white/80 hover:bg-red-50 hover:text-red-500 border border-gray-100 flex items-center justify-center text-gray-500 shadow-sm transition-all duration-200 focus:outline-none">
              <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            </button>

            <!-- Image Panel -->
            <div class="h-60 bg-gradient-to-b from-gray-50/50 to-white flex items-center justify-center overflow-hidden p-6 relative">
              <a href="/products/<%= product.id %>" class="w-full h-full flex items-center justify-center">
                <img src="<%= product.image %>" alt="<%= product.title %>" class="max-w-[85%] max-h-full object-contain transform group-hover:scale-115 group-hover:rotate-[-6deg] transition-all duration-500 ease-out z-10" onerror="this.src='/nike.png'">
              </a>
              <div class="absolute bottom-3 left-4 right-4 flex justify-between text-[10px] text-gray-400 font-medium z-10 group-hover:opacity-0 transition-opacity">
                <span><%= product.color %></span>
                <span><%= (product.sizes && product.sizes !== 'N/A' && product.sizes !== '') ? 'Size: ' + product.sizes : (translateItemType(product.item_type) || '') %></span>
              </div>
            </div>

            <!-- Content Card -->
            <div class="p-6 flex-1 flex flex-col justify-between space-y-4 border-t border-gray-50/50">
              <div>
                <span class="text-[10px] uppercase font-bold text-gray-400 tracking-wider"><%= product.category === 'men' ? 'Nam' : product.category === 'women' ? 'Nữ' : 'Trẻ Em' %> &bull; <%= translateItemType(product.item_type) %></span>
                <a href="/products/<%= product.id %>" class="block font-bold text-gray-800 text-sm hover:text-nike-orange transition-colors truncate mt-2"><%= product.title %></a>
                
                <!-- Ratings -->
                <div class="flex items-center gap-1 mt-1.5">
                  <div class="flex text-yellow-400">
                    <% for(let i=0; i<5; i++) { %>
                      <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    <% } %>
                  </div>
                  <span class="text-[10px] text-gray-500 font-bold ml-1"><%= product.rating || '4.5' %></span>
                </div>
              </div>

              <!-- Price & Checkout option -->
              <div class="flex justify-between items-center pt-3 border-t border-gray-50">
                <div class="flex flex-col">
                  <% if (product.discount_percent > 0) { %>
                    <span class="text-xs text-gray-400 line-through"><%= formatPrice(product.price) %></span>
                    <span class="font-extrabold text-sm text-nike-orange"><%= formatPrice(product.price * (1 - product.discount_percent / 100)) %></span>
                  <% } else { %>
                    <span class="font-extrabold text-sm text-nike-black"><%= formatPrice(product.price) %></span>
                  <% } %>
                </div>
                
                <!-- Quick add to cart button -->
                <button onclick="addToCart(JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(product)) %>')), '39', 'Trắng', 1)" class="bg-nike-black hover:bg-nike-orange text-white p-2.5 rounded-full transition-all duration-300 hover:rotate-[360deg] shadow-md focus:outline-none glow-dark hover:glow-orange">
                  <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <!-- No Products Placeholder -->
        <div class="col-span-full py-16 text-center text-gray-500">
          <p class="font-bold text-lg">Danh mục này hiện đang cập nhật sản phẩm!</p>
          <p class="text-sm mt-1">Vui lòng quay lại sau.</p>
        </div>
      <% } %>
    </div>

    <% if (totalPages > 1) { %>
    <%
      // Build query string for pagination that preserves filter params
      var paginationParams = '';
      if (activeFilters.item_type) paginationParams += '&item_type=' + encodeURIComponent(activeFilters.item_type);
      if (activeFilters.price_range) paginationParams += '&price_range=' + encodeURIComponent(activeFilters.price_range);
      if (activeFilters.sort && activeFilters.sort !== 'default') paginationParams += '&sort=' + encodeURIComponent(activeFilters.sort);
      if (activeFilters.q) paginationParams += '&q=' + encodeURIComponent(activeFilters.q);
    %>
    <!-- ========================================== -->
    <!-- PAGINATION BAR                             -->
    <!-- ========================================== -->
    <div class="flex items-center justify-center gap-2 mt-12 flex-wrap">
      <% if (page > 1) { %>
        <a href="?page=<%= page - 1 %><%= paginationParams %>" class="flex items-center gap-1.5 px-4 py-2 bg-white border border-gray-200 hover:border-nike-orange hover:text-nike-orange text-gray-600 font-bold text-xs rounded-full transition-all shadow-sm">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Trước
        </a>
      <% } %>

      <% for (let i = Math.max(1, page-2); i <= Math.min(totalPages, page+2); i++) { %>
        <a href="?page=<%= i %><%= paginationParams %>" class="w-9 h-9 flex items-center justify-center font-extrabold text-xs rounded-full transition-all shadow-sm
          <%= i === page ? 'bg-nike-black text-white shadow-md' : 'bg-white border border-gray-200 text-gray-600 hover:border-nike-orange hover:text-nike-orange' %>">
          <%= i %>
        </a>
      <% } %>

      <% if (page < totalPages) { %>
        <a href="?page=<%= page + 1 %><%= paginationParams %>" class="flex items-center gap-1.5 px-4 py-2 bg-white border border-gray-200 hover:border-nike-orange hover:text-nike-orange text-gray-600 font-bold text-xs rounded-full transition-all shadow-sm">
          Sau
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      <% } %>
    </div>
    <% } %>
  </div>

  <!-- Server-Side Filter Logic — reload with query params -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const typeFilter  = document.getElementById('catTypeFilter');
      const priceFilter = document.getElementById('catPriceFilter');
      const sortSelect  = document.getElementById('catSortSelect');
      const searchInput = document.getElementById('catSearchInput');
      const applyBtn    = document.getElementById('applyFilterBtn');

      // Build URL with current filter state and navigate
      function applyFilters() {
        const params = new URLSearchParams();
        
        const itemType   = typeFilter  ? typeFilter.value  : '';
        const priceRange = priceFilter ? priceFilter.value : '';
        const sortVal    = sortSelect  ? sortSelect.value  : 'default';
        const searchQ    = searchInput ? searchInput.value.trim() : '';

        if (itemType)                    params.set('item_type', itemType);
        if (priceRange)                  params.set('price_range', priceRange);
        if (sortVal && sortVal !== 'default') params.set('sort', sortVal);
        if (searchQ)                     params.set('q', searchQ);
        // Always reset to page 1 when filter changes
        
        const queryStr = params.toString();
        window.location.href = window.location.pathname + (queryStr ? '?' + queryStr : '');
      }

      // "Xem kết quả" button triggers the filter
      if (applyBtn) applyBtn.addEventListener('click', applyFilters);

      // Search on Enter key
      if (searchInput) {
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') { e.preventDefault(); applyFilters(); }
        });
      }
      
      // Sort buttons
      const sortBtns = document.querySelectorAll('.catSortBtn');
      sortBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          sortBtns.forEach(b => {
             b.classList.remove('bg-nike-black', 'text-white', 'shadow-sm', 'active');
             b.classList.add('bg-gray-50', 'text-gray-600');
          });
          btn.classList.remove('bg-gray-50', 'text-gray-600');
          btn.classList.add('bg-nike-black', 'text-white', 'shadow-sm', 'active');
          if (sortSelect) sortSelect.value = btn.getAttribute('data-sort');
        });
      });
    });
  </script>

<%- include('partials/footer') %>
