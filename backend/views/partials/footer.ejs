  <!-- ========================================== -->
  <!-- DYNAMIC CLIENT JAVASCRIPT                 -->
  <!-- ========================================== -->
  <script>
    // ==========================================
    // SIDEBAR OPEN/CLOSE STATE LOGIC
    // ==========================================
    const backdrop = document.getElementById('backdrop');
    const cartSidebar = document.getElementById('cartSidebar');
    const wishlistSidebar = document.getElementById('wishlistSidebar');

    const cartBtn = document.getElementById('cartBtn');
    const wishlistBtn = document.getElementById('wishlistBtn');
    const closeCartBtn = document.getElementById('closeCartBtn');
    const closeWishlistBtn = document.getElementById('closeWishlistBtn');

    function openCart() {
      if (!localStorage.getItem('nike_user')) {
        window.location.href = '/login';
        return;
      }
      closeWishlist();
      backdrop.classList.remove('hidden');
      setTimeout(() => {
        backdrop.classList.add('opacity-100');
        cartSidebar.classList.remove('translate-x-full');
      }, 50);
    }

    function closeCart() {
      cartSidebar.classList.add('translate-x-full');
      backdrop.classList.remove('opacity-100');
      setTimeout(() => {
        if (wishlistSidebar.classList.contains('translate-x-full')) {
          backdrop.classList.add('hidden');
        }
      }, 300);
    }

    function openWishlist() {
      if (!localStorage.getItem('nike_user')) {
        window.location.href = '/login';
        return;
      }
      closeCart();
      backdrop.classList.remove('hidden');
      setTimeout(() => {
        backdrop.classList.add('opacity-100');
        wishlistSidebar.classList.remove('translate-x-full');
      }, 50);
    }

    function closeWishlist() {
      wishlistSidebar.classList.add('translate-x-full');
      backdrop.classList.remove('opacity-100');
      setTimeout(() => {
        if (cartSidebar.classList.contains('translate-x-full')) {
          backdrop.classList.add('hidden');
        }
      }, 300);
    }

    if(cartBtn) cartBtn.addEventListener('click', openCart);
    if(closeCartBtn) closeCartBtn.addEventListener('click', closeCart);
    if(wishlistBtn) wishlistBtn.addEventListener('click', openWishlist);
    if(closeWishlistBtn) closeWishlistBtn.addEventListener('click', closeWishlist);
    if(backdrop) backdrop.addEventListener('click', () => { closeCart(); closeWishlist(); });

    // ==========================================
    // SHOPPING CART CORE LOGIC (LOCALSTORAGE)
    // ==========================================
    function getCurrentUserKey() {
      const userStr = localStorage.getItem('nike_user');
      if (!userStr) return null;
      try {
        const user = JSON.parse(userStr);
        return user.id || user.username || null;
      } catch (e) {
        return null;
      }
    }

    function getCart() {
      const userKey = getCurrentUserKey();
      if (!userKey) return [];
      const storageKey = `nike_cart_${userKey}`;
      const cart = localStorage.getItem(storageKey);
      const parsed = cart ? JSON.parse(cart) : [];
      let updated = false;
      parsed.forEach(item => {
        if (item.checked === undefined) {
          item.checked = false;
          updated = true;
        }
      });
      if (updated) {
        localStorage.setItem(storageKey, JSON.stringify(parsed));
      }
      return parsed;
    }

    function saveCart(cart) {
      const userKey = getCurrentUserKey();
      if (!userKey) return;
      const storageKey = `nike_cart_${userKey}`;
      localStorage.setItem(storageKey, JSON.stringify(cart));
      updateCartUI();
    }

    function addToCart(product, size = '39', color = 'Trắng', quantity = 1) {
      if (!localStorage.getItem('nike_user')) {
        window.location.href = '/login';
        return;
      }
      const cart = getCart();
      
      // Parse price to number
      let numPrice = parseFloat(String(product.price).replace(/[^0-9.-]+/g,""));
      
      const existingItem = cart.find(item => item.id === product.id && item.size === size && item.color === color);
      
      if (existingItem) {
        existingItem.cartQuantity += quantity;
        if (existingItem.checked === undefined) {
          existingItem.checked = false;
        }
      } else {
        cart.push({
          id: product.id,
          title: product.title,
          price: numPrice,
          image: product.image,
          category: product.category,
          size: size,
          color: color,
          cartQuantity: quantity,
          checked: false
        });
      }
      saveCart(cart);
      // Removed openCart() to prevent annoying the user when buying multiple items
    }

    function removeFromCart(id, size, color) {
      let cart = getCart();
      cart = cart.filter(item => !(item.id === id && item.size === size && item.color === color));
      saveCart(cart);
    }

    function updateQuantity(id, size, color, quantity) {
      const cart = getCart();
      const item = cart.find(item => item.id === id && item.size === size && item.color === color);
      if (item) {
        item.cartQuantity = parseInt(quantity);
        if (item.cartQuantity <= 0) {
          removeFromCart(id, size, color);
          return;
        }
      }
      saveCart(cart);
    }

    function clearCart() {
      saveCart([]);
    }

    function toggleItemSelect(id, size, color, checked) {
      const cart = getCart();
      const item = cart.find(item => item.id === id && item.size === size && item.color === color);
      if (item) {
        item.checked = checked;
        saveCart(cart);
        if (typeof renderCartPage === 'function') {
          renderCartPage();
        }
      }
    }

    function toggleSelectAll(checked) {
      const cart = getCart();
      cart.forEach(item => {
        item.checked = checked;
      });
      saveCart(cart);
      if (typeof renderCartPage === 'function') {
        renderCartPage();
      }
    }

    function deleteSelected() {
      let cart = getCart();
      const selectedCount = cart.filter(item => item.checked).length;
      if (selectedCount === 0) {
        alert('Vui lòng chọn ít nhất một sản phẩm để xóa!');
        return;
      }
      if (confirm('Bạn có chắc chắn muốn xóa các sản phẩm đã chọn khỏi giỏ hàng?')) {
        cart = cart.filter(item => !item.checked);
        saveCart(cart);
        if (typeof renderCartPage === 'function') {
          renderCartPage();
        }
      }
    }

    function updateCartUI() {
      const cart = getCart();
      const cartCountBadge = document.getElementById('cartCount');
      const cartSidebarBadge = document.getElementById('cartSidebarCount');
      const cartItemsList = document.getElementById('cartItemsList');
      const emptyState = document.getElementById('emptyCartState');
      const footerSummary = document.getElementById('cartFooter');
      const totalPriceEl = document.getElementById('cartTotalPrice');
      const selectAllBar = document.getElementById('sidebarSelectAllBar');

      // 1. Update badges
      const totalItems = cart.reduce((acc, item) => acc + item.cartQuantity, 0);
      if (totalItems > 0) {
        if(cartCountBadge) { cartCountBadge.textContent = totalItems; cartCountBadge.classList.remove('hidden'); }
        if(cartSidebarBadge) cartSidebarBadge.textContent = totalItems;
      } else {
        if(cartCountBadge) cartCountBadge.classList.add('hidden');
        if(cartSidebarBadge) cartSidebarBadge.textContent = '0';
      }

      // 2. Render list of items
      if (cart.length === 0) {
        if(emptyState) emptyState.classList.remove('hidden');
        if(footerSummary) footerSummary.classList.add('hidden');
        if(selectAllBar) selectAllBar.classList.add('hidden');
        // Clear all item elements except empty state
        const itemNodes = cartItemsList.querySelectorAll('.cart-item-node');
        itemNodes.forEach(n => n.remove());
      } else {
        if(emptyState) emptyState.classList.add('hidden');
        if(footerSummary) footerSummary.classList.remove('hidden');

        // Show & update select-all bar
        if(selectAllBar) {
          selectAllBar.classList.remove('hidden');
          const allChecked = cart.every(item => item.checked);
          const selectAllCb = document.getElementById('sidebarSelectAllCb');
          if(selectAllCb) selectAllCb.checked = allChecked;
          const selectedCount = cart.filter(item => item.checked).length;
          const selLabel = document.getElementById('sidebarSelectAllLabel');
          if(selLabel) selLabel.textContent = `Chọn tất cả (${selectedCount}/${cart.length})`;
        }
        
        // Remove existing cart item nodes
        const itemNodes = cartItemsList.querySelectorAll('.cart-item-node');
        itemNodes.forEach(n => n.remove());

        let totalPrice = 0;

        cart.slice().reverse().forEach(item => {
          const itemSubtotal = item.price * item.cartQuantity;
          // Only sum checked items
          if (item.checked) {
            totalPrice += itemSubtotal;
          }

          const itemHtml = `
            <div class="cart-item-node flex gap-3 p-3 bg-gray-50 rounded-2xl border ${
              item.checked ? 'border-nike-orange/25' : 'border-gray-100/50'
            } hover:border-nike-orange/30 transition-all duration-300 relative group">
              <!-- Delete Button -->
              <button onclick="removeFromCart(${item.id}, '${item.size}', '${item.color}')" class="absolute top-2 right-2 text-gray-400 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity p-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
              </button>

              <!-- Checkbox -->
              <div class="flex items-center flex-shrink-0">
                <input type="checkbox" ${item.checked ? 'checked' : ''}
                  onchange="toggleSidebarItem(${item.id}, '${item.size}', '${item.color}', this.checked)"
                  class="w-4 h-4 accent-nike-orange cursor-pointer rounded border-gray-300 focus:ring-nike-orange/50 transition-all">
              </div>
              
              <!-- Image -->
              <div class="w-18 h-18 bg-white rounded-xl flex items-center justify-center border border-gray-100 overflow-hidden p-1 flex-shrink-0" style="width:72px;height:72px">
                <img src="${item.image}" alt="${item.title}" class="w-full h-auto object-contain transform hover:scale-110 transition-transform duration-300" onerror="this.src='/nike.png'">
              </div>

              <!-- Details -->
              <div class="flex-1 flex flex-col justify-between min-w-0">
                <div>
                  <h4 class="font-bold text-xs text-nike-black truncate pr-6">${item.title}</h4>
                  <div class="flex gap-2 text-[10px] text-gray-500 mt-1">
                    <span>Size: <strong class="text-nike-black font-semibold">${item.size}</strong></span>
                    <span>Màu: <strong class="text-nike-black font-semibold">${item.color}</strong></span>
                  </div>
                </div>

                <div class="flex justify-between items-center mt-2">
                  <!-- Qty Controls -->
                  <div class="flex items-center border border-gray-200 rounded-full bg-white px-2 py-0.5">
                    <button onclick="updateQuantity(${item.id}, '${item.size}', '${item.color}', ${item.cartQuantity - 1})" class="text-gray-500 hover:text-nike-black font-bold text-sm px-1 focus:outline-none">-</button>
                    <span class="text-xs font-bold px-2 w-6 text-center">${item.cartQuantity}</span>
                    <button onclick="updateQuantity(${item.id}, '${item.size}', '${item.color}', ${item.cartQuantity + 1})" class="text-gray-500 hover:text-nike-black font-bold text-sm px-1 focus:outline-none">+</button>
                  </div>
                  <!-- Price -->
                  <span class="font-extrabold text-sm ${item.checked ? 'text-nike-orange' : 'text-gray-400'}">${formatPrice(itemSubtotal)}</span>
                </div>
              </div>
            </div>
          `;
          cartItemsList.insertAdjacentHTML('beforeend', itemHtml);
        });

        // Update selected count label in footer
        const selectedCount = cart.filter(item => item.checked).length;
        const checkoutBtn = document.getElementById('sidebarCheckoutBtn');
        if (checkoutBtn) {
          if (selectedCount === 0) {
            checkoutBtn.classList.add('opacity-50', 'pointer-events-none');
          } else {
            checkoutBtn.classList.remove('opacity-50', 'pointer-events-none');
          }
        }
        const selectedInfo = document.getElementById('sidebarSelectedInfo');
        if (selectedInfo) {
          selectedInfo.textContent = selectedCount > 0 ? `Đã chọn ${selectedCount} sản phẩm` : 'Chưa chọn sản phẩm nào';
        }

        if(totalPriceEl) totalPriceEl.textContent = formatPrice(totalPrice);
      }
    }

    // Toggle individual item in sidebar
    function toggleSidebarItem(id, size, color, checked) {
      toggleItemSelect(id, size, color, checked);
      updateCartUI();
    }

    // Toggle all items in sidebar
    function toggleSidebarSelectAll(checked) {
      toggleSelectAll(checked);
      updateCartUI();
    }

    // Helper: format price
    function formatPrice(number) {
      // In the database, price is saved like "2500" or similar representing USD/VND.
      // Let's assume if price is under 50000, it represents USD, so let's multiply by 25000 to display in VND, or display as-is if it's already in millions.
      // Looking at products dump: 
      // 1. Nike Addapt BB 2.0: price '20000000000' (VND or typo)
      // 2. Nike Martine Rose: price '2500' (which means 2.500.000 VND or 2500 USD)
      // Let's formatting it clean. If price >= 100000, we treat it as VND. If price < 100000, we multiply by 1000 to represent thousands of VND (e.g. 2500 -> 2.500.000đ).
      // Let's do a simple clean converter:
      let cleanVal = parseFloat(number);
      if (isNaN(cleanVal)) return number;
      
      if (cleanVal < 100000) {
        // e.g. 2500 -> 2,500,000đ
        cleanVal = cleanVal * 1000;
      }
      
      return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cleanVal);
    }

    // ==========================================
    // WISHLIST CORE LOGIC (LOCALSTORAGE)
    // ==========================================
    function getWishlist() {
      const userKey = getCurrentUserKey();
      if (!userKey) return [];
      const storageKey = `nike_wishlist_${userKey}`;
      const wish = localStorage.getItem(storageKey);
      return wish ? JSON.parse(wish) : [];
    }

    function saveWishlist(wish) {
      const userKey = getCurrentUserKey();
      if (!userKey) return;
      const storageKey = `nike_wishlist_${userKey}`;
      localStorage.setItem(storageKey, JSON.stringify(wish));
      updateWishlistUI();
    }

    function toggleWishlist(product) {
      if (!localStorage.getItem('nike_user')) {
        window.location.href = '/login';
        return;
      }
      const wish = getWishlist();
      const idx = wish.findIndex(item => item.id === product.id);
      
      if (idx !== -1) {
        wish.splice(idx, 1);
        saveWishlist(wish);
      } else {
        wish.push(product);
        saveWishlist(wish);
        // Removed openWishlist() to prevent annoying the user when liking multiple items
      }
    }

    function updateWishlistUI() {
      const wish = getWishlist();
      const wishlistCountBadge = document.getElementById('wishlistCount');
      const wishlistSidebarBadge = document.getElementById('wishlistSidebarCount');
      const wishlistItemsList = document.getElementById('wishlistItemsList');
      const emptyState = document.getElementById('emptyWishlistState');

      // 1. Update badges
      if (wish.length > 0) {
        if(wishlistCountBadge) { wishlistCountBadge.textContent = wish.length; wishlistCountBadge.classList.remove('hidden'); }
        if(wishlistSidebarBadge) wishlistSidebarBadge.textContent = wish.length;
      } else {
        if(wishlistCountBadge) wishlistCountBadge.classList.add('hidden');
        if(wishlistSidebarBadge) wishlistSidebarBadge.textContent = '0';
      }

      // 2. Render list of items
      if (wish.length === 0) {
        if(emptyState) emptyState.classList.remove('hidden');
        const itemNodes = wishlistItemsList.querySelectorAll('.wishlist-item-node');
        itemNodes.forEach(n => n.remove());
      } else {
        if(emptyState) emptyState.classList.add('hidden');
        
        // Remove existing wishlist item nodes
        const itemNodes = wishlistItemsList.querySelectorAll('.wishlist-item-node');
        itemNodes.forEach(n => n.remove());

        wish.forEach(item => {
          const itemHtml = `
            <div class="wishlist-item-node flex gap-4 p-3 bg-gray-50 rounded-2xl border border-gray-100/50 hover:border-red-500/20 transition-all duration-300 relative group">
              <!-- Delete Button -->
              <button onclick="toggleWishlist(JSON.parse(decodeURIComponent('${encodeURIComponent(JSON.stringify(item))}')))" class="absolute top-2 right-2 text-gray-400 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity p-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
              </button>
              
              <!-- Image -->
              <div class="w-16 h-16 bg-white rounded-xl flex items-center justify-center border border-gray-100 overflow-hidden p-1 flex-shrink-0">
                <img src="${item.image}" alt="${item.title}" class="w-full h-auto object-contain" onerror="this.src='/nike.png'">
              </div>

              <!-- Details -->
              <div class="flex-1 flex flex-col justify-between">
                <div>
                  <h4 class="font-bold text-xs text-nike-black truncate w-48">${item.title}</h4>
                  <span class="text-[10px] text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full uppercase inline-block mt-1">${item.category === 'men' ? 'Nam' : item.category === 'women' ? 'Nữ' : 'Trẻ Em'}</span>
                </div>

                <div class="flex justify-between items-center mt-2">
                  <span class="font-extrabold text-sm text-nike-orange">${formatPrice(item.price)}</span>
                  <button onclick="addToCart(JSON.parse(decodeURIComponent('${encodeURIComponent(JSON.stringify(item))}')), '39', 'Trắng', 1)" class="bg-nike-black text-white hover:bg-nike-orange text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider transition-colors duration-200">Thêm vào giỏ</button>
                </div>
              </div>
            </div>
          `;
          wishlistItemsList.insertAdjacentHTML('beforeend', itemHtml);
        });
      }
    }

    // ==========================================
    // AUTHENTICATION STATE RENDERING
    // ==========================================
    function checkAuth() {
      const userStr = localStorage.getItem('nike_user');
      const profileBtn       = document.getElementById('profileBtn');
      const avatarContainer  = document.getElementById('avatarContainer');
      const avatarImg        = document.getElementById('avatarImg');
      const avatarInitials   = document.getElementById('avatarInitials');
      const defaultUserIcon  = document.getElementById('defaultUserIcon');  // new
      const adminDropdownLink= document.getElementById('adminDropdownLink');
      const loginDropdownBtn = document.getElementById('loginDropdownBtn');
      const logoutDropdownBtn= document.getElementById('logoutDropdownBtn');

      // Redirect if accessing a protected page while logged out
      const protectedPages = ['/cart', '/wishlist', '/my-orders', '/profile'];
      if (protectedPages.includes(window.location.pathname) && !userStr) {
        window.location.href = '/login';
        return;
      }

      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          if (profileBtn) profileBtn.href = '#';  // Prevent going to login page
          if (defaultUserIcon) defaultUserIcon.classList.add('hidden'); // hide SVG icon

          // ─── Hiển thị avatar ───
          if (avatarContainer) avatarContainer.classList.remove('hidden');

          // Priority: dbAvatar (uploaded) → Google avatar → initials
          const displayAvatar = user.dbAvatar || user.avatar || null;
          if (displayAvatar && avatarImg) {
            avatarImg.src = displayAvatar;
            avatarImg.classList.remove('hidden');
            if (avatarInitials) avatarInitials.classList.add('hidden');
          } else if (avatarInitials) {
            const name = user.fullname || user.displayName || user.username || '?';
            avatarInitials.textContent = name.charAt(0).toUpperCase();
            avatarInitials.classList.remove('hidden');
            if (avatarImg) avatarImg.classList.add('hidden');
          }

          // Tooltip khi hover — hiển thị tên
          const nameLabel = document.getElementById('profileNameLabel');
          if (nameLabel) {
            nameLabel.textContent = user.fullname || user.displayName || user.username;
          }

          if (user.role === 'admin') {
            if (adminDropdownLink) adminDropdownLink.classList.remove('hidden');
          } else {
            if (adminDropdownLink) adminDropdownLink.classList.add('hidden');
          }
          if (loginDropdownBtn)  loginDropdownBtn.classList.add('hidden');
          if (logoutDropdownBtn) logoutDropdownBtn.classList.remove('hidden');

          // Sync profile from server (async, non-blocking)
          if (user.id && !user._profileLoaded) {
            fetch(`/api/auth/profile/${user.id}`)
              .then(r => r.json())
              .then(data => {
                if (data.status === 'success') {
                  const p = data.data;
                  const updated = Object.assign(user, {
                    fullname: p.fullname || user.fullname,
                    phone: p.phone || user.phone,
                    address: p.address || user.address,
                    city: p.city || user.city,
                    _profileLoaded: true
                  });
                  localStorage.setItem('nike_user', JSON.stringify(updated));
                  // Update displayed name if fullname is set
                  if (p.fullname) {
                    if (nameLabel) nameLabel.textContent = p.fullname;
                    if (avatarInitials && !user.avatar) avatarInitials.textContent = p.fullname.charAt(0).toUpperCase();
                  }
                }
              })
              .catch(() => {});
          }
        } catch (e) {
          localStorage.removeItem('nike_user');
        }
      } else {
        if (profileBtn)    profileBtn.href = '/login';
        if (avatarContainer) avatarContainer.classList.add('hidden');
        if (defaultUserIcon) defaultUserIcon.classList.remove('hidden'); // show SVG icon
        if (adminDropdownLink) adminDropdownLink.classList.add('hidden');
        if (loginDropdownBtn)  loginDropdownBtn.classList.remove('hidden');
        if (logoutDropdownBtn) logoutDropdownBtn.classList.add('hidden');
      }
    }

    function logout() {
      localStorage.removeItem('nike_user');
      window.location.href = "/";
    }

    // Initializations on DOM Load
    document.addEventListener('DOMContentLoaded', () => {
      updateCartUI();
      updateWishlistUI();
      checkAuth();
    });
  </script>
</body>
</html>
