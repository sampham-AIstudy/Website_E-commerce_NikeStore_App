                class="w-full bg-gray-50 border-0 rounded-2xl py-3 px-4 text-xs font-semibold text-gray-800 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 transition-all appearance-none">
                <option value="accessories">Phụ kiện (Accessories)</option>
                <option value="bags">Balo / Túi (Bags)</option>
                <option value="cap">Mũ / Nón (Cap)</option>
                <option value="equipment">Dụng cụ (Equipment)</option>
