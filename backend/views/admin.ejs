    async function updateOrderStatusSubmit() {
      if (!currentSelectedOrderId) return;
      const status = document.getElementById('adminUpdateStatusSelect').value;

      try {
        const response = await fetch(`/api/orders/${currentSelectedOrderId}/status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status })
        });
        const result = await response.json();

        if (result.status === 'success') {
          alert('Đã cập nhật trạng thái đơn hàng thành công!');
          window.location.reload();
        } else {
          alert('Cập nhật thất bại: ' + result.message);
        }
      } catch (e) {
        alert('Lỗi kết nối máy chủ.');
      }
    }

    async function confirmPayment(paymentStatus) {
      if (!currentSelectedOrderId) return;
      const btnPaid   = document.getElementById('btnConfirmPaid');
      const btnFailed = document.getElementById('btnConfirmFailed');
      btnPaid.disabled = true; btnFailed.disabled = true;

      try {
        const response = await fetch(`/api/orders/${currentSelectedOrderId}/payment-status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ payment_status: paymentStatus })
        });
        const result = await response.json();

        if (result.status === 'success') {
          currentOrderPaymentStatus = paymentStatus;
          const statusMap = { pending: '⏳ Chờ xác nhận', paid: '✔ Đã nhận tiền', failed: '✗ Thất bại' };
          const colorMap  = { pending: 'text-amber-600', paid: 'text-green-600', failed: 'text-red-600' };
          const badge = document.getElementById('adminPaymentStatusBadge');
          badge.textContent = statusMap[paymentStatus];
          badge.className = 'font-bold ' + (colorMap[paymentStatus] || 'text-gray-600');
          btnPaid.disabled   = paymentStatus === 'paid';
          btnFailed.disabled = paymentStatus === 'failed';
          // Cập nhật dấu hiệu trên bảng không cần reload
          const rowBtn = document.querySelector(`button[data-id="${currentSelectedOrderId}"]`);
          if (rowBtn) rowBtn.setAttribute('data-payment-status', paymentStatus);
        } else {
          alert('Lỗi: ' + result.message);
          btnPaid.disabled = false; btnFailed.disabled = false;
        }
      } catch (e) {
        alert('Lỗi kết nối máy chủ.');
        btnPaid.disabled = false; btnFailed.disabled = false;
      }
    }

