    // 1. Verification of admin session
    function verifyAdminAccess() {
      const userStr = localStorage.getItem('nike_user');
      if (!userStr) {
        window.location.href = '/login';
        return;
      }
      try {
        const user = JSON.parse(userStr);
        if (user.role !== 'admin') {
          window.location.href = '/login';
          return;
        }
        
        // Show panel
        document.getElementById('adminPanelLoading').classList.add('hidden');
        document.getElementById('adminPanelContent').classList.remove('hidden');
      } catch (e) {
        window.location.href = '/login';
      }
    }

    // 2. Tab switching
    function switchAdminTab(tab) {
      if (activeAdminTab === tab) return;
      activeAdminTab = tab;
      sessionStorage.setItem('adminCurrentTab', tab);

      // Reset styles
      document.querySelectorAll('.admin-tab-btn').forEach(btn => {
        btn.className = "admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black";
      });
      document.querySelectorAll('.admin-tab-content').forEach(c => {
        c.classList.add('hidden');
      });

      // Set active
      const activeBtn = document.getElementById(`tabBtn-${tab}`);
      activeBtn.className = "admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-nike-orange text-nike-orange";
      
      document.getElementById(`tabContent-${tab}`).classList.remove('hidden');
    }

    // ==========================================
    // ORDERS DYNAMICS (MODAL & UPDATE)
    // ==========================================
    async function viewOrderDetails(elementOrId) {
      const orderId = typeof elementOrId === 'object' ? elementOrId.getAttribute('data-id') : elementOrId;
      currentSelectedOrderId = orderId;
      currentOrderPaymentMethod = (typeof elementOrId === 'object' ? elementOrId.getAttribute('data-payment-method') : 'cod') || 'cod';
      currentOrderPaymentStatus = (typeof elementOrId === 'object' ? elementOrId.getAttribute('data-payment-status') : 'pending') || 'pending';

      document.getElementById('adminModalOrderId').textContent = '#' + orderId;

      // Hiện/ẩn khu vực xác nhận thanh toán VPBank
      const paymentBox = document.getElementById('adminPaymentConfirmBox');
      const statusBadge = document.getElementById('adminPaymentStatusBadge');
      if (currentOrderPaymentMethod.toLowerCase() === 'vpbank') {
        paymentBox.classList.remove('hidden');
        const statusMap = { pending: '⏳ Chờ xác nhận', paid: '✔ Đã nhận tiền', failed: '✗ Thất bại' };
        const colorMap = { pending: 'text-amber-600', paid: 'text-green-600', failed: 'text-red-600' };
        statusBadge.textContent = statusMap[currentOrderPaymentStatus] || currentOrderPaymentStatus;
        statusBadge.className = 'font-bold ' + (colorMap[currentOrderPaymentStatus] || 'text-gray-600');
        document.getElementById('btnConfirmPaid').disabled = currentOrderPaymentStatus === 'paid';
        document.getElementById('btnConfirmFailed').disabled = currentOrderPaymentStatus === 'failed';
      } else {
        paymentBox.classList.add('hidden');
      }

      const itemsList = document.getElementById('adminModalItemsList');
      itemsList.innerHTML = '<div class="text-center py-6 text-gray-400 font-bold text-xs">Đang tải chi tiết đơn hàng...</div>';

      const modal = document.getElementById('adminOrderModal');
      modal.classList.remove('hidden');

      try {
        const resDetail = await fetch(`/api/orders/${orderId}`);
        const resultDetail = await resDetail.json();

        if (resultDetail.status === 'success' && resultDetail.items) {
          itemsList.innerHTML = '';
          
          // Set status dropdown
          document.getElementById('adminUpdateStatusSelect').value = resultDetail.order.status;

          resultDetail.items.forEach(item => {
            const itemHtml = `
              <div class="flex gap-4 p-3 bg-gray-50 border rounded-2xl items-center">
                <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center p-1 border overflow-hidden flex-shrink-0">
                  <img src="${item.image}" alt="${item.title}" class="w-full h-auto object-contain" onerror="this.src='/nike.png'">
                </div>
                <div class="flex-grow min-w-0">
                  <h4 class="font-bold text-xs text-gray-800 truncate">${item.title}</h4>
                  <div class="flex gap-2 text-[10px] text-gray-400 mt-0.5">
                    <span>Size: <strong class="text-nike-black font-semibold">${item.size}</strong></span>
                    <span>Màu: <strong class="text-nike-black font-semibold">${item.color}</strong></span>
                    <span>Số lượng: <strong class="text-nike-black font-semibold">${item.quantity}</strong></span>
                  </div>
                </div>
                <span class="font-extrabold text-xs text-nike-orange">${formatPrice(item.price * item.quantity)}</span>
              </div>
            `;
            itemsList.insertAdjacentHTML('beforeend', itemHtml);
          });
        } else {
          itemsList.innerHTML = `<div class="text-center py-6 text-red-500 font-bold text-xs">Không tải được chi tiết đơn hàng: ${resultDetail.message}</div>`;
        }
      } catch (err) {
        itemsList.innerHTML = `<div class="text-center py-6 text-red-500 font-bold text-xs">Lỗi kết nối máy chủ: ${err.message}</div>`;
      }
    }

