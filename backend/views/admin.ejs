      function fetchAnalytics() {
        const range = document.getElementById('analyticsTimeFilter').value || '30d';
        document.getElementById('analyticsLoading').classList.remove('hidden');

        fetch('/api/analytics/v2/dashboard?range=' + range)
          .then(r => r.json())
          .then(res => {
            if (res.status !== 'success') throw new Error(res.message);

            const data = res.data;

            // Render KPIs
            document.getElementById('kpiNetRevenue').textContent = fmtM(data.kpi.confirmed_revenue) + ' ₫';
            document.getElementById('kpiTotalOrders2').textContent = data.kpi.total_orders;
            document.getElementById('kpiSuccessRate').textContent = 'Thành công: ' + data.kpi.success_rate + '%';
            document.getElementById('kpiTotalCustomers').textContent = data.kpi.total_customers;
            document.getElementById('kpiLowStockWarning').textContent = data.kpi.low_stock_count;

            // Render Charts (if Chart.js is loaded)
            if (typeof Chart !== 'undefined') {
              renderRevenueChartV2(data.revenueChart);
              renderOrderStatusChart(data.orderStatusChart);
              renderCategoryChartV2(data.categoryChart);
            } else {
              console.warn('Chart.js chưa được tải. Không thể vẽ biểu đồ.');
            }

            // Render Tables & Insights
            renderTopProductsV2(data.topProducts || []);
            renderSmartInsights(data.insights || []);

          })
          .catch(err => {
            console.error(err);
            alert('Lỗi tải thống kê: ' + err.message);
          })
          .finally(() => {
            document.getElementById('analyticsLoading').classList.add('hidden');
          });
      }

      function renderRevenueChartV2(data) {
        const ctx = document.getElementById('chartRevenue');
        if (!ctx) return;
        if (chartRevenueInst) chartRevenueInst.destroy();

        const labels = data.map(d => {
          // Rút gọn label nếu là YYYY-MM-DD
          let lbl = d.label;
          if (lbl && lbl.length === 10) {
            const parts = lbl.split('-');
            return parts[2] + '/' + parts[1];
          }
          return lbl;
        });
        const values = data.map(d => parseFloat(d.value) || 0);

        chartRevenueInst = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Doanh Thu (VNĐ)',
              data: values,
              borderColor: '#f97316', // nike-orange
              backgroundColor: 'rgba(249,115,22,0.1)',
              borderWidth: 2,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#f97316',
              pointRadius: 4,
              pointHoverRadius: 6,
              fill: true,
              tension: 0.4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: function (context) { return fmtM(context.parsed.y) + ' ₫'; }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: { color: '#f3f4f6', drawBorder: false },
                ticks: { callback: function (val) { return fmtM(val); }, font: { size: 10 } }
              },
              x: {
                grid: { display: false, drawBorder: false },
                ticks: { maxTicksLimit: 10, font: { size: 10 } }
              }
            }
          }
        });
      }

      function renderOrderStatusChart(data) {
        const ctx = document.getElementById('chartOrderStatus');
        if (!ctx) return;
        if (chartOrderStatusInst) chartOrderStatusInst.destroy();

        const labelsRaw = data.map(d => d.status);
        const values = data.map(d => parseInt(d.count));

        // Map status text & colors
        const map = {
          'pending': { text: 'Chờ xử lý', color: '#f59e0b' },
          'pending_payment': { text: 'Chờ TT', color: '#fbbf24' },
          'processing': { text: 'Đang xử lý', color: '#3b82f6' },
          'shipped': { text: 'Đang giao', color: '#6366f1' },
          'delivered': { text: 'Thành công', color: '#10b981' },
          'returning': { text: 'Đang trả', color: '#ec4899' },
          'returned': { text: 'Đã hoàn trả', color: '#9ca3af' },
          'cancelled': { text: 'Đã hủy', color: '#ef4444' }
        };

        const labels = labelsRaw.map(l => {
          if (!l || String(l).trim() === '') return 'Chưa xác định';
          return map[l] ? map[l].text : String(l);
        });
        const colors = labelsRaw.map(l => {
          if (!l || String(l).trim() === '') return '#d1d5db';
          return map[l] ? map[l].color : '#9ca3af';
        });

        chartOrderStatusInst = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: labels,
            datasets: [{
              data: values,
              backgroundColor: colors,
              borderWidth: 0,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '75%',
            plugins: {
              legend: { position: 'right', labels: { boxWidth: 10, font: { size: 10 } } }
