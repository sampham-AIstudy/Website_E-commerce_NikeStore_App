        let applyScope = document.getElementById('voucherApplyScope').value;
        let scopeValue = null;
        if (applyScope === 'category') {
          let checked = document.querySelectorAll('#voucherCategoryCheckboxes input:checked');
          scopeValue = Array.from(checked).map(c => c.value).join(',');
