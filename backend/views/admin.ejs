                <p class="text-[9px] text-gray-400 mt-0.5">ID: #${p.id}</p>
              </div>
            </div>
          </td>
          <td class="p-3 text-right font-extrabold text-nike-black">${sold}</td>
          <td class="p-3 text-right font-bold text-emerald-600 text-[11px]">${fmtM(rev)} ₫</td>
          <td class="p-3 text-right text-xs">${stkHtml}</td>
        </tr>`;
        }).join('');
