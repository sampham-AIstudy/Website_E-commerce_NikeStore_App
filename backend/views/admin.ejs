        document.getElementById('adminModalOrderId').textContent = '#' + orderId;

        // Hiện/ẩn khu vực xác nhận thanh toán VPBank / VNPay
        const paymentBox = document.getElementById('adminPaymentConfirmBox');
        const statusBadge = document.getElementById('adminPaymentStatusBadge');
        const paymentTitle = document.getElementById('adminPaymentConfirmTitle');
        const btnConfirmPaid = document.getElementById('btnConfirmPaid');
        const btnConfirmFailed = document.getElementById('btnConfirmFailed');

        const isVPBank = currentOrderPaymentMethod.toLowerCase() === 'vpbank';
        const isVNPay = currentOrderPaymentMethod.toLowerCase().startsWith('vnpay');

        if (isVPBank || isVNPay) {
          paymentBox.classList.remove('hidden');
          paymentTitle.textContent = isVPBank ? 'Xác nhận thanh toán VPBank' : 'Thanh toán VNPay';

          // Đổi màu box
          if (isVPBank) {
            paymentBox.className = 'p-3 bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl border border-green-200 space-y-2';
            paymentTitle.className = 'text-[10px] font-bold text-green-700 uppercase tracking-wider';
            btnConfirmPaid.classList.remove('hidden');
            btnConfirmFailed.classList.remove('hidden');
          } else {
            paymentBox.className = 'p-3 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border border-blue-200 space-y-2';
            paymentTitle.className = 'text-[10px] font-bold text-blue-700 uppercase tracking-wider';
            // VNPay tự động qua Webhook, Admin không cần nút xác nhận thủ công
            btnConfirmPaid.classList.add('hidden');
            btnConfirmFailed.classList.add('hidden');
          }

          const statusMap = { pending: '⏳ Chờ thanh toán', paid: '✔ Đã thanh toán', failed: '✗ Thất bại' };
          const colorMap = { pending: 'text-amber-600', paid: 'text-green-600', failed: 'text-red-600' };
          statusBadge.textContent = statusMap[currentOrderPaymentStatus] || currentOrderPaymentStatus;
          statusBadge.className = 'font-bold ' + (colorMap[currentOrderPaymentStatus] || 'text-gray-600');

          btnConfirmPaid.disabled = currentOrderPaymentStatus === 'paid';
          btnConfirmFailed.disabled = currentOrderPaymentStatus === 'failed';
        } else {
          paymentBox.classList.add('hidden');
        }

        const itemsList = document.getElementById('adminModalItemsList');
        itemsList.innerHTML = '<div class="text-center py-6 text-gray-400 font-bold text-xs">Đang tải chi tiết đơn hàng...</div>';

        const modal = document.getElementById('adminOrderModal');
        modal.classList.remove('hidden');

        try {
          const resDetail = await fetch(`/api/orders/${orderId}`);
          const resultDetail = await resDetail.json();

          if (resultDetail.status === 'success' && resultDetail.items) {
            itemsList.innerHTML = '';

            // Set status dropdown
            document.getElementById('adminUpdateStatusSelect').value = resultDetail.order.status;

            // Set return reason if exists
            const returnReasonBox = document.getElementById('adminReturnReasonBox');
            if (resultDetail.order.return_reason) {
              returnReasonBox.classList.remove('hidden');
              document.getElementById('adminReturnReasonText').textContent = resultDetail.order.return_reason;
            } else {
              returnReasonBox.classList.add('hidden');
            }

            resultDetail.items.forEach(item => {
              const itemHtml = `
              <div class="flex gap-4 p-3 bg-gray-50 border rounded-2xl items-center">
                <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center p-1 border overflow-hidden flex-shrink-0">
                  <img src="${item.image}" alt="${item.title}" class="w-full h-auto object-contain" onerror="this.src='/nike.png'">
