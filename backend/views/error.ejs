<%- include('partials/header', { title: 'Lỗi - Nike Store' }) %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
  <h1 class="text-4xl font-black text-nike-black mb-4">Opps! <%= error.status || 500 %></h1>
  <h2 class="text-xl text-gray-500 mb-8"><%= message || "Đã xảy ra lỗi không mong muốn." %></h2>
  <a href="/" class="bg-nike-black text-white px-8 py-3 rounded-full font-bold uppercase hover:bg-nike-orange transition-colors">Quay về trang chủ</a>
  <% if (error.stack) { %>
    <div class="mt-12 text-left bg-gray-100 p-6 rounded-lg overflow-x-auto text-xs text-gray-500">
      <pre><%= error.stack %></pre>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
