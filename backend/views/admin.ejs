    <!-- Admin Verification & Tab JS Routing -->
    <!-- JSON Data for Orders -->
    <script id="adminOrdersDataJson" type="application/json">
    <%- JSON.stringify(orders || []) %>
  </script>

    <script>
      // ── ADMIN ORDERS LOGIC ───────────────────────────────────────────────────
      const adminOrdersData = JSON.parse(document.getElementById('adminOrdersDataJson').textContent || '[]');
      let currentOrderStatusTab = 'all';

      function formatPriceJS(number) {
        let cleanVal = parseFloat(String(number).replace(/[^0-9.-]+/g, ""));
        if (isNaN(cleanVal)) return number;
        return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cleanVal);
      }

      function switchOrderStatusTab(tab) {
        currentOrderStatusTab = tab;
        document.querySelectorAll('.order-status-tab').forEach(btn => {
          btn.classList.remove('text-nike-orange', 'border-nike-orange');
          btn.classList.add('text-gray-400', 'border-transparent');
        });
        const activeBtn = document.getElementById('btnTab-' + tab);
        if (activeBtn) {
          activeBtn.classList.remove('text-gray-400', 'border-transparent');
          activeBtn.classList.add('text-nike-orange', 'border-nike-orange');
        }
        renderAdminOrders();
      }

      function toggleCustomDate() {
        const val = document.getElementById('orderDateFilter').value;
        const customRange = document.getElementById('customDateRange');
        if (val === 'custom') {
          customRange.classList.remove('hidden');
        } else {
          customRange.classList.add('hidden');
        }
      }

      function renderAdminOrders() {
        const searchStr = (document.getElementById('orderSearchInput')?.value || '').toLowerCase().trim();
        const dateFilter = document.getElementById('orderDateFilter')?.value || 'all';
        const sortFilter = document.getElementById('orderSortFilter')?.value || 'newest';

        const dateFromStr = document.getElementById('orderDateFrom')?.value;
        const dateToStr = document.getElementById('orderDateTo')?.value;

        // Base Filter
        let baseFiltered = adminOrdersData.filter(order => {
          // Search
          const orderIdMatch = String(order.id).toLowerCase().includes(searchStr);
          const nameMatch = (order.fullname || '').toLowerCase().includes(searchStr);
          const phoneMatch = (order.phone || '').toLowerCase().includes(searchStr);
          const emailMatch = (order.email || '').toLowerCase().includes(searchStr);
          if (searchStr && !orderIdMatch && !nameMatch && !phoneMatch && !emailMatch) return false;

          // Date
          const orderDate = new Date(order.created_at);
          const today = new Date();
          today.setHours(0, 0, 0, 0);

          if (dateFilter === 'today') {
            if (orderDate < today) return false;
          } else if (dateFilter === '7days') {
            const past7 = new Date(); past7.setDate(past7.getDate() - 7); past7.setHours(0, 0, 0, 0);
            if (orderDate < past7) return false;
          } else if (dateFilter === '30days') {
            const past30 = new Date(); past30.setDate(past30.getDate() - 30); past30.setHours(0, 0, 0, 0);
            if (orderDate < past30) return false;
          } else if (dateFilter === 'custom') {
            if (dateFromStr) {
              const f = new Date(dateFromStr); f.setHours(0, 0, 0, 0);
              if (orderDate < f) return false;
            }
            if (dateToStr) {
              const t = new Date(dateToStr); t.setHours(23, 59, 59, 999);
              if (orderDate > t) return false;
            }
          }
          return true;
        });

        // Update Counts
        const counts = { all: 0, pending: 0, processing: 0, shipped: 0, delivered: 0, returned: 0, cancelled: 0 };
        baseFiltered.forEach(o => {
          counts.all++;
          if (o.status === 'pending' || o.status === 'pending_payment') counts.pending++;
          else if (o.status === 'returned' || o.status === 'returning') counts.returned++;
          else if (counts[o.status] !== undefined) counts[o.status]++;
        });
        Object.keys(counts).forEach(k => {
          const el = document.getElementById('count-' + k);
          if (el) el.textContent = counts[k];
        });
        const dot = document.getElementById('dot-pending');
        if (dot) {
          if (counts.pending > 0) dot.classList.remove('hidden');
          else dot.classList.add('hidden');
        }

        // Tab Filter
        let filtered = baseFiltered.filter(order => {
          if (currentOrderStatusTab !== 'all') {
            if (currentOrderStatusTab === 'pending') {
              if (order.status !== 'pending' && order.status !== 'pending_payment') return false;
            } else if (currentOrderStatusTab === 'returned') {
              if (order.status !== 'returned' && order.status !== 'returning') return false;
            } else {
              if (order.status !== currentOrderStatusTab) return false;
            }
          }
          return true;
        });

        // Sort
        filtered.sort((a, b) => {
          if (sortFilter === 'newest') return new Date(b.created_at) - new Date(a.created_at);
          if (sortFilter === 'oldest') return new Date(a.created_at) - new Date(b.created_at);
          if (sortFilter === 'price_desc') return b.total_amount - a.total_amount;
          if (sortFilter === 'price_asc') return a.total_amount - b.total_amount;
          return 0;
        });
        if (dot) {
          if (counts.pending > 0) dot.classList.remove('hidden');
          else dot.classList.add('hidden');
        }

        // Render
        const tbody = document.getElementById('adminOrdersTableBody');
        const emptyState = document.getElementById('adminOrdersEmptyState');
        const tableDiv = tbody.parentElement.parentElement; // overflow-x-auto

        if (filtered.length === 0) {
          tableDiv.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          tableDiv.classList.remove('hidden');
          emptyState.classList.add('hidden');

          tbody.innerHTML = filtered.map(order => {
            const pMethod = (order.payment_method || 'cod').toLowerCase();
            const pStatus = (order.payment_status || 'pending').toLowerCase();

            let paymentHtml = '';
            if (pMethod === 'vpbank') {
              paymentHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-200 mb-1 block w-max">🏦 VPBank</span>`;
            } else if (pMethod.startsWith('vnpay')) {
              paymentHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold border mb-1 block w-max" style="background:#eff6ff;color:#005baa;border-color:#bfdbfe">🏦 VNPay</span>`;
            } else {
              paymentHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-600 mb-1 block w-max">🚚 COD</span>`;
            }

            if (pMethod !== 'cod') {
              if (pStatus === 'paid') paymentHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700 block w-max">✔ Đã thanh toán</span>`;
              else if (pStatus === 'failed') paymentHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700 block w-max">✗ Thất bại</span>`;
              else paymentHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-700 block w-max">⏳ Chờ TT</span>`;
            }

            let statusHtml = '';
            if (order.status === 'pending' || order.status === 'pending_payment') statusHtml = `<span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-orange-100 text-orange-800">Chờ duyệt</span>`;
            else if (order.status === 'processing') statusHtml = `<span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-800">Chờ lấy hàng</span>`;
            else if (order.status === 'shipped') statusHtml = `<span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-purple-100 text-purple-800">Đang giao</span>`;
            else if (order.status === 'delivered') statusHtml = `<span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-green-100 text-green-800">Hoàn thành</span>`;
            else if (order.status === 'returned') statusHtml = `<span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-800">Đã hoàn tiền</span>`;
            else if (order.status === 'returning') statusHtml = `<span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-amber-100 text-amber-800 animate-pulse">Y/c Trả hàng</span>`;
            else statusHtml = `<span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-100 text-red-800">Đã hủy</span>`;

            // Quick Actions
            let actionsHtml = `<button onclick="viewOrderDetails(this)" data-id="${order.id}" data-payment-method="${order.payment_method || 'cod'}" data-payment-status="${order.payment_status || 'pending'}" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors shadow-sm mb-1 w-full text-center">Xem</button>`;
            if (order.status === 'pending') {
              actionsHtml += `<button onclick="updateOrderStatusAPI(${order.id}, 'processing')" class="bg-blue-500 hover:bg-blue-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors shadow-sm mb-1 w-full text-center">Duyệt</button>`;
              actionsHtml += `<button onclick="updateOrderStatusAPI(${order.id}, 'cancelled')" class="bg-red-500 hover:bg-red-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors shadow-sm mb-1 w-full text-center">Hủy</button>`;
            } else if (order.status === 'processing') {
              actionsHtml += `<button onclick="updateOrderStatusAPI(${order.id}, 'shipped')" class="bg-purple-500 hover:bg-purple-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors shadow-sm mb-1 w-full text-center">Giao hàng</button>`;
            } else if (order.status === 'shipped') {
              actionsHtml += `<button onclick="updateOrderStatusAPI(${order.id}, 'delivered')" class="bg-green-500 hover:bg-green-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors shadow-sm mb-1 w-full text-center">Hoàn thành</button>`;
            } else if (order.status === 'returning') {
              actionsHtml += `<button onclick="updateOrderStatusAPI(${order.id}, 'returned')" class="bg-amber-500 hover:bg-amber-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors shadow-sm mb-1 w-full text-center">Duyệt hoàn tiền</button>`;
            }

            return `
            <tr class="hover:bg-gray-50/30 transition-colors">
              <td class="p-4 font-bold text-nike-orange">#${order.id}</td>
              <td class="p-4">
                <div class="font-bold text-gray-800">${order.fullname}</div>
                <div class="text-xs text-gray-500">${order.phone}</div>
              </td>
              <td class="p-4">${statusHtml}</td>
              <td class="p-4">${paymentHtml}</td>
              <td class="p-4 font-extrabold text-nike-black">${formatPriceJS(order.total_amount)}</td>
              <td class="p-4 text-gray-500 text-xs font-medium">
                ${new Date(order.created_at).toLocaleDateString('vi-VN', { hour: '2-digit', minute: '2-digit' })}
              </td>
              <td class="p-4">
                <div class="flex flex-col items-center justify-center">${actionsHtml}</div>
              </td>
            </tr>
          `;
          }).join('');
        }
      }

      function exportToCSV() {
        if (!adminOrdersData || adminOrdersData.length === 0) {
          alert("Không có đơn hàng nào để xuất!");
          return;
        }
        let csvContent = "Mã Đơn,Khách Hàng,Số Điện Thoại,Email,Tổng Tiền,Phương Thức TT,Trạng Thái TT,Trạng Thái Đơn,Ngày Đặt\\n";
        adminOrdersData.forEach(o => {
          let id = o.id;
          let name = (o.fullname || "").replace(/,/g, " ");
          let phone = (o.phone || "");
          let email = (o.email || "").replace(/,/g, " ");
          let total = o.total_amount;
          let pm = o.payment_method || "cod";
          let ps = o.payment_status || "pending";
          let status = o.status;
          let date = new Date(o.created_at).toLocaleString('vi-VN');
          csvContent += `${id},${name},${phone},${email},${total},${pm},${ps},${status},${date}\\n`;
        });
        const blob = new Blob(["\\uFEFF" + csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.setAttribute("href", url);
        link.setAttribute("download", `Don_Hang_Nike_${new Date().getTime()}.csv`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      }

      function updateOrderStatusAPI(orderId, newStatus) {
        let statusText = newStatus;
        if (newStatus === 'processing') statusText = 'Đang soạn hàng';
        else if (newStatus === 'shipped') statusText = 'Đang giao hàng';
        else if (newStatus === 'delivered') statusText = 'Đã giao thành công';
        else if (newStatus === 'returned') statusText = 'Đã hoàn tiền (Trả hàng)';
        else if (newStatus === 'cancelled') statusText = 'Đã hủy đơn';

        if (!confirm("Bạn có chắc muốn chuyển trạng thái đơn #" + orderId + " sang: " + statusText + "?")) return;

        fetch(`/api/orders/${orderId}/status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus })
        })
          .then(res => {
            if (!res.ok) throw new Error("Cập nhật thất bại");
            return res.json();
          })
          .then(data => {
            if (data.status === 'success') {
              // Cập nhật mảng data
              const idx = adminOrdersData.findIndex(o => o.id === orderId);
              if (idx !== -1) adminOrdersData[idx].status = newStatus;
              renderAdminOrders();
              alert("Cập nhật trạng thái thành công!");
            } else {
              alert('Cập nhật thất bại: ' + data.message);
            }
          })
          .catch(err => {
            console.error(err);
            alert("Lỗi khi cập nhật trạng thái!");
          });
      }

