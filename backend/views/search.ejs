<%- include('partials/header', { title: 'Nike Store - Tìm Kiếm Sản Phẩm' }) %>

  <% 
    /* Helper to format price in EJS */
    function formatPrice(number) { 
      let cleanVal = parseFloat(String(number).replace(/[^0-9.-]+/g,"")); 
      if (isNaN(cleanVal)) return number; 
      if (cleanVal < 100000) { cleanVal = cleanVal * 1000; } 
      return new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND' }).format(cleanVal); 
    } 
  %>

    <!-- ========================================== -->
    <!-- SEARCH BAR BANNER                          -->
    <!-- ========================================== -->
    <div class="bg-gradient-to-r from-zinc-900 to-sky-950 text-white py-12 relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(255,84,0,0.1),transparent)]"></div>
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col justify-center items-center text-center space-y-4">
        <span class="text-nike-orange font-extrabold text-xs uppercase tracking-widest block">Tìm kiếm sản phẩm</span>
        <h1 class="text-2xl sm:text-4xl font-black uppercase tracking-tight">Kết Quả Tìm Kiếm</h1>

        <!-- Live Search Box inside page -->
        <form action="/search" method="GET"
          class="relative w-full max-w-lg mt-2 shadow-xl rounded-full overflow-hidden">
          <input type="text" name="q" value="<%= query %>" placeholder="Tìm giày Nike, dòng sản phẩm..." required
            class="bg-white/95 border-0 rounded-full py-4 pl-6 pr-16 text-sm text-nike-black font-semibold focus:outline-none w-full shadow-inner">
          <button type="submit"
            class="bg-nike-orange hover:bg-nike-black text-white px-5 py-4 absolute right-0 top-0 transition-colors duration-250 font-bold text-xs uppercase tracking-wider flex items-center justify-center">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
        </form>

        <p class="text-xs text-gray-400 font-light">
          Đang hiển thị kết quả cho từ khóa: <strong class="text-white">"<%= query %>"</strong> (<%= products.length %>
            kết quả)
        </p>
      </div>
    </div>

    <!-- ========================================== -->
    <!-- PRODUCTS CONTAINER                         -->
    <!-- ========================================== -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

      <% if (products.length> 0) { %>
        <!-- Top Filter Bar -->
        <div class="flex flex-col lg:flex-row justify-between items-center bg-white rounded-3xl p-5 border border-gray-100 shadow-sm gap-4 mb-10 relative">
          <!-- Left: Secondary Search -->
          <div class="relative w-full lg:w-80">
            <input type="text" id="catSearchInput" placeholder="Lọc kết quả trong trang..." class="bg-gray-50 border-0 rounded-full py-2.5 pl-4 pr-10 text-xs focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full font-medium">
            <svg class="w-4 h-4 text-gray-400 absolute right-3.5 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>

          <!-- Right: Filter Button & Count -->
          <div class="flex items-center justify-between w-full lg:w-auto gap-4">
            <span class="text-xs text-gray-400 font-bold hidden lg:inline border-r pr-4 border-gray-200">Hiển thị <span id="visibleProductsCount" class="text-nike-black font-extrabold"><%= products.length %></span> sản phẩm</span>
            
            <!-- Filter Toggle Button -->
            <button onclick="document.getElementById('catFilterPanel').classList.toggle('hidden')" class="bg-white border-2 border-gray-100 hover:border-nike-orange text-gray-700 hover:text-nike-orange font-bold text-xs px-5 py-2.5 rounded-full flex items-center justify-center gap-2 transition-all shadow-sm focus:outline-none w-full sm:w-auto">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
              Bộ Lọc
            </button>
          </div>

          <!-- Filter Panel (Dropdown) -->
          <div id="catFilterPanel" class="hidden absolute top-[110%] right-0 mt-2 w-full lg:w-[500px] bg-white rounded-3xl border border-gray-100 shadow-2xl p-6 z-[100]">
            <div class="flex justify-between items-center mb-5 border-b border-gray-50 pb-3">
              <h3 class="font-extrabold text-sm uppercase tracking-wider text-nike-black">Tùy chỉnh bộ lọc</h3>
              <button onclick="document.getElementById('catFilterPanel').classList.add('hidden')" class="text-gray-400 hover:text-nike-orange focus:outline-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="space-y-2">
                <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Loại sản phẩm</span>
                <select id="catTypeFilter" class="bg-gray-50 border-0 rounded-xl py-3 px-4 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
                  <option value="">Tất cả</option>
                  <option value="shoes">Giày</option>
                  <option value="bags">Balo/Túi</option>
                  <option value="cap">Mũ/Nón</option>
                  <option value="equipment">Dụng cụ</option>
                  <option value="hoodie">Áo Hoodie</option>
                  <option value="jacket">Áo khoác</option>
                  <option value="pants">Quần dài</option>
                  <option value="shirt">Áo thun</option>
                  <option value="shorts">Quần ngắn</option>
                  <option value="socks">Tất/Vớ</option>
                  <option value="accessories">Phụ kiện</option>
                </select>
              </div>

              <div class="space-y-2">
                <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Khoảng giá</span>
                <select id="catPriceFilter" class="bg-gray-50 border-0 rounded-xl py-3 px-4 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
                  <option value="">Tất cả mức giá</option>
                  <option value="under-1m">Dưới 1.000.000₫</option>
                  <option value="1m-2m">1.000.000₫ - 2.000.000₫</option>
                  <option value="2m-4m">2.000.000₫ - 4.000.000₫</option>
                  <option value="over-4m">Trên 4.000.000₫</option>
                </select>
              </div>

              <div class="space-y-2 sm:col-span-2 border-t border-gray-50 pt-3">
                <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Sắp xếp theo</span>
                <div class="flex flex-wrap gap-2">
                  <button class="catSortBtn active flex-1 bg-nike-black text-white py-2 px-3 rounded-xl text-[11px] font-bold transition-colors shadow-sm" data-sort="default">Mặc định</button>
                  <button class="catSortBtn flex-1 bg-gray-50 text-gray-600 hover:bg-gray-200 py-2 px-3 rounded-xl text-[11px] font-bold transition-colors" data-sort="price-asc">Giá Thấp ➡ Cao</button>
                  <button class="catSortBtn flex-1 bg-gray-50 text-gray-600 hover:bg-gray-200 py-2 px-3 rounded-xl text-[11px] font-bold transition-colors" data-sort="price-desc">Giá Cao ➡ Thấp</button>
                </div>
                <input type="hidden" id="catSortSelect" value="default">
              </div>
            </div>

            <div class="mt-6">
              <button onclick="document.getElementById('catFilterPanel').classList.add('hidden')" class="w-full bg-nike-orange hover:bg-orange-600 text-white font-bold text-xs py-3 rounded-xl uppercase tracking-wider transition-colors shadow-md">
                Xem kết quả
              </button>
            </div>
          </div>
        </div>

        <!-- Product Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" id="categoryProductsGrid">
          <% products.forEach(product=> { %>
            <% 
              let numPrice = parseFloat(product.price);
              let finalPrice = numPrice;
              if (product.discount_percent > 0) {
                finalPrice = numPrice * (1 - product.discount_percent / 100);
              }
              if (finalPrice < 100000) {
                finalPrice = finalPrice * 1000;
              }
            %>
            <div class="cat-product-card group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl border border-gray-100/60 hover:border-nike-orange/15 transition-all duration-300 flex flex-col relative"
                 data-title="<%= product.title.toLowerCase() %>"
                 data-price="<%= finalPrice %>"
                 data-rating="<%= product.rating || 4.5 %>"
                 data-sizes="<%= product.sizes %>"
                 data-item-type="<%= (product.item_type || 'shoes').toLowerCase() %>">

              <!-- Badges (New / Discount) -->
              <div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
                <% if (product.is_new) { %>
                  <span
                    class="bg-red-500 text-white font-extrabold text-[9px] uppercase tracking-widest px-2.5 py-1 rounded-full shadow-sm">NEW</span>
                  <% } %>
                    <% if (product.discount_percent> 0) { %>
                      <span
                        class="bg-nike-orange text-white font-extrabold text-[9px] uppercase tracking-widest px-2.5 py-1 rounded-full shadow-sm">SALE
                        -<%= product.discount_percent %>%</span>
                      <% } %>
              </div>

              <!-- Like / Wishlist Toggle -->
              <button
                onclick="toggleWishlist(JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(product)) %>')))"
                class="absolute top-4 right-4 z-20 w-8 h-8 rounded-full bg-white/80 hover:bg-red-50 hover:text-red-500 border border-gray-100 flex items-center justify-center text-gray-500 shadow-sm transition-all duration-200 focus:outline-none">
                <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                  </path>
                </svg>
              </button>

              <!-- Image Panel -->
              <div
                class="h-60 bg-gradient-to-b from-gray-50/50 to-white flex items-center justify-center overflow-hidden p-6 relative">
                <a href="/products/<%= product.id %>" class="w-full h-full flex items-center justify-center">
                  <img src="<%= product.image %>" alt="<%= product.title %>"
                    class="max-w-[85%] max-h-full object-contain transform group-hover:scale-115 group-hover:rotate-[-6deg] transition-all duration-500 ease-out z-10"
                    onerror="this.src='/nike.png'">
                </a>
                <div
                  class="absolute bottom-3 left-4 right-4 flex justify-between text-[10px] text-gray-400 font-medium z-10 opacity-0 group-hover:opacity-100 transition-opacity">
                  <span>
                    <%= product.color %>
                  </span>
                  <span>Size: <%= product.sizes %></span>
                </div>
              </div>

              <!-- Content Card -->
              <div class="p-6 flex-1 flex flex-col justify-between space-y-4">
                <div>
                  <span class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">
                    <%= product.category==='men' ? 'Nam' : product.category==='women' ? 'Nữ' : 'Trẻ Em' %> &bull; <%=
                        translateItemType(product.item_type) %>
                  </span>
                  <a href="/products/<%= product.id %>"
                    class="block font-bold text-gray-800 text-sm hover:text-nike-orange transition-colors truncate mt-1">
                    <%= product.title %>
                  </a>

                  <!-- Ratings -->
                  <div class="flex items-center gap-1 mt-1.5">
                    <div class="flex text-yellow-400">
                      <% for(let i=0; i<5; i++) { %>
                        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
                          <path
                            d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                        </svg>
                        <% } %>
                    </div>
                    <span class="text-[10px] text-gray-500 font-bold ml-1">
                      <%= product.rating || '4.5' %>
                    </span>
                  </div>
                </div>

                <!-- Price & Checkout option -->
                <div class="flex justify-between items-center pt-3 border-t border-gray-50">
                  <div class="flex flex-col">
                    <% if (product.discount_percent> 0) { %>
                      <span class="text-xs text-gray-400 line-through">
                        <%= formatPrice(product.price) %>
                      </span>
                      <span class="font-extrabold text-sm text-nike-orange">
                        <%= formatPrice(product.price * (1 - product.discount_percent / 100)) %>
                      </span>
                      <% } else { %>
                        <span class="font-extrabold text-sm text-nike-black">
                          <%= formatPrice(product.price) %>
                        </span>
                        <% } %>
                  </div>

                  <!-- Quick add to cart button -->
                  <button
                    onclick="addToCart(JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(product)) %>')), '39', 'Trắng', 1)"
                    class="bg-nike-black hover:bg-nike-orange text-white p-2.5 rounded-full transition-all duration-300 hover:rotate-[360deg] shadow-md focus:outline-none glow-dark hover:glow-orange">
                    <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                      xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
            <% }) %>
        </div>
        <% } else { %>
          <!-- No Search Results Placeholder -->
          <div class="bg-white rounded-3xl p-16 text-center shadow-sm border border-gray-100 space-y-6">
            <img src="/assets/design/emptybag.png" alt="No Results"
              class="w-40 h-auto mx-auto opacity-75 transform hover:scale-105 transition-transform duration-300"
              onerror="this.style.display='none'">
            <div class="space-y-2">
              <h3 class="font-extrabold text-2xl text-gray-800">Không tìm thấy sản phẩm nào!</h3>
              <p class="text-sm text-gray-500 max-w-sm mx-auto leading-relaxed font-light">
                Chúng tôi không tìm thấy kết quả nào phù hợp với từ khóa <strong class="text-nike-orange">"<%= query %>
                    "</strong>. Vui lòng kiểm tra lại chính tả hoặc thử bằng từ khóa khác.
              </p>
            </div>

            <!-- Suggestions -->
            <div class="pt-4 max-w-md mx-auto">
              <h5 class="text-xs uppercase text-gray-400 font-extrabold tracking-wider mb-3">Từ khóa gợi ý cho bạn</h5>
              <div class="flex flex-wrap justify-center gap-2">
                <a href="/search?q=Pegasus"
                  class="bg-gray-50 hover:bg-nike-orange hover:text-white px-4 py-2 rounded-xl text-xs font-semibold text-gray-600 transition-colors border">Pegasus</a>
                <a href="/search?q=Zoom"
                  class="bg-gray-50 hover:bg-nike-orange hover:text-white px-4 py-2 rounded-xl text-xs font-semibold text-gray-600 transition-colors border">Zoom</a>
                <a href="/search?q=Vaporfly"
                  class="bg-gray-50 hover:bg-nike-orange hover:text-white px-4 py-2 rounded-xl text-xs font-semibold text-gray-600 transition-colors border">Vaporfly</a>
                <a href="/search?q=Force"
                  class="bg-gray-50 hover:bg-nike-orange hover:text-white px-4 py-2 rounded-xl text-xs font-semibold text-gray-600 transition-colors border">Air
                  Force</a>
              </div>
            </div>
          </div>
          <% } %>

    </div>

    </div>

    <!-- Dynamic Filter Logic in Client Side -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('catSearchInput');
        const typeFilter  = document.getElementById('catTypeFilter');
        const priceFilter = document.getElementById('catPriceFilter');
        const sortSelect  = document.getElementById('catSortSelect');
        const grid        = document.getElementById('categoryProductsGrid');
        const countEl     = document.getElementById('visibleProductsCount');

        if (!grid) return; // Only run if grid exists (results found)

        function filterAndSort() {
          const query       = searchInput ? searchInput.value.toLowerCase().trim() : '';
          const selectedType = typeFilter ? typeFilter.value.toLowerCase() : '';
          const sortVal     = sortSelect ? sortSelect.value : 'default';
          const priceVal    = priceFilter ? priceFilter.value : '';

          let cards = Array.from(grid.querySelectorAll('.cat-product-card'));
          let visibleCount = 0;

          cards.forEach(card => {
            const title    = card.getAttribute('data-title') || '';
            const itemType = (card.getAttribute('data-item-type') || '').toLowerCase();
            const price    = parseFloat(card.getAttribute('data-price')) || 0;

            const matchesSearch = !query || title.includes(query);
            const matchesType   = !selectedType || itemType === selectedType;
            
            let matchesPrice = true;
            if (priceVal === 'under-1m') matchesPrice = price < 1000000;
            else if (priceVal === '1m-2m') matchesPrice = price >= 1000000 && price <= 2000000;
            else if (priceVal === '2m-4m') matchesPrice = price >= 2000000 && price <= 4000000;
            else if (priceVal === 'over-4m') matchesPrice = price > 4000000;

            if (matchesSearch && matchesType && matchesPrice) {
              card.classList.remove('hidden');
              visibleCount++;
            } else {
              card.classList.add('hidden');
            }
          });

          if (countEl) countEl.textContent = visibleCount;

          // Perform Sorting
          let visibleCards = cards.filter(c => !c.classList.contains('hidden'));
          if (sortVal !== 'default') {
            visibleCards.sort((a, b) => {
              if (sortVal === 'price-asc')   return parseFloat(a.getAttribute('data-price')) - parseFloat(b.getAttribute('data-price'));
              if (sortVal === 'price-desc')  return parseFloat(b.getAttribute('data-price')) - parseFloat(a.getAttribute('data-price'));
              if (sortVal === 'rating-desc') return parseFloat(b.getAttribute('data-rating')) - parseFloat(a.getAttribute('data-rating'));
              return 0;
            });
          }
          visibleCards.forEach(c => grid.appendChild(c));
        }

        if (searchInput) searchInput.addEventListener('input', filterAndSort);
        if (typeFilter)  typeFilter.addEventListener('change', filterAndSort);
        if (priceFilter) priceFilter.addEventListener('change', filterAndSort);
        
        const sortBtns = document.querySelectorAll('.catSortBtn');
        sortBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            sortBtns.forEach(b => {
               b.classList.remove('bg-nike-black', 'text-white', 'shadow-sm', 'active');
               b.classList.add('bg-gray-50', 'text-gray-600');
            });
            btn.classList.remove('bg-gray-50', 'text-gray-600');
            btn.classList.add('bg-nike-black', 'text-white', 'shadow-sm', 'active');
            if (sortSelect) sortSelect.value = btn.getAttribute('data-sort');
            filterAndSort();
          });
        });

        filterAndSort(); // init count
      });
    </script>

    <%- include('partials/footer') %>