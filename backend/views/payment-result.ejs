<%- include('partials/header', { title: title }) %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

  .payment-result-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  }

  .result-card {
    background: white;
    border-radius: 2rem;
    padding: 3rem 2.5rem;
    max-width: 520px;
    width: 100%;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0,0,0,0.08);
    border: 1px solid rgba(0,0,0,0.06);
    animation: cardEntrance 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
  }

  @keyframes cardEntrance {
    from { opacity: 0; transform: translateY(30px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Success Icon ──────────────────────────────────────────── */
  .icon-circle {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.75rem;
  }
  .icon-circle.success {
    background: linear-gradient(135deg, #d1fae5, #a7f3d0);
    animation: successPulse 2s ease-in-out infinite;
  }
  .icon-circle.failure {
    background: linear-gradient(135deg, #fee2e2, #fca5a5);
  }
  @keyframes successPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.3); }
    50%       { box-shadow: 0 0 0 16px rgba(16,185,129,0); }
  }

  .result-title {
    font-size: 1.625rem;
    font-weight: 900;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
  }
  .result-title.success { color: #064e3b; }
  .result-title.failure { color: #7f1d1d; }

  .result-subtitle {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.6;
    margin-bottom: 2rem;
    font-weight: 400;
  }

  /* ── Detail Box ────────────────────────────────────────────── */
  .detail-box {
    background: #f9fafb;
    border-radius: 1.25rem;
    padding: 1.25rem 1.5rem;
    text-align: left;
    margin-bottom: 1.75rem;
    border: 1px solid #e5e7eb;
  }
  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    font-size: 0.8125rem;
    border-bottom: 1px solid #f3f4f6;
  }
  .detail-row:last-child { border-bottom: none; }
  .detail-label { color: #6b7280; font-weight: 500; }
  .detail-value { font-weight: 700; color: #111827; }
  .detail-value.highlight { color: #f97316; }
  .detail-value.vnpay { color: #005baa; }

  /* ── VNPay badge ────────────────────────────────────────────── */
  .vnpay-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: #005baa;
    color: white;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    letter-spacing: 0.05em;
  }

  /* ── Buttons ───────────────────────────────────────────────── */
  .btn-primary {
    display: block;
    width: 100%;
    padding: 1rem;
    background: #111827;
    color: white;
    border: none;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    margin-bottom: 0.75rem;
  }
  .btn-primary:hover {
    background: #f97316;
    transform: translateY(-1px);
    color: white;
    text-decoration: none;
  }
  .btn-secondary {
    display: block;
    width: 100%;
    padding: 0.875rem;
    background: transparent;
    color: #6b7280;
    border: 2px solid #e5e7eb;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    border-color: #111827;
    color: #111827;
    text-decoration: none;
  }

  /* ── Spinner (polling) ─────────────────────────────────────── */
  .polling-bar {
    margin: 1.25rem 0;
    text-align: center;
    font-size: 0.75rem;
    color: #9ca3af;
  }
  .spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid #e5e7eb;
    border-top-color: #ae2070;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    vertical-align: middle;
    margin-right: 6px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Confetti (success) ─────────────────────────────────────── */
  .confetti-dot {
    position: fixed;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: confettiFall 3s ease-in forwards;
    pointer-events: none;
  }
  @keyframes confettiFall {
    0%   { opacity: 1; transform: translateY(-20px) rotate(0); }
    100% { opacity: 0; transform: translateY(110vh) rotate(720deg); }
  }
</style>

<div class="payment-result-page">
  <div class="result-card">

    <% if (isSuccess) { %>
      <!-- ==================== SUCCESS ==================== -->
      <div class="icon-circle success">
        <svg width="52" height="52" fill="none" stroke="#059669" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 class="result-title success">Thanh Toán Thành Công! 🎉</h1>
      <p class="result-subtitle">
        <% if (internalOrderId && internalOrderId.startsWith('NCOIN_')) { %>
          Yêu cầu nạp N-Coin của bạn đã được tiếp nhận. Xin cảm ơn!
        <% } else { %>
          Đơn hàng của bạn đã được xác nhận. Nike Store sẽ chuẩn bị và giao hàng trong thời gian sớm nhất. Cảm ơn bạn đã mua sắm!
        <% } %>
      </p>

      <div class="detail-box">
        <% if (internalOrderId) { %>
        <div class="detail-row">
          <span class="detail-label">Mã đơn hàng</span>
          <span class="detail-value highlight">#<%= internalOrderId %></span>
        </div>
        <% } %>
        <div class="detail-row">
          <span class="detail-label">Số tiền</span>
          <span class="detail-value green">
            <%= parseInt(amount).toLocaleString('vi-VN') %> ₫
          </span>
        </div>
        <% if (transId) { %>
        <div class="detail-row">
          <span class="detail-label">Mã giao dịch VNPay</span>
          <span class="detail-value vnpay"><%= transId %></span>
        </div>
        <% } %>
        <% if (payType) { %>
        <div class="detail-row">
          <span class="detail-label">Ngân hàng</span>
          <span class="detail-value">
            🏦 <%= payType %>
          </span>
        </div>
        <% } %>
        <div class="detail-row">
          <span class="detail-label">Thanh toán qua</span>
          <span class="vnpay-brand">
            VNPAY
          </span>
        </div>
      </div>

      <!-- Polling: chờ IPN cập nhật DB rồi mới show trạng thái chính xác -->
      <% if (internalOrderId) { %>
      <div class="polling-bar" id="pollingBar">
        <span class="spinner"></span>
        <span id="pollingMsg">
          <% if (internalOrderId && internalOrderId.startsWith('NCOIN_')) { %>
            Đang xác nhận giao dịch nạp tiền...
          <% } else { %>
            Đang xác nhận đơn hàng từ hệ thống...
          <% } %>
        </span>
      </div>
      <% } %>

      <% if (internalOrderId && internalOrderId.startsWith('NCOIN_')) { %>
        <a href="/profile" class="btn-primary" id="viewOrderBtn" style="display:none">
          💰 Về Ví N-Coin
        </a>
      <% } else { %>
        <a href="/my-orders" class="btn-primary" id="viewOrderBtn" style="display:none">
          📦 Xem Đơn Hàng Của Tôi
        </a>
      <% } %>
      <a href="/" class="btn-secondary">← Tiếp Tục Mua Sắm</a>

    <% } else { %>
      <!-- ==================== FAILURE ==================== -->
      <div class="icon-circle failure">
        <svg width="52" height="52" fill="none" stroke="#dc2626" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </div>

      <h1 class="result-title failure">Thanh Toán Thất Bại</h1>
      <p class="result-subtitle">
        <%
          // Map VNPay result code → thông báo tiếng Việt thân thiện
          var codeMsg = '';
          if      (resultCode === '24') codeMsg = 'Bạn đã huỷ giao dịch.';
          else if (resultCode === '09') codeMsg = 'Thẻ/Tài khoản chưa đăng ký dịch vụ InternetBanking.';
          else if (resultCode === '10') codeMsg = 'Xác thực thông tin thẻ/tài khoản không đúng quá 3 lần.';
          else if (resultCode === '11') codeMsg = 'Đã hết hạn chờ thanh toán.';
          else if (resultCode === '12') codeMsg = 'Thẻ/Tài khoản bị khóa.';
          else if (resultCode === '51') codeMsg = 'Tài khoản không đủ số dư.';
          else if (resultCode === '65') codeMsg = 'Tài khoản đã vượt quá hạn mức giao dịch trong ngày.';
          else if (resultCode === '75') codeMsg = 'Ngân hàng thanh toán đang bảo trì.';
          else if (resultCode === '79') codeMsg = 'Nhập sai mật khẩu thanh toán quá số lần quy định.';
          else if (resultCode === '99') codeMsg = 'Lỗi hệ thống hoặc chữ ký không hợp lệ.';
          else if (message)             codeMsg = message;
        %>
        <% if (codeMsg) { %>
          <strong><%= codeMsg %></strong><br>
        <% } %>
        Đơn hàng đang ở trạng thái chờ xác nhận. Vui lòng vào mục "Đơn hàng của tôi" để thanh toán lại hoặc yêu cầu đổi sang COD.
      </p>

      <div class="detail-box">
        <div class="detail-row">
          <span class="detail-label">Kết quả</span>
          <span class="detail-value" style="color:#dc2626">
            ❌ Thất bại
            <% if (resultCode !== undefined && resultCode !== null) { %>
              <span style="font-size:0.7em;color:#9ca3af;font-weight:500"> (mã <%= resultCode %>)</span>
            <% } %>
          </span>
        </div>
        <% if (internalOrderId) { %>
        <div class="detail-row">
          <span class="detail-label">Đơn hàng</span>
          <span class="detail-value">#<%= internalOrderId %> <span style="color:#f59e0b;font-size:0.8em">(Chờ xác nhận)</span></span>
        </div>
        <% } %>
        <% if (amount > 0) { %>
        <div class="detail-row">
          <span class="detail-label">Số tiền</span>
          <span class="detail-value"><%= parseInt(amount).toLocaleString('vi-VN') %> ₫</span>
        </div>
        <% } %>
        <div class="detail-row">
          <span class="detail-label">Thanh toán qua</span>
          <span class="vnpay-brand">
            VNPAY
          </span>
        </div>
      </div>

      <!-- Action buttons -->
      <a href="/cart" class="btn-primary" style="background:#005baa;margin-bottom:0.75rem">
        🔄 Thử Lại Thanh Toán
      </a>
      <a href="/" class="btn-secondary">← Quay Về Trang Chủ</a>

    <% } %>

  </div>
</div>

<% if (isSuccess) { %>
<script>
  // ── Confetti animation ───────────────────────────────────────
  (function () {
    var colors = ['#f97316','#ae2070','#059669','#3b82f6','#facc15','#ec4899'];
    for (var i = 0; i < 40; i++) {
      (function (i) {
        setTimeout(function () {
          var dot = document.createElement('div');
          dot.className = 'confetti-dot';
          dot.style.cssText = [
            'left:' + Math.random() * 100 + 'vw',
            'top:-10px',
            'background:' + colors[Math.floor(Math.random() * colors.length)],
            'animation-duration:' + (2 + Math.random() * 2) + 's',
            'animation-delay:' + (Math.random() * 0.5) + 's',
          ].join(';');
          document.body.appendChild(dot);
          setTimeout(function () { dot.remove(); }, 4000);
        }, i * 60);
      })(i);
    }
  })();

  // ── Polling: kiểm tra DB đã cập nhật chưa ───────────────────
  <% if (isSuccess && internalOrderId) { %>
  var MAX_POLLS   = 12;   // tối đa 12 lần × 2.5s = 30s
  var pollCount   = 0;
  var orderId     = "<%= internalOrderId %>"; // FIXED: Wrapped in quotes
  var pollingBar  = document.getElementById('pollingBar');
  var pollingMsg  = document.getElementById('pollingMsg');
  var viewBtn     = document.getElementById('viewOrderBtn');

  function pollOrderStatus() {
    if (pollCount >= MAX_POLLS) {
      pollingMsg.textContent = orderId.startsWith('NCOIN_') ? 'Giao dịch đang được xử lý.' : 'Đơn hàng đang được xử lý. Vui lòng kiểm tra mục "Đơn hàng của tôi".';
      pollingBar.querySelector('.spinner').style.display = 'none';
      viewBtn.style.display = 'block';
      return;
    }
    pollCount++;

    fetch('/api/orders/vnpay/check-payment?order_id=' + orderId)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.status === 'success') {
          var order = data.order;
          if (order.payment_status === 'paid' || order.status === 'pending') {
            // IPN đã cập nhật xong
            pollingMsg.textContent = '✅ Đơn hàng đã xác nhận thành công!';
            pollingBar.querySelector('.spinner').style.display = 'none';
            viewBtn.style.display = 'block';

            // Xoá cart items đã thanh toán (VNPay flow)
            try {
              var pendingVnpayOrder = JSON.parse(sessionStorage.getItem('pendingVnpayOrder') || 'null');
              if (pendingVnpayOrder && pendingVnpayOrder.orderId == orderId) {
                var userStr = localStorage.getItem('nike_user');
                var userKey = null;
                if (userStr) {
                  var user = JSON.parse(userStr);
                  userKey = user.id || user.username || null;
                }
                if (userKey) {
                  var storageKey = 'nike_cart_' + userKey;
                  var cart = JSON.parse(localStorage.getItem(storageKey) || '[]');
                  var remaining = cart.filter(function (item) {
                    return !pendingVnpayOrder.itemIds.includes(item.id + '_' + item.size + '_' + item.color);
                  });
                  localStorage.setItem(storageKey, JSON.stringify(remaining));
                  sessionStorage.removeItem('pendingVnpayOrder');
                  // Trigger cart badge update
                  window.dispatchEvent(new Event('cartUpdated'));
                }
              }
            } catch (e) {}
            return;
          }
        }
        // Chưa cập nhật — thử lại sau 2.5s
        setTimeout(pollOrderStatus, 2500);
      })
      .catch(function () {
        setTimeout(pollOrderStatus, 3000);
      });
  }

  // Bắt đầu polling sau 1.5s
  setTimeout(pollOrderStatus, 1500);
  <% } %>
</script>
<% } %>

<%- include('partials/footer') %>
