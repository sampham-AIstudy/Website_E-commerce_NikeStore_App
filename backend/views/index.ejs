<!-- ========================================== -->
<!-- SCRIPTS FOR HOME VIEW INTERACTIVITY        -->
<!-- ========================================== -->
<script>
  // ─── 1. INTERACTIVE HERO COLORWAY SWITCHER ───
  function changeHeroColorway(colorName, imgSrc, bgGradient, swatchBg, swatchText, titleGradient) {
    const heroImage = document.getElementById('hero-shoe-image');
    const heroTitleAccent = document.getElementById('hero-title-accent');
    const heroGlowRing = document.getElementById('hero-glow-ring');
    const heroGlow1 = document.getElementById('hero-glow-1');
    const colorButtons = document.querySelectorAll('.colorway-btn');

    // Add scale-down transition
    heroImage.classList.add('scale-75', 'opacity-0', 'rotate-[-30deg]');

    // Active swatch border style update
    colorButtons.forEach(btn => {
      btn.classList.remove('ring-2', 'ring-nike-orange/50', 'scale-110', 'border-white');
      btn.classList.add('border-transparent');
    });
    event.currentTarget.classList.remove('border-transparent');
    event.currentTarget.classList.add('ring-2', 'ring-nike-orange/50', 'scale-110', 'border-white');

    setTimeout(() => {
      // Swap Image
      heroImage.src = imgSrc;

      // Swap Colors / Gradients
      if (heroGlowRing) {
        heroGlowRing.className = `absolute w-56 sm:w-80 h-56 sm:h-80 bg-gradient-to-tr ${bgGradient} rounded-full blur-3xl opacity-60 z-0 transition-all duration-1000`;
      }
      
      // Update Title Text gradient color
      if (heroTitleAccent) {
        heroTitleAccent.className = `text-transparent bg-clip-text bg-gradient-to-r ${titleGradient} transition-all duration-500`;
      }

      // Dynamic title swap
      if (colorName === 'black') {
        heroTitleAccent.textContent = 'ĐEN HUYỀN BÍ';
        if (heroGlow1) heroGlow1.className = 'absolute top-1/4 left-1/4 w-[350px] h-[350px] bg-neutral-600/10 rounded-full blur-[120px] pointer-events-none transition-all duration-1000';
      } else if (colorName === 'volt') {
        heroTitleAccent.textContent = 'ĐIỆN TỬ NEON';
        if (heroGlow1) heroGlow1.className = 'absolute top-1/4 left-1/4 w-[350px] h-[350px] bg-lime-400/15 rounded-full blur-[120px] pointer-events-none transition-all duration-1000';
      } else {
        heroTitleAccent.textContent = 'MỌI GIỚI HẠN';
        if (heroGlow1) heroGlow1.className = 'absolute top-1/4 left-1/4 w-[350px] h-[350px] bg-nike-orange/15 rounded-full blur-[120px] pointer-events-none transition-all duration-1000';
      }

      // Zoom back in animation
      heroImage.classList.remove('scale-75', 'opacity-0', 'rotate-[-30deg]');
    }, 300);
  }

  // ─── 2. CLIENT-SIDE DYNAMIC PRODUCT FILTER ───
  function filterProducts(filterType, buttonEl) {
    const allProducts = document.querySelectorAll('.product-card-node');
    const tabs = document.querySelectorAll('.product-tab-btn');
    const grid = document.getElementById('products-grid');

    // Switch active state for buttons
    tabs.forEach(btn => {
      btn.className = 'product-tab-btn px-5 py-2 rounded-full text-xs uppercase font-extrabold tracking-wider transition-all duration-300 text-gray-500 hover:text-nike-black';
    });
    buttonEl.className = 'product-tab-btn px-5 py-2 rounded-full text-xs uppercase font-extrabold tracking-wider transition-all duration-300 bg-nike-black text-white shadow-sm';

    // Fade out grid
    grid.classList.add('opacity-40', 'scale-98');

    setTimeout(() => {
      allProducts.forEach(card => {
        const isNew = card.getAttribute('data-new') === 'true';
        const isSale = card.getAttribute('data-sale') === 'true';

        if (filterType === 'all') {
          card.classList.remove('hidden');
        } else if (filterType === 'new') {
          if (isNew) card.classList.remove('hidden');
          else card.classList.add('hidden');
        } else if (filterType === 'sale') {
          if (isSale) card.classList.remove('hidden');
          else card.classList.add('hidden');
        }
      });
      // Fade back in
      grid.classList.remove('opacity-40', 'scale-98');
    }, 250);
  }

  // ─── 3. VIDEO CAMPAIGN EMBED MODAL ───
  function openVideoPlayer(embedUrl) {
    const modal = document.getElementById('videoPlayerModal');
    const iframe = document.getElementById('video-iframe');
    if (modal && iframe) {
      // Auto-play query inside Youtube URL
      iframe.src = embedUrl + "?autoplay=1&mute=0";
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
  }

  function closeVideoPlayer() {
    const modal = document.getElementById('videoPlayerModal');
    const iframe = document.getElementById('video-iframe');
    if (modal && iframe) {
      iframe.src = ""; // stop video
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  }

  // ─── 4. ATHLETE TESTIMONIAL CAROUSEL SLIDER ───
  let currentQuote = 0;
  const totalQuotes = 3;

  function switchQuote(index) {
    if (index === currentQuote) return;
    const dots = document.querySelectorAll('.quote-dot');
    
    const currentCard = document.getElementById(`quote-card-${currentQuote}`);
    const newCard = document.getElementById(`quote-card-${index}`);
    
    const isNext = index > currentQuote;

    if (currentCard) {
      currentCard.classList.remove('opacity-100', 'translate-x-0', 'relative');
      currentCard.classList.add('opacity-0', isNext ? '-translate-x-full' : 'translate-x-full', 'absolute', 'pointer-events-none');
    }

    if (newCard) {
      newCard.classList.remove('-translate-x-full', 'translate-x-full', 'relative');
      newCard.classList.add(isNext ? 'translate-x-full' : '-translate-x-full', 'absolute', 'opacity-0');
      
      // Force reflow
      newCard.offsetHeight;
      
      newCard.classList.remove('opacity-0', '-translate-x-full', 'translate-x-full', 'absolute', 'pointer-events-none');
      newCard.classList.add('opacity-100', 'translate-x-0', 'relative');
    }

    // Update dots
    dots.forEach((dot, idx) => {
      if (idx === index) {
        dot.className = 'quote-dot w-2 h-2 rounded-full bg-nike-orange transition-all duration-300';
      } else {
        dot.className = 'quote-dot w-2 h-2 rounded-full bg-gray-300 hover:bg-gray-400 transition-all duration-300';
      }
    });

    currentQuote = index;
  }

  // Auto scroll quotes
  setInterval(() => {
    let next = (currentQuote + 1) % totalQuotes;
    switchQuote(next);
  }, 8000);

  // ─── 5. MEMBER CLUB SIGNUP FORM ───
  function handleMemberSignup(e) {
    e.preventDefault();
    const email = document.getElementById('member-email').value;
    if (email) {
      // Simulate API call
      const form = document.getElementById('member-signup-form');
      const success = document.getElementById('member-success-msg');
      if (form && success) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
        showToast('Chào mừng bạn đến với hội viên Nike Club!');
      }
    }
  }

  // ─── 6. TOAST NOTIFICATION ───
  function showToast(message) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = 'flex items-center gap-3 bg-neutral-900 text-white text-xs font-bold px-5 py-3.5 rounded-full shadow-2xl border border-neutral-800 transition-all duration-300 transform translate-y-10 opacity-0';
    toast.innerHTML = `
      <svg class="w-4 h-4 text-nike-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <span>${message}</span>
    `;

    container.appendChild(toast);

    // Fade in
    setTimeout(() => {
      toast.classList.remove('translate-y-10', 'opacity-0');
    }, 50);

    // Fade out and remove
    setTimeout(() => {
      toast.classList.add('translate-y-[-10px]', 'opacity-0');
      setTimeout(() => {
        toast.remove();
      }, 300);
    }, 3500);
  }

  // ─── 7. PRODUCT QUICK VIEW MODAL STATE & ACTIONS ───
  let selectedProduct = null;
  let selectedSize = '39';
  let selectedColor = 'Trắng';

  function openQuickView(product) {
    selectedProduct = product;
    
    const modal = document.getElementById('quickViewModal');
    const card = document.getElementById('quickViewCard');
    
    // Fill fields
    document.getElementById('qv-image').src = product.image;
    document.getElementById('qv-title').textContent = product.title;
    document.getElementById('qv-description').textContent = product.description || 'Sản phẩm cao cấp được sản xuất trên dây chuyền công nghệ cao của Nike. Mang lại hiệu suất bảo vệ tối đa và êm ái dài lâu cho gót chân.';
    
    // Set Category label
    const catLabel = document.getElementById('qv-category');
    if (product.category === 'men') catLabel.textContent = 'Thời trang Nam';
    else if (product.category === 'women') catLabel.textContent = 'Thời trang Nữ';
    else catLabel.textContent = 'Trẻ Em';

    // Format prices
    const qvPrice = document.getElementById('qv-price');
    const qvOldPrice = document.getElementById('qv-old-price');
    
    let numPrice = parseFloat(product.price);
    if (product.discount_percent > 0) {
      let discountedPrice = numPrice * (1 - product.discount_percent / 100);
      qvPrice.textContent = formatPriceHelper(discountedPrice);
      qvOldPrice.textContent = formatPriceHelper(numPrice);
      qvOldPrice.classList.remove('hidden');
    } else {
      qvPrice.textContent = formatPriceHelper(numPrice);
      qvOldPrice.classList.add('hidden');
    }

    // Set badges
    const badgeNew = document.getElementById('qv-badge-new');
    if (product.is_new) badgeNew.classList.remove('hidden');
    else badgeNew.classList.add('hidden');

    // Populate Size Buttons (e.g. 38, 39, 40, 41, 42)
    const sizesContainer = document.getElementById('qv-sizes-container');
    sizesContainer.innerHTML = '';
    
    // Split db size string if exists, otherwise default sizes
    let sizes = ['38', '39', '40', '41', '42', '43'];
    if (product.sizes && product.sizes !== 'N/A' && product.sizes !== '') {
      sizes = product.sizes.split(',').map(s => s.trim());
    }
    
    selectedSize = sizes[0] || '39'; // set default size to first one

    sizes.forEach(size => {
      const btn = document.createElement('button');
      btn.textContent = size;
      btn.className = `size-btn border text-xs px-3.5 py-1.5 rounded-full font-bold transition-all focus:outline-none ${size === selectedSize ? 'border-nike-black bg-nike-black text-white' : 'border-gray-200 hover:border-nike-black text-gray-600'}`;
      btn.onclick = () => {
        selectedSize = size;
        document.querySelectorAll('.size-btn').forEach(b => {
          b.className = 'size-btn border text-xs px-3.5 py-1.5 rounded-full font-bold transition-all focus:outline-none border-gray-200 hover:border-nike-black text-gray-600';
        });
        btn.className = 'size-btn border text-xs px-3.5 py-1.5 rounded-full font-bold transition-all focus:outline-none border-nike-black bg-nike-black text-white';
      };
      sizesContainer.appendChild(btn);
    });

    // Populate Color Swatches
    const colorsContainer = document.getElementById('qv-colors-container');
    colorsContainer.innerHTML = '';
    
    let colors = ['Trắng', 'Đen', 'Xám'];
    if (product.color && product.color !== 'N/A' && product.color !== '') {
      colors = product.color.split(',').map(c => c.trim());
    }
    
    selectedColor = colors[0] || 'Trắng'; // default to first

    colors.forEach(col => {
      const btn = document.createElement('button');
      btn.textContent = col;
      btn.className = `color-sel-btn border text-[10px] px-3.5 py-1 rounded-full font-bold transition-all focus:outline-none ${col === selectedColor ? 'border-nike-orange bg-nike-orange text-white' : 'border-gray-200 hover:border-nike-orange text-gray-600'}`;
      btn.onclick = () => {
        selectedColor = col;
        document.querySelectorAll('.color-sel-btn').forEach(b => {
          b.className = 'color-sel-btn border text-[10px] px-3.5 py-1 rounded-full font-bold transition-all focus:outline-none border-gray-200 hover:border-nike-orange text-gray-600';
        });
        btn.className = 'color-sel-btn border text-[10px] px-3.5 py-1 rounded-full font-bold transition-all focus:outline-none border-nike-orange bg-nike-orange text-white';
      };
      colorsContainer.appendChild(btn);
    });

    // Configure Add Button inside Modal
    const addBtn = document.getElementById('qv-add-btn');
    addBtn.onclick = () => {
      addToCart(selectedProduct, selectedSize, selectedColor, 1);
      closeQuickView();
      showToast('Đã thêm sản phẩm vào giỏ hàng!');
    };

    // Open Modal Visuals
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    setTimeout(() => {
      card.classList.remove('scale-95', 'opacity-0');
    }, 50);
  }

  function closeQuickView() {
    const modal = document.getElementById('quickViewModal');
    const card = document.getElementById('quickViewCard');
    
    if (card) {
      card.classList.add('scale-95', 'opacity-0');
    }
    setTimeout(() => {
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    }, 250);
  }

  // Price formatting helper for quickview modal (VND)
  function formatPriceHelper(number) {
    let cleanVal = parseFloat(number);
    if (isNaN(cleanVal)) return number;
    if (cleanVal < 100000) {
      cleanVal = cleanVal * 1000;
    }
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cleanVal);
  }

  // Double Check touch events for continuous marquee on mount
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('inspiration-marquee-track');
    if (!track) return;
    track.addEventListener('touchstart', () => { track.classList.add('paused'); }, { passive: true });
    track.addEventListener('touchend', () => { track.classList.remove('paused'); }, { passive: true });
  });
</script>

