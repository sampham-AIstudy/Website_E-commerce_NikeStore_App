      function renderSmartInsights(insights) {
        const container = document.getElementById('smartInsightsContainer');
        if (!insights.length) {
          container.innerHTML = '<p class="text-white/70 text-xs col-span-2">Hệ thống đang thu thập thêm dữ liệu để đưa ra gợi ý...</p>';
          return;
        }

        container.innerHTML = insights.map(ins => {
          let bgClass = 'bg-white/10';
          let borderClass = 'border-white/10';
          let iconBg = 'bg-white/10';

          if (ins.type === 'danger') {
            borderClass = 'border-red-400/30';
            iconBg = 'bg-red-500/20';
          } else if (ins.type === 'warning') {
            borderClass = 'border-orange-400/30';
            iconBg = 'bg-orange-500/20';
          } else if (ins.type === 'success') {
            borderClass = 'border-emerald-400/30';
            iconBg = 'bg-emerald-500/20';
          }

          return `
          <div class="rounded-2xl ${bgClass} border ${borderClass} p-4 backdrop-blur-sm transition-all hover:bg-white/20">
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-xl ${iconBg} flex items-center justify-center flex-shrink-0 text-sm">
                ${ins.icon}
              </div>
              <p class="text-xs text-white/90 leading-relaxed font-medium">
                ${ins.text}
