              </div>
              <!-- Option B: Upload file -->
              <div class="space-y-1">
                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-wide block">Cách B: Tải ảnh từ máy
                  tính</span>
                <input type="file" id="prodImageFile" accept="image/*"
                  class="w-full bg-white border border-gray-200 rounded-xl py-1.5 px-3 text-xs font-semibold text-gray-800 focus:outline-none focus:ring-2 focus:ring-nike-orange/30 transition-all">
