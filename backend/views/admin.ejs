                <option value="jacket">Áo khoác (Jacket)</option>
                <option value="pants">Quần dài (Pants)</option>
                <option value="shirt">Áo thun (Shirt)</option>
                <option value="shoes" selected>Giày (Shoes)</option>
                <option value="shorts">Quần ngắn (Shorts)</option>
                <option value="socks">Tất / Vớ (Socks)</option>
              </select>
            </div>
            <!-- Stock -->
            <div class="space-y-1">
              <label for="prodStock" class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Hàng trong
