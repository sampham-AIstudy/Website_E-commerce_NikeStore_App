                  <p class="text-2xl font-black text-nike-black relative z-10" id="kpiTotalOrders2">--</p>
                  <div
                    class="mt-2 text-[10px] font-bold text-blue-500 bg-blue-50 inline-block px-2 py-0.5 rounded-full relative z-10"
