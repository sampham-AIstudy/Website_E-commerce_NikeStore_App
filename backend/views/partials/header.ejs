<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof title !=='undefined' ? title : 'Nike Store - Premium Footwear' %>
  </title>
  <link rel="icon" type="image/png" href="/nike.png">

  <!-- Tailwind CSS Play CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            nike: {
              black: '#111111',
              grey: '#707072',
              orange: '#FF5400',
              blue: '#1A237E',
              green: '#10B981',
            }
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          backdropBlur: {
            xs: '2px',
          }
        }
      }
    }
  </script>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">

  <!-- Custom Styles for Premium UI -->
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f7f7f9;
      color: #111111;
      overflow-x: hidden;
    }

    /* Sleek Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
      background: #c1c1c1;
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #a8a8a8;
    }

    /* Glassmorphism effects */
    .glass-nav {
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-bottom: 1px solid rgba(209, 213, 219, 0.3);
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.4);
    }

    /* Glow Animations */
    .glow-orange:hover {
      box-shadow: 0 10px 25px -5px rgba(255, 84, 0, 0.4);
    }

    .glow-dark:hover {
      box-shadow: 0 10px 25px -5px rgba(17, 17, 17, 0.3);
    }

    /* Floating Hero Shoe */
    @keyframes float {
      0% {
        transform: translateY(0px) rotate(-15deg);
      }

      50% {
        transform: translateY(-15px) rotate(-12deg);
      }

      100% {
        transform: translateY(0px) rotate(-15deg);
      }
    }

    .floating-shoe {
      animation: float 6s ease-in-out infinite;
      filter: drop-shadow(0 25px 25px rgba(0, 0, 0, 0.2));
    }

    /* Pulse badge */
    .badge-pulse {
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        transform: scale(1);
      }

      50% {
        transform: scale(1.15);
      }
    }
  </style>
</head>

<body class="min-h-screen flex flex-col">

  <!-- ========================================== -->
  <!-- NAVIGATION BAR (GLASSMORPHISM)             -->
  <!-- ========================================== -->
  <nav class="sticky top-0 z-50 glass-nav transition-all duration-300 w-full">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-20 items-center">

        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center">
          <a href="/" class="flex items-center gap-2 group">
            <img src="/assets/logo.png" alt="Nike Logo"
              class="h-10 w-auto transform transition-transform duration-300 group-hover:scale-110 group-hover:rotate-[-5deg]"
              onerror="this.src='/nike.png'">
            <span class="font-extrabold text-2xl tracking-tighter uppercase text-nike-black hidden sm:block">NIKE<span
                class="text-nike-orange">STORE</span></span>
          </a>
        </div>

        <!-- Navigation Links -->
        <div class="hidden md:flex items-center space-x-4 lg:space-x-6 xl:space-x-8 flex-shrink-0">
          <a href="/"
            class="text-nike-black hover:text-nike-orange font-semibold text-xs lg:text-sm tracking-wide uppercase transition-colors duration-200 py-2 border-b-2 border-transparent hover:border-nike-orange whitespace-nowrap">Trang
            Chủ</a>
          <a href="/men"
            class="text-nike-black hover:text-nike-orange font-semibold text-xs lg:text-sm tracking-wide uppercase transition-colors duration-200 py-2 border-b-2 border-transparent hover:border-nike-orange whitespace-nowrap">Nam</a>
          <a href="/women"
            class="text-nike-black hover:text-nike-orange font-semibold text-xs lg:text-sm tracking-wide uppercase transition-colors duration-200 py-2 border-b-2 border-transparent hover:border-nike-orange whitespace-nowrap">Nữ</a>
          <a href="/kids"
            class="text-nike-black hover:text-nike-orange font-semibold text-xs lg:text-sm tracking-wide uppercase transition-colors duration-200 py-2 border-b-2 border-transparent hover:border-nike-orange whitespace-nowrap">Trẻ
            Em</a>
          <a href="/new"
            class="text-nike-black hover:text-nike-orange font-semibold text-xs lg:text-sm tracking-wide uppercase transition-colors duration-200 py-2 border-b-2 border-transparent hover:border-nike-orange flex items-center gap-1 whitespace-nowrap">Mới
            <span
              class="bg-red-500 text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full uppercase tracking-tighter badge-pulse">New</span></a>
          <a href="/sale"
            class="text-nike-black hover:text-nike-orange font-semibold text-xs lg:text-sm tracking-wide uppercase transition-colors duration-200 py-2 border-b-2 border-transparent hover:border-nike-orange flex items-center gap-1 whitespace-nowrap">Khuyến
            Mãi <span
              class="bg-nike-orange text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full uppercase tracking-tighter">Sale</span></a>
        </div>

        <!-- Icon Options (Search, Wishlist, Cart, Profile) -->
        <div class="flex items-center gap-1.5 sm:gap-3 lg:gap-4 flex-shrink-0">

          <!-- Search (Desktop) -->
          <form action="/search" method="GET" class="relative hidden lg:block">
            <input type="text" name="q" placeholder="Tìm sản phẩm..."
              class="bg-gray-100/80 border-0 rounded-full py-2 pl-4 pr-10 text-xs lg:text-sm focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-28 lg:w-48 focus:w-40 lg:focus:w-64 transition-all duration-300 text-nike-black font-medium">
            <button type="submit" class="absolute right-3 top-2.5 lg:right-3.5 lg:top-3 focus:outline-none">
              <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </button>
          </form>

          <!-- Wishlist Toggle -->
          <button id="wishlistBtn"
            class="relative p-1.5 lg:p-2 text-nike-black hover:text-red-500 transition-colors duration-200 focus:outline-none flex-shrink-0">
            <svg class="w-5.5 h-5.5 lg:w-6 lg:h-6 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
              </path>
            </svg>
            <span id="wishlistCount"
              class="hidden bg-red-500 text-white rounded-full text-[9px] w-4.5 h-4.5 lg:w-5 lg:h-5 flex items-center justify-center font-extrabold absolute -top-0.5 -right-0.5 border-2 border-white shadow-sm badge-pulse">0</span>
          </button>

          <!-- Cart Toggle -->
          <button id="cartBtn"
            class="relative p-1.5 lg:p-2 text-nike-black hover:text-nike-orange transition-colors duration-200 focus:outline-none flex-shrink-0">
            <svg class="w-5.5 h-5.5 lg:w-6 lg:h-6 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            <span id="cartCount"
              class="hidden bg-sky-500 text-white rounded-full text-[9px] w-4.5 h-4.5 lg:w-5 lg:h-5 flex items-center justify-center font-extrabold absolute -top-0.5 -right-0.5 border-2 border-white shadow-sm badge-pulse">0</span>
          </button>

          <!-- Profile / Login -->
          <div class="relative group flex-shrink-0">
            <a id="profileBtn" href="/login"
              class="p-1 lg:p-1.5 text-nike-black hover:text-nike-orange transition-colors duration-200 focus:outline-none flex items-center gap-2 whitespace-nowrap">

              <!-- Avatar container (hidden when logged out, shown when logged in) -->
              <div id="avatarContainer" class="hidden flex items-center gap-2">
                <!-- Google avatar (shown for Google accounts) -->
                <img id="avatarImg" src="" alt="avatar"
                  class="hidden w-8 h-8 rounded-full object-cover ring-2 ring-nike-orange/30 shadow-sm transition-transform duration-200 group-hover:scale-105">
                <!-- Initials avatar (shown for regular accounts) -->
                <div id="avatarInitials"
                  class="hidden w-8 h-8 rounded-full bg-gradient-to-br from-nike-orange to-orange-400 text-white text-xs font-black flex items-center justify-center shadow-sm ring-2 ring-nike-orange/20 transition-transform duration-200 group-hover:scale-105">
                </div>
              </div>

              <!-- Default icon when NOT logged in -->
              <svg id="defaultUserIcon" class="w-6 h-6 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </a>

            <!-- Dropdown menu -->
            <div id="userDropdown"
              class="absolute right-0 mt-2 w-52 bg-white border border-gray-100 rounded-2xl shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 delay-150 group-hover:delay-0 z-50 before:content-[''] before:absolute before:-top-2 before:left-0 before:w-full before:h-2">

              <!-- Profile name label (shown when logged in) -->
              <div id="profileNameLabel"
                class="px-4 py-2.5 text-xs font-bold text-gray-800 border-b border-gray-100 truncate">
              </div>

              <!-- Admin Dashboard link (Only shown to admins) -->
              <a id="adminDropdownLink" href="/admin"
                class="hidden px-4 py-2 text-sm text-nike-orange hover:bg-orange-50 font-bold flex items-center gap-1.5 border-b border-gray-100 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z">
                  </path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Trang Quản Trị
              </a>

              <a href="/profile"    class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-nike-orange font-medium transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                Thông tin cá nhân
              </a>
              <a href="/my-orders" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 font-medium transition-colors">Đơn hàng của tôi</a>
              <a href="/wishlist"  class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 font-medium transition-colors">Sản phẩm yêu thích</a>
              <a href="/cart"      class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 font-medium transition-colors">Giỏ hàng của tôi</a>
              <hr class="my-1 border-gray-100">
              <!-- Auth Action Buttons -->
              <a id="loginDropdownBtn" href="/login"
                class="block mx-3 my-1.5 text-center bg-nike-black text-white hover:bg-nike-orange font-bold text-xs py-2.5 rounded-full uppercase tracking-wider transition-all duration-200 shadow-md">Đăng nhập</a>
              <button id="logoutDropdownBtn" onclick="logout()"
                class="block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 font-semibold transition-colors">Đăng xuất</button>
            </div>
          </div>


          <!-- Mobile Menu Icon -->
          <button class="md:hidden p-2 text-nike-black focus:outline-none flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ========================================== -->
  <!-- BACKDROP OVERLAY                           -->
  <!-- ========================================== -->
  <div id="backdrop"
    class="fixed inset-0 bg-black/55 backdrop-blur-xs z-[90] hidden transition-opacity duration-300 ease-in-out opacity-0">
  </div>

  <!-- ========================================== -->
  <!-- SIDEBAR: SHOPPING CART (DYNAMIC)          -->
  <!-- ========================================== -->
  <div id="cartSidebar"
    class="fixed inset-y-0 right-0 w-full sm:w-[460px] bg-white shadow-2xl z-[100] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col border-l border-gray-100">
    <!-- Header -->
    <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-nike-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
        </svg>
        <span class="font-bold text-lg text-nike-black uppercase tracking-wide">Giỏ Hàng Của Bạn</span>
        <span id="cartSidebarCount"
          class="bg-nike-orange text-white text-xs px-2 py-0.5 rounded-full font-bold">0</span>
      </div>
      <button id="closeCartBtn"
        class="text-gray-400 hover:text-nike-black p-1.5 rounded-full hover:bg-gray-100 transition-colors focus:outline-none">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Items List -->
    <div id="cartItemsList" class="flex-1 overflow-y-auto px-6 py-4 space-y-3">
      <!-- Empty Cart State -->
      <div id="emptyCartState" class="flex flex-col items-center justify-center h-full text-center space-y-4 py-12">
        <img src="/assets/design/emptybag.png" alt="Empty Bag"
          class="w-32 h-auto opacity-75 transform hover:scale-105 transition-transform duration-300"
          onerror="this.style.display='none'">
        <div>
          <p class="font-bold text-gray-800 text-base">Giỏ hàng của bạn đang trống!</p>
          <p class="text-sm text-gray-500 mt-1">Hãy khám phá các sản phẩm tuyệt vời của Nike.</p>
        </div>
        <button onclick="closeCart(); window.location.href='/'"
          class="bg-nike-black text-white hover:bg-nike-orange px-6 py-2.5 rounded-full font-bold text-sm uppercase tracking-wide transition-all duration-300 glow-dark hover:glow-orange">Mua
          Sắm Ngay</button>
      </div>
      <!-- Cart Items will be injected here by JS -->
    </div>

    <!-- Footer Summary / Checkout -->
    <div id="cartFooter" class="border-t border-gray-100 bg-gray-50/50 hidden">
      <!-- Select All Bar -->
      <div id="sidebarSelectAllBar" class="px-5 py-2.5 border-b border-gray-100 bg-white flex items-center justify-between">
        <label class="flex items-center gap-2.5 cursor-pointer select-none">
          <input type="checkbox" id="sidebarSelectAllCb" onchange="toggleSidebarSelectAll(this.checked)"
            class="w-4 h-4 accent-nike-orange cursor-pointer rounded border-gray-300 focus:ring-nike-orange/50">
          <span id="sidebarSelectAllLabel" class="text-xs font-bold text-gray-700">Chọn tất cả</span>
        </label>
        <span class="text-[10px] text-gray-400 font-medium">Tích để thanh toán</span>
      </div>
      <!-- Price & Actions -->
      <div class="p-5 space-y-3">
        <div class="flex justify-between items-center">
          <div>
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wider block">Tạm tính (đã chọn):</span>
            <span id="sidebarSelectedInfo" class="text-[10px] text-gray-400">Chưa chọn sản phẩm nào</span>
          </div>
          <span id="cartTotalPrice" class="text-xl text-nike-orange font-extrabold">0đ</span>
        </div>
        <p class="text-[10px] text-gray-400">Thuế &amp; phí vận chuyển tính tại bước thanh toán.</p>
        <div class="grid grid-cols-2 gap-3">
          <button onclick="clearCart()"
            class="border-2 border-gray-200 hover:border-red-500 hover:text-red-500 text-gray-600 font-bold py-3 px-4 rounded-full text-xs uppercase tracking-wider transition-colors duration-200 focus:outline-none">Xóa
            Giỏ Hàng</button>
          <a id="sidebarCheckoutBtn" href="/cart"
            class="bg-nike-black hover:bg-nike-orange text-white text-center font-bold py-3 px-4 rounded-full text-xs uppercase tracking-wider transition-all duration-300 shadow-md flex items-center justify-center gap-1.5 glow-dark hover:glow-orange">
            Thanh Toán
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========================================== -->
  <!-- SIDEBAR: WISHLIST (DYNAMIC)                -->
  <!-- ========================================== -->
  <div id="wishlistSidebar"
    class="fixed inset-y-0 right-0 w-full sm:w-[460px] bg-white shadow-2xl z-[100] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col border-l border-gray-100">
    <!-- Header -->
    <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-red-500 fill-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
          </path>
        </svg>
        <span class="font-bold text-lg text-nike-black uppercase tracking-wide">Yêu Thích</span>
        <span id="wishlistSidebarCount"
          class="bg-red-500 text-white text-xs px-2 py-0.5 rounded-full font-bold">0</span>
      </div>
      <button id="closeWishlistBtn"
        class="text-gray-400 hover:text-nike-black p-1.5 rounded-full hover:bg-gray-100 transition-colors focus:outline-none">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Items List -->
    <div id="wishlistItemsList" class="flex-1 overflow-y-auto px-6 py-4 space-y-4">
      <!-- Empty Wishlist State -->
      <div id="emptyWishlistState" class="flex flex-col items-center justify-center h-full text-center space-y-4 py-12">
        <img src="/assets/design/broken_heart.png" alt="Empty Wishlist"
          class="w-24 h-auto opacity-70 transform hover:scale-105 transition-transform duration-300"
          onerror="this.style.display='none'">
        <div>
          <p class="font-bold text-gray-800 text-base">Danh sách yêu thích trống!</p>
          <p class="text-sm text-gray-500 mt-1">Lưu các sản phẩm bạn thích để tiện theo dõi sau.</p>
        </div>
        <button onclick="closeWishlist(); window.location.href='/'"
          class="bg-nike-black text-white hover:bg-nike-orange px-6 py-2.5 rounded-full font-bold text-sm uppercase tracking-wide transition-all duration-300 glow-dark hover:glow-orange">Tìm
          Sản Phẩm</button>
      </div>
      <!-- Wishlist items injected here by JS -->
    </div>
  </div>

  <main class="flex-grow">