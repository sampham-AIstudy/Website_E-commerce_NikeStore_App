                <div class="flex-grow min-w-0">
                  <h4 class="font-bold text-xs text-gray-800 truncate">${item.title}</h4>
                  <div class="flex gap-2 text-[10px] text-gray-400 mt-0.5">
                    <span>Size: <strong class="text-nike-black font-semibold">${item.size}</strong></span>
                    <span>Màu: <strong class="text-nike-black font-semibold">${item.color}</strong></span>
                    <span>Số lượng: <strong class="text-nike-black font-semibold">${item.quantity}</strong></span>
                  </div>
                </div>
                <span class="font-extrabold text-xs text-nike-orange">${formatPrice(item.price * item.quantity)}</span>
              </div>
