<%- include('partials/header', { title: 'Nike Store - Trang Quản Trị Hệ Thống' }) %>

<% 
  // Helper to format price in EJS
  function formatPrice(number) {
    let cleanVal = parseFloat(String(number).replace(/[^0-9.-]+/g,""));
    if (isNaN(cleanVal)) return number;
    if (cleanVal < 100000) {
      cleanVal = cleanVal * 1000;
    }
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cleanVal);
  }
%>

  <!-- Admin Verification (Pre-renders blank if unauthorized, JS handles redirection) -->
  <div id="adminPanelLoading" class="min-h-[60vh] flex flex-col items-center justify-center space-y-4">
    <div class="w-12 h-12 border-4 border-nike-black border-t-nike-orange rounded-full animate-spin"></div>
    <p class="text-xs text-gray-500 font-bold uppercase tracking-wider">Đang kiểm tra quyền truy cập Quản trị viên...</p>
  </div>

  <div id="adminPanelContent" class="hidden">
    <!-- ========================================== -->
    <!-- PANEL HEADER                               -->
    <!-- ========================================== -->
    <div class="bg-gradient-to-r from-zinc-900 to-sky-950 text-white py-12 relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(255,84,0,0.1),transparent)]"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col sm:flex-row justify-between items-center gap-6">
        <div class="space-y-2 text-center sm:text-left">
          <span class="text-nike-orange font-extrabold text-xs uppercase tracking-widest block">Quản trị viên</span>
          <h1 class="text-3xl font-black uppercase tracking-tight">Hệ Thống Quản Trị Nike Store</h1>
          <p class="text-xs text-gray-400 font-light max-w-md">
            Quản lý và vận hành toàn bộ cửa hàng: sản phẩm, tài khoản khách hàng, theo dõi và xử lý chi tiết các đơn hàng của khách.
          </p>
        </div>
        <div class="flex items-center gap-3">
          <button onclick="logout()" class="bg-red-500 hover:bg-red-600 text-white font-bold text-xs px-4 py-3 rounded-full uppercase tracking-wider transition-colors shadow-lg shadow-red-500/20">Đăng xuất</button>
          <a href="/" class="bg-white hover:bg-gray-100 text-nike-black font-bold text-xs px-4 py-3 rounded-full uppercase tracking-wider transition-colors shadow-md">Xem cửa hàng</a>
        </div>
      </div>
    </div>

    <!-- ========================================== -->
    <!-- TABS NAVIGATION                            -->
    <!-- ========================================== -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      
      <!-- Tab selectors -->
      <div class="flex border-b border-gray-200 gap-8 mb-8 overflow-x-auto pb-1">
        <button onclick="switchAdminTab('orders')" id="tabBtn-orders" class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-nike-orange text-nike-orange">
          Đơn Hàng (<%= orders.length %>)
        </button>
        <button onclick="switchAdminTab('products')" id="tabBtn-products" class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black">
          Sản Phẩm (<%= products.length %>)
        </button>
        <button onclick="switchAdminTab('users')" id="tabBtn-users" class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black">
          Khách Hàng (<%= users.length %>)
        </button>
        <button onclick="switchAdminTab('vouchers')" id="tabBtn-vouchers" class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black">
          Mã Giảm Giá (<%= typeof vouchers !== 'undefined' ? vouchers.length : 0 %>)
        </button>
      </div>

      <!-- ========================================== -->
      <!-- TAB CONTENT: ORDERS                        -->
      <!-- ========================================== -->
      <div id="tabContent-orders" class="admin-tab-content space-y-6">
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
            <h3 class="font-bold text-base text-nike-black uppercase tracking-wide">Danh sách đơn hàng của khách</h3>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="bg-gray-100/50 text-gray-500 font-bold uppercase tracking-wider border-b border-gray-100">
                  <th class="p-4">Mã đơn</th>
                  <th class="p-4">Khách hàng</th>
                  <th class="p-4">Điện thoại</th>
                  <th class="p-4">Tổng tiền</th>
                  <th class="p-4">Giao hàng</th>
                  <th class="p-4">Thanh toán</th>
                  <th class="p-4">Ngày đặt</th>
                  <th class="p-4 text-center">Chi tiết</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% if(orders.length > 0) { %>
                  <% orders.forEach(order => { %>
                    <tr class="hover:bg-gray-50/30 transition-colors">
                      <td class="p-4 font-bold text-nike-orange">#<%= order.id %></td>
                      <td class="p-4 font-semibold text-gray-800"><%= order.fullname %></td>
                      <td class="p-4 text-gray-500 font-medium"><%= order.phone %></td>
                      <td class="p-4 font-extrabold text-nike-black"><%= formatPrice(order.total_amount) %></td>
                      <td class="p-4">
                        <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                          <%= order.status === 'pending' ? 'bg-amber-100 text-amber-800' :
                             order.status === 'processing' ? 'bg-blue-100 text-blue-800' :
                             order.status === 'shipped' ? 'bg-indigo-100 text-indigo-800' :
                             order.status === 'delivered' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                          <%= order.status === 'pending' ? 'Chờ duyệt' :
                             order.status === 'processing' ? 'Đang soạn' :
                             order.status === 'shipped' ? 'Đang giao' :
                             order.status === 'delivered' ? 'Đã giao' : 'Đã hủy' %>
                        </span>
                      </td>
                      <!-- Cột Thanh toán -->
                      <td class="p-4">
                        <div class="flex flex-col gap-1">
                          <!-- Phương thức -->
                          <% if (order.payment_method && order.payment_method.toLowerCase() === 'vpbank') { %>
                            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-200">
                              🏦 VPBank
                            </span>
                          <% } else { %>
                            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-600">
                              🚚 COD
                            </span>
                          <% } %>
                          <!-- Trạng thái TT -->
                          <% if (order.payment_method && order.payment_method.toLowerCase() === 'vpbank') { %>
                            <% if (order.payment_status === 'paid') { %>
                              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700">
                                ✔ Đã nhận tiền
                              </span>
                            <% } else if (order.payment_status === 'failed') { %>
                              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700">
                                ✗ Thất bại
                              </span>
                            <% } else { %>
                              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-700">
                                ⏳ Chờ TT
                              </span>
                            <% } %>
                          <% } %>
                        </div>
                      </td>
                      <td class="p-4 text-gray-400 font-medium">
                        <%= new Date(order.created_at).toLocaleDateString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %>
                      </td>
                      <td class="p-4 text-center">
                        <button onclick="viewOrderDetails(this)" data-id="<%= order.id %>" data-payment-method="<%= order.payment_method || 'cod' %>" data-payment-status="<%= order.payment_status || 'pending' %>" class="bg-nike-black hover:bg-nike-orange text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors shadow-sm focus:outline-none">Xem</button>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="7" class="p-8 text-center text-gray-400 font-bold">Chưa có đơn hàng nào được tạo!</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ========================================== -->
      <!-- TAB CONTENT: PRODUCTS                      -->
      <!-- ========================================== -->
      <div id="tabContent-products" class="admin-tab-content space-y-6 hidden">
        
        <!-- Toolbar: Search + Filter + Add Button -->
        <div class="flex flex-col sm:flex-row justify-between items-center gap-3 relative">
          <!-- Left: Search and Filter Toggle -->
          <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
            <div class="relative w-full sm:w-72">
              <input type="text" id="adminProductSearch" placeholder="Tìm theo tên, loại, danh mục..." oninput="adminFilterProducts()" class="bg-white border border-gray-200 rounded-full py-2.5 pl-4 pr-10 text-xs font-medium focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full text-gray-700 shadow-sm">
              <svg class="w-4 h-4 text-gray-400 absolute right-3.5 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            
            <button onclick="document.getElementById('adminFilterPanel').classList.toggle('hidden')" class="bg-white border border-gray-200 hover:border-nike-orange text-gray-700 hover:text-nike-orange font-bold text-xs px-4 py-2.5 rounded-full flex items-center justify-center gap-2 transition-all shadow-sm focus:outline-none w-full sm:w-auto">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
              Lọc
            </button>
          </div>

          <!-- Admin Filter Panel -->
          <div id="adminFilterPanel" class="hidden absolute top-[110%] left-0 mt-2 w-full sm:w-[350px] bg-white rounded-3xl border border-gray-100 shadow-2xl p-5 z-[100]">
            <div class="flex justify-between items-center mb-4 border-b border-gray-50 pb-2">
              <h3 class="font-extrabold text-sm uppercase tracking-wider text-nike-black">Lọc Sản Phẩm</h3>
              <button onclick="document.getElementById('adminFilterPanel').classList.add('hidden')" class="text-gray-400 hover:text-nike-orange focus:outline-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
            
            <div class="space-y-4">
              <div class="space-y-2">
                <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Danh mục (Giới tính)</span>
                <select id="adminCategoryFilter" onchange="adminFilterProducts()" class="bg-gray-50 border-0 rounded-xl py-2.5 px-3 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
                  <option value="">Tất cả danh mục</option>
                  <option value="men">Nam</option>
                  <option value="women">Nữ</option>
                  <option value="kids">Trẻ em</option>
                </select>
              </div>

              <div class="space-y-2">
                <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Tình trạng Kho</span>
                <select id="adminStockFilter" onchange="adminFilterProducts()" class="bg-gray-50 border-0 rounded-xl py-2.5 px-3 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
                  <option value="">Tất cả tình trạng</option>
                  <option value="instock">Còn hàng (Stock > 0)</option>
                  <option value="outstock">Hết hàng (Stock = 0)</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Right side: count + add button -->
          <div class="flex items-center justify-end gap-3 w-full sm:w-auto">
            <span id="adminProductCount" class="text-xs text-gray-400 font-bold whitespace-nowrap"></span>
            <button onclick="openProductDrawer()" class="bg-nike-black hover:bg-nike-orange text-white font-bold text-xs px-5 py-3 rounded-full uppercase tracking-wider transition-colors shadow-md flex items-center gap-1.5 glow-dark hover:glow-orange whitespace-nowrap">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              Thêm mới
            </button>
          </div>
        </div>

        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="bg-gray-100/50 text-gray-500 font-bold uppercase tracking-wider border-b border-gray-100">
                  <th class="p-4">Mã</th>
                  <th class="p-4">Hình</th>
                  <th class="p-4">Tên sản phẩm</th>
                  <th class="p-4">Phân loại</th>
                  <th class="p-4">Giá gốc</th>
                  <th class="p-4">Màu sắc</th>
                  <th class="p-4">Kho</th>
                  <th class="p-4 text-center">Thao tác</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% if(products.length > 0) { %>
                  <% products.forEach(prod => { %>
                    <tr class="hover:bg-gray-50/30 transition-colors"
                        data-product-row="1"
                        data-category="<%= prod.category %>"
                        data-stock="<%= prod.stock %>"
                        data-search-text="<%= (prod.title + ' ' + prod.category + ' ' + (prod.item_type||'') + ' ' + (prod.color||'')).toLowerCase() %>">
                      <td class="p-4 font-bold text-gray-400">#<%= prod.id %></td>
                      <td class="p-4">
                        <div class="w-10 h-10 bg-gray-50 border border-gray-100 rounded-lg flex items-center justify-center p-1 overflow-hidden">
                          <img src="<%= prod.image %>" alt="<%= prod.title %>" class="w-full h-auto object-contain" onerror="this.src='/nike.png'">
                        </div>
                      </td>
                      <td class="p-4 font-bold text-gray-800 max-w-[200px] truncate"><%= prod.title %></td>
                      <td class="p-4">
                        <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-700">
                          <%= prod.category === 'men' ? 'Nam' : prod.category === 'women' ? 'Nữ' : 'Trẻ em' %>
                        </span>
                      </td>
                      <td class="p-4 font-bold text-nike-orange"><%= formatPrice(prod.price) %></td>
                      <td class="p-4 font-semibold text-gray-600"><%= prod.color || 'Trắng' %></td>
                      <td class="p-4 font-bold text-gray-600"><%= prod.stock %> chiếc</td>
                      <td class="p-4 text-center">
                        <div class="flex gap-2 justify-center">
                          <button onclick="editProduct(this)" data-product="<%= encodeURIComponent(JSON.stringify(prod)) %>" class="border-2 border-gray-200 hover:border-nike-orange text-gray-500 hover:text-nike-orange text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Sửa</button>
                          <button onclick="deleteProduct(this)" data-id="<%= prod.id %>" class="border-2 border-gray-200 hover:border-red-500 text-gray-500 hover:text-red-500 text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Xóa</button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="8" class="p-8 text-center text-gray-400 font-bold">Chưa có sản phẩm nào!</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Admin Products Pagination Bar -->
        <div id="adminProductPagination" class="flex items-center justify-center gap-2 mt-4 flex-wrap"></div>
      </div>

      <!-- ========================================== -->
      <!-- TAB CONTENT: USERS                         -->
      <!-- ========================================== -->
      <div id="tabContent-users" class="admin-tab-content space-y-6 hidden">
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-100">
            <h3 class="font-bold text-base text-nike-black uppercase tracking-wide">Tài khoản thành viên</h3>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="bg-gray-100/50 text-gray-500 font-bold uppercase tracking-wider border-b border-gray-100">
                  <th class="p-4">ID</th>
                  <th class="p-4">Tên đăng nhập</th>
                  <th class="p-4">Vai trò</th>
                  <th class="p-4">Ngày tạo</th>
                  <th class="p-4 text-center">Xóa tài khoản</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% if(users.length > 0) { %>
                  <% users.forEach(user => { %>
                    <tr class="hover:bg-gray-50/30 transition-colors">
                      <td class="p-4 font-bold text-gray-400">#<%= user.id %></td>
                      <td class="p-4 font-semibold text-gray-800"><%= user.username %></td>
                      <td class="p-4">
                        <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                          <%= user.role === 'admin' ? 'bg-purple-100 text-purple-800' : 'bg-gray-100 text-gray-700' %>">
                          <%= user.role === 'admin' ? 'Quản trị' : 'Thành viên' %>
                        </span>
                      </td>
                      <td class="p-4 text-gray-400 font-medium">
                        <%= new Date(user.created_at).toLocaleDateString('vi-VN') %>
                      </td>
                      <td class="p-4 text-center">
                        <% if(user.username !== 'admin') { %>
                          <button onclick="deleteUser(this)" data-id="<%= user.id %>" class="border-2 border-gray-100 hover:border-red-500 text-gray-400 hover:text-red-500 text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Xóa</button>
                        <% } else { %>
                          <span class="text-gray-300 font-bold text-[10px] uppercase">Hệ thống</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" class="p-8 text-center text-gray-400 font-bold">Chưa có người dùng nào!</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ========================================== -->
      <!-- TAB CONTENT: VOUCHERS                      -->
      <!-- ========================================== -->
      <div id="tabContent-vouchers" class="admin-tab-content space-y-6 hidden">
        <div class="flex justify-between items-center mb-4">
          <h3 class="font-extrabold text-lg text-nike-black uppercase tracking-wide">Quản lý Mã Giảm Giá</h3>
          <button onclick="openVoucherDrawer()" class="bg-nike-black hover:bg-nike-orange text-white font-bold text-xs px-5 py-3 rounded-full uppercase tracking-wider transition-colors shadow-md flex items-center gap-1.5 glow-dark hover:glow-orange">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Tạo Mã Mới
          </button>
        </div>

        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="bg-gray-100/50 text-gray-500 font-bold uppercase tracking-wider border-b border-gray-100">
                  <th class="p-4">Mã</th>
                  <th class="p-4">Loại</th>
                  <th class="p-4">Mức Giảm</th>
                  <th class="p-4">Điều kiện & Tối đa</th>
                  <th class="p-4 text-center">Đã dùng / Tổng</th>
                  <th class="p-4">Hạn SD</th>
                  <th class="p-4 text-center">Trạng thái</th>
                  <th class="p-4 text-center">Thao tác</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% if(typeof vouchers !== 'undefined' && vouchers.length > 0) { %>
                  <% vouchers.forEach(v => { %>
                    <tr class="hover:bg-gray-50/30 transition-colors">
                      <td class="p-4 font-extrabold text-gray-800"><%= v.code %></td>
                      <td class="p-4">
                        <% if(v.category === 'shipping') { %>
                          <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-green-100 text-green-700">Freeship</span>
                        <% } else { %>
                          <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-orange-100 text-orange-700">Sản phẩm</span>
                        <% } %>
                      </td>
                      <td class="p-4 font-bold text-nike-orange">
                        <%= v.discount_type === 'percent' ? v.discount_value + '%' : formatPrice(v.discount_value) %>
                      </td>
                      <td class="p-4 text-gray-500 font-medium">
                        Min: <%= formatPrice(v.min_order_value) %> <br>
                        Max: <%= v.max_discount ? formatPrice(v.max_discount) : 'Không có' %>
                      </td>
                      <td class="p-4 text-center font-bold text-gray-600">
                        <%= v.used_count %> / <%= v.usage_limit %>
                      </td>
                      <td class="p-4 text-gray-500 font-medium whitespace-nowrap">
                        <%= new Date(v.expires_at).toLocaleDateString('vi-VN') %>
                      </td>
                      <td class="p-4 text-center">
                        <% if(v.is_active) { %>
                          <span class="text-green-500 font-bold">● Đang bật</span>
                        <% } else { %>
                          <span class="text-red-500 font-bold">● Đã tắt</span>
                        <% } %>
                      </td>
                      <td class="p-4 text-center">
                        <div class="flex gap-2 justify-center">
                          <button onclick="editVoucher(this)" data-voucher="<%= encodeURIComponent(JSON.stringify(v)) %>" class="border-2 border-gray-200 hover:border-nike-orange text-gray-500 hover:text-nike-orange text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Sửa</button>
