  <!-- Admin Verification & Tab JS Routing -->
  <script>
    let activeAdminTab = sessionStorage.getItem('adminCurrentTab') || 'orders';

    window.addEventListener('DOMContentLoaded', () => {
      const tabToOpen = sessionStorage.getItem('adminCurrentTab') || 'orders';
      activeAdminTab = null;
      switchAdminTab(tabToOpen);

      // Init admin product search + pagination
      adminFilterProducts();
    });

    // ── Admin Product Search + Pagination ────────────────────────────────────
    const ADMIN_PAGE_SIZE = 20;
    let adminCurrentPage = 1;
    let adminFilteredRows = [];

    function adminFilterProducts() {
      const query = (document.getElementById('adminProductSearch')?.value || '').toLowerCase().trim();
      const catFilter = document.getElementById('adminCategoryFilter')?.value || '';
      const stockFilter = document.getElementById('adminStockFilter')?.value || '';
      const tbody = document.querySelector('#tabContent-products tbody');
      if (!tbody) return;

      const allRows = Array.from(tbody.querySelectorAll('tr[data-product-row]'));
      adminFilteredRows = allRows.filter(row => {
        const searchText = row.getAttribute('data-search-text').toLowerCase();
        const category = row.getAttribute('data-category');
        const stock = parseInt(row.getAttribute('data-stock')) || 0;
        
        const matchesQuery = !query || searchText.includes(query);
        const matchesCategory = !catFilter || category === catFilter;
        let matchesStock = true;
        
        if (stockFilter === 'instock') matchesStock = stock > 0;
        else if (stockFilter === 'outstock') matchesStock = stock === 0;

        return matchesQuery && matchesCategory && matchesStock;
      });

      adminCurrentPage = 1;
      adminRenderPage();
    }

    function adminRenderPage() {
      const tbody = document.querySelector('#tabContent-products tbody');
      const countEl = document.getElementById('adminProductCount');
      const paginationEl = document.getElementById('adminProductPagination');
      if (!tbody) return;

      const allRows = Array.from(tbody.querySelectorAll('tr[data-product-row]'));

      // Hide all first
      allRows.forEach(r => r.classList.add('hidden'));

      // Show page slice
      const totalPages = Math.max(1, Math.ceil(adminFilteredRows.length / ADMIN_PAGE_SIZE));
      adminCurrentPage = Math.min(adminCurrentPage, totalPages);
      const start = (adminCurrentPage - 1) * ADMIN_PAGE_SIZE;
      adminFilteredRows.slice(start, start + ADMIN_PAGE_SIZE).forEach(r => r.classList.remove('hidden'));

      // Update count
      if (countEl) countEl.textContent = `${adminFilteredRows.length} sản phẩm`;

      // Render pagination
      if (!paginationEl) return;
      paginationEl.innerHTML = '';
      if (totalPages <= 1) return;

      const mkBtn = (label, page, active = false, disabled = false) => {
        const el = document.createElement('button');
        el.innerHTML = label;
        el.className = [
          'px-3 py-1.5 rounded-full text-xs font-bold transition-all border',
          active ? 'bg-nike-black text-white border-nike-black shadow-md' : 'bg-white text-gray-600 border-gray-200 hover:border-nike-orange hover:text-nike-orange',
          disabled ? 'opacity-40 cursor-not-allowed pointer-events-none' : ''
        ].join(' ');
        if (!disabled) el.onclick = () => { adminCurrentPage = page; adminRenderPage(); };
        return el;
      };

      paginationEl.appendChild(mkBtn('&laquo; Trước', adminCurrentPage - 1, false, adminCurrentPage === 1));

      const startP = Math.max(1, adminCurrentPage - 2);
      const endP   = Math.min(totalPages, adminCurrentPage + 2);
      for (let i = startP; i <= endP; i++) {
        paginationEl.appendChild(mkBtn(i, i, i === adminCurrentPage));
      }

      paginationEl.appendChild(mkBtn('Sau &raquo;', adminCurrentPage + 1, false, adminCurrentPage === totalPages));
    }

