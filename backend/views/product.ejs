<%- include('partials/header', { title: 'Nike Store - ' + product.title }) %>

<% 
  // Helper to format price in EJS
  function formatPrice(number) {
    let cleanVal = parseFloat(String(number).replace(/[^0-9.-]+/g,""));
    if (isNaN(cleanVal)) return number;
    if (cleanVal < 100000) {
      cleanVal = cleanVal * 1000;
    }
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cleanVal);
  }
%>

  <!-- ========================================== -->
  <!-- BREADCRUMBS & NAVIGATION                   -->
  <!-- ========================================== -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
    <nav class="flex text-xs font-semibold text-gray-400 uppercase tracking-wider items-center gap-2">
      <a href="/" class="hover:text-nike-orange transition-colors">Trang Chủ</a>
      <span>&bull;</span>
      <a href="/<%= product.category %>" class="hover:text-nike-orange transition-colors"><%= product.category === 'men' ? 'Nam' : product.category === 'women' ? 'Nữ' : 'Trẻ Em' %></a>
      <span>&bull;</span>
      <span class="text-gray-800 font-bold"><%= product.title %></span>
    </nav>
  </div>

  <!-- ========================================== -->
  <!-- PRODUCT DETAILS LAYOUT                    -->
  <!-- ========================================== -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start bg-white rounded-3xl p-6 sm:p-10 border border-gray-100 shadow-sm">
      
      <!-- Left Column: Product Image Box -->
      <div class="space-y-6">
        <div class="bg-gradient-to-b from-gray-50/50 to-white rounded-3xl border border-gray-100 p-8 flex items-center justify-center overflow-hidden aspect-square relative group">
          
          <!-- Badges (New / Discount) -->
          <div class="absolute top-6 left-6 z-20 flex flex-col gap-2">
            <% if (product.is_new) { %>
              <span class="bg-red-500 text-white font-extrabold text-[10px] uppercase tracking-widest px-3 py-1.5 rounded-full shadow-sm">MỚI NHẤT</span>
            <% } %>
            <% if (product.discount_percent > 0) { %>
              <span class="bg-nike-orange text-white font-extrabold text-[10px] uppercase tracking-widest px-3 py-1.5 rounded-full shadow-sm">SALE GIẢM <%= product.discount_percent %>%</span>
            <% } %>
          </div>

          <!-- Product Image -->
          <img src="<%= product.image %>" alt="<%= product.title %>" class="max-w-[85%] max-h-full object-contain transform group-hover:scale-105 transition-transform duration-500 pointer-events-none" id="mainProductImage" onerror="this.src='/nike.png'">
        </div>
        
        <!-- Trust banners -->
        <div class="grid grid-cols-3 gap-4 text-center">
          <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100/50">
            <h5 class="font-bold text-xs uppercase tracking-wide text-gray-800">100% Chính hãng</h5>
            <p class="text-[10px] text-gray-400 mt-0.5">Nike Official Store</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100/50">
            <h5 class="font-bold text-xs uppercase tracking-wide text-gray-800">Ship Hỏa Tốc</h5>
            <p class="text-[10px] text-gray-400 mt-0.5">Giao nhanh toàn quốc</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100/50">
            <h5 class="font-bold text-xs uppercase tracking-wide text-gray-800">Miễn Phí Đổi</h5>
            <p class="text-[10px] text-gray-400 mt-0.5">Lên tới 30 ngày</p>
          </div>
        </div>
      </div>

      <!-- Right Column: Info & Action Panel -->
      <div class="space-y-6 lg:pl-4">
        <!-- Header -->
        <div class="space-y-2 border-b pb-6">
          <span class="text-nike-orange font-bold text-xs uppercase tracking-wider block"><%= product.item_type %> &bull; <%= product.category === 'men' ? 'Bộ sưu tập Nam' : product.category === 'women' ? 'Bộ sưu tập Nữ' : 'Bộ sưu tập Trẻ Em' %></span>
          <h1 class="text-2xl sm:text-3xl font-extrabold text-nike-black leading-tight uppercase"><%= product.title %></h1>
          
          <div class="flex items-center gap-4 mt-2">
            <!-- Rating stars -->
            <div class="flex items-center gap-1.5">
              <div class="flex text-yellow-400">
                <% for(let i=0; i<5; i++) { %>
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <% } %>
              </div>
              <span class="text-xs text-gray-500 font-extrabold"><%= product.rating || '4.5' %> / 5.0</span>
            </div>
            <span class="text-gray-300">|</span>
            <span class="text-xs text-green-600 font-bold">Còn hàng: <%= product.stock %> sản phẩm</span>
          </div>
        </div>

        <!-- Price Section -->
        <div class="bg-gray-50/50 p-5 rounded-2xl border border-gray-100 flex items-center justify-between">
          <div>
            <span class="text-[10px] text-gray-400 uppercase font-bold tracking-wider block">Giá niêm yết</span>
            <div class="flex items-baseline gap-2 mt-1">
              <% if (product.discount_percent > 0) { %>
                <% 
                  let numPrice = parseFloat(product.price);
                  let finalPrice = numPrice * (1 - product.discount_percent / 100);
                %>
                <span class="text-2xl font-black text-nike-orange"><%= formatPrice(finalPrice) %></span>
                <span class="text-sm text-gray-400 line-through"><%= formatPrice(product.price) %></span>
              <% } else { %>
                <span class="text-2xl font-black text-nike-black"><%= formatPrice(product.price) %></span>
              <% } %>
            </div>
          </div>
          <span class="bg-nike-orange/10 text-nike-orange text-[10px] font-extrabold uppercase px-3 py-1 rounded-full">Cam kết giá tốt</span>
        </div>

        <!-- Color Selector -->
        <div class="space-y-3">
          <% 
            let defaultColor = (product.color || 'Trắng').split(',')[0].trim();
          %>
          <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Màu sắc: <strong id="selectedColorLabel" class="text-nike-black"><%= defaultColor %></strong></span>
          <div class="flex gap-3">
            <% 
              let colorsArray = (product.color || 'Trắng').split(',');
              let colorHexMap = {
                'trắng': '#ffffff',
                'white': '#ffffff',
                'đen': '#171717',
                'black': '#171717',
                'đỏ': '#dc2626',
                'red': '#dc2626',
                'xanh': '#2563eb',
                'blue': '#2563eb',
                'xanh lá': '#16a34a',
                'green': '#16a34a',
                'vàng': '#facc15',
                'yellow': '#facc15',
                'hồng': '#ec4899',
                'pink': '#ec4899',
                'cam': '#f97316',
                'orange': '#f97316',
                'xám': '#9ca3af',
                'gray': '#9ca3af',
                'grey': '#9ca3af',
                'tím': '#9333ea',
                'purple': '#9333ea'
              };
              colorsArray.forEach((color, idx) => {
                let cleanColor = color.trim();
                let lowerColor = cleanColor.toLowerCase();
                let hexColor = colorHexMap[lowerColor] || '#9ca3af'; // fallback to gray
              %>
                <button onclick="selectColor('<%= cleanColor %>', this)" 
                        class="color-btn w-8 h-8 rounded-full border-2 <%= idx === 0 ? 'border-nike-black' : 'border-transparent' %> flex items-center justify-center shadow-sm relative focus:outline-none transition-all duration-200"
                        title="<%= cleanColor %>">
                  <span class="absolute w-5 h-5 rounded-full border border-gray-200" style="background-color: <%= hexColor %>;"></span>
                </button>
              <% }) %>
          </div>
        </div>

        <!-- Size Selector -->
        <div class="space-y-3">
          <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Chọn Kích Cỡ: <strong id="selectedSizeLabel" class="text-nike-black">39</strong></span>
          <div class="flex flex-wrap gap-2.5">
            <% 
              let sizesArray = product.sizes.split(',');
              sizesArray.forEach((size, idx) => {
            %>
              <button onclick="selectSize('<%= size.trim() %>', this)" class="size-btn px-4 py-2.5 rounded-xl border-2 text-xs font-bold uppercase transition-all duration-200 focus:outline-none <%= idx === 1 ? 'bg-nike-black border-nike-black text-white' : 'border-gray-200 text-gray-600 hover:border-nike-black hover:text-nike-black bg-white' %>">
                <%= size.trim() %>
              </button>
            <% }) %>
          </div>
        </div>

        <!-- Quantity Selector -->
        <div class="space-y-3">
          <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Số lượng:</span>
          <div class="flex items-center border border-gray-200 rounded-full bg-white px-3 py-1.5 w-32 shadow-sm">
            <button onclick="adjustQty(-1)" class="text-gray-500 hover:text-nike-black font-extrabold text-lg px-2 focus:outline-none">-</button>
            <span id="productQty" class="text-sm font-bold flex-1 text-center select-none">1</span>
            <button onclick="adjustQty(1)" class="text-gray-500 hover:text-nike-black font-extrabold text-lg px-2 focus:outline-none">+</button>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <!-- Add to Cart -->
          <button onclick="triggerAddToCart()" class="flex-1 bg-nike-black hover:bg-nike-orange text-white text-center font-extrabold py-4 px-6 rounded-full text-xs uppercase tracking-widest transition-all duration-300 shadow-md flex items-center justify-center gap-2 glow-dark hover:glow-orange focus:outline-none">
            <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            Thêm vào giỏ hàng
          </button>
          <!-- Wishlist Toggle -->
          <button onclick="toggleWishlist(JSON.parse(decodeURIComponent('<% animate = encodeURIComponent(JSON.stringify(product)) %><%= animate %>')))" class="border-2 border-gray-200 hover:border-red-500 hover:text-red-500 text-gray-600 font-extrabold py-4 px-6 rounded-full text-xs uppercase tracking-widest transition-all duration-200 flex items-center justify-center gap-2 focus:outline-none">
            <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            Yêu thích
          </button>
        </div>

        <!-- Description Box -->
        <div class="border-t pt-6 space-y-3">
          <span class="text-xs text-gray-800 font-extrabold uppercase tracking-wide block">Mô tả sản phẩm</span>
          <p class="text-xs text-gray-500 leading-relaxed font-light">
            <%= product.description ? product.description : 'Sản phẩm giày Nike cao cấp, mang thiết kế đột phá, nâng đỡ tối đa đôi chân. Giúp tạo phong cách riêng biệt, tràn đầy cá tính trên mọi hành trình. Chất liệu vải lưới thông khí hoàn hảo, đế cao su chống trượt bền bỉ mang lại sự an tâm tuyệt đối.' %>
          </p>
        </div>

      </div>

    </div>
  </div>

  <!-- ========================================== -->
  <!-- CUSTOMER REVIEWS & RATINGS SECTION        -->
  <!-- ========================================== -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-gray-100">
    <div class="border-b border-gray-100 pb-5 mb-8">
      <span class="text-nike-orange font-bold text-xs uppercase tracking-widest">Phản hồi của khách hàng</span>
      <h2 class="text-2xl font-extrabold tracking-tight uppercase mt-1">Đánh Giá & Nhận Xét</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      
      <!-- Column 1 & 2: Review List -->
      <div class="lg:col-span-2 space-y-6">
        <h3 class="font-bold text-sm text-gray-800 uppercase tracking-wider">Nhận xét từ người mua (<%= typeof reviews !== 'undefined' ? reviews.length : 0 %>)</h3>
        
        <% if (typeof reviews !== 'undefined' && reviews.length > 0) { %>
          <div class="space-y-4 max-h-[500px] overflow-y-auto pr-2" id="reviewsContainer">
            <% reviews.forEach(review => { %>
              <div class="bg-white rounded-3xl border border-gray-100 p-5 shadow-sm space-y-3 hover:border-nike-orange/10 transition-colors">
                <div class="flex justify-between items-start">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center font-bold text-xs text-nike-orange uppercase border">
                      <%= review.username.slice(0,2) %>
                    </div>
                    <div>
                      <h5 class="font-bold text-xs text-nike-black uppercase"><%= review.username %></h5>
                      <span class="text-[9px] text-gray-400 font-medium"><%= new Date(review.created_at).toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    </div>
                  </div>
                  <!-- Stars -->
                  <div class="flex text-yellow-400">
                    <% for(let i=1; i<=5; i++) { %>
                      <svg class="w-3.5 h-3.5 <%= i <= review.rating ? 'fill-current' : 'text-gray-200 fill-current' %>" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    <% } %>
                  </div>
                </div>
                <p class="text-xs text-gray-500 font-light leading-relaxed">
                  <%= review.comment %>
                </p>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="bg-white rounded-3xl border border-gray-100 p-10 text-center space-y-3 text-gray-400" id="noReviewsPlaceholder">
            <svg class="w-12 h-12 mx-auto stroke-[1.2] text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            <p class="text-xs font-semibold">Chưa có đánh giá nào cho đôi giày này.</p>
            <p class="text-[10px] font-light">Hãy là người đầu tiên chia sẻ cảm nhận về sản phẩm này của Nike!</p>
          </div>
        <% } %>
      </div>

      <!-- Column 3: Add Review Form -->
      <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm h-fit space-y-5">
        <div class="border-b border-gray-50 pb-3">
          <h4 class="font-extrabold text-sm text-nike-black uppercase tracking-wider">Viết Đánh Giá Của Bạn</h4>
          <p class="text-[10px] text-gray-400 mt-1 font-light leading-relaxed">Chia sẻ cảm nhận của bạn để giúp cộng đồng yêu giày có sự lựa chọn tốt nhất.</p>
        </div>

        <form id="reviewSubmitForm" class="space-y-4">
          <!-- Username Input -->
          <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider block">Tên hiển thị</label>
            <input type="text" id="reviewAuthor" required placeholder="Nhập họ tên của bạn..." class="w-full bg-gray-50 border-0 rounded-xl py-3.5 px-4 text-xs font-medium text-nike-black focus:outline-none focus:ring-2 focus:ring-nike-orange/30">
          </div>

          <!-- Star Selector -->
          <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider block">Chọn số sao đánh giá</label>
            <div class="flex gap-2 text-gray-300" id="ratingSelector">
              <% for(let star=1; star<=5; star++) { %>
                <button type="button" onclick="setFormRating(<%= star %>)" class="rating-star-btn text-2xl hover:scale-120 transition-transform focus:outline-none text-yellow-400" data-star="<%= star %>">&#9733;</button>
              <% } %>
            </div>
            <input type="hidden" id="reviewRatingVal" value="5">
          </div>

          <!-- Review Content -->
          <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider block">Nội dung nhận xét</label>
            <textarea id="reviewComment" required rows="4" placeholder="Đôi giày này đi có êm không, size chuẩn không..." class="w-full bg-gray-50 border-0 rounded-xl py-3.5 px-4 text-xs font-medium text-nike-black focus:outline-none focus:ring-2 focus:ring-nike-orange/30 resize-none leading-relaxed"></textarea>
          </div>

          <!-- Submit Button -->
          <button type="submit" class="w-full bg-nike-black hover:bg-nike-orange text-white py-3.5 rounded-full text-xs font-bold uppercase tracking-widest transition-all duration-300 shadow-md glow-dark hover:glow-orange focus:outline-none">Gửi đánh giá</button>
        </form>
      </div>

    </div>
  </div>

  <!-- ========================================== -->
  <!-- RECOMMENDED PRODUCTS                       -->
  <!-- ========================================== -->
  <% if (typeof relatedProducts !== 'undefined' && relatedProducts.length > 0) { %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="border-b border-gray-100 pb-5 mb-8">
        <span class="text-nike-orange font-bold text-xs uppercase tracking-widest">Gợi ý dành riêng cho bạn</span>
        <h2 class="text-2xl font-extrabold tracking-tight uppercase mt-1">Sản Phẩm Tương Tự</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% relatedProducts.slice(0, 4).forEach(rel => { %>
          <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl border border-gray-100/60 hover:border-nike-orange/15 transition-all duration-300 flex flex-col relative">
            <div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
              <% if (rel.is_new) { %>
                <span class="bg-red-500 text-white font-extrabold text-[9px] uppercase tracking-widest px-2.5 py-1 rounded-full shadow-sm">NEW</span>
              <% } %>
            </div>

            <!-- Image -->
            <div class="h-56 bg-gradient-to-b from-gray-50/50 to-white flex items-center justify-center overflow-hidden p-6 relative">
              <a href="/products/<%= rel.id %>" class="w-full h-full flex items-center justify-center">
                <img src="<%= rel.image %>" alt="<%= rel.title %>" class="max-w-[85%] max-h-full object-contain transform group-hover:scale-110 transition-transform duration-500 ease-out z-10" onerror="this.src='/nike.png'">
              </a>
            </div>

            <!-- Content -->
            <div class="p-5 flex-1 flex flex-col justify-between space-y-3">
              <div>
                <span class="text-[9px] uppercase font-bold text-gray-400 tracking-wider"><%= rel.item_type %></span>
                <a href="/products/<%= rel.id %>" class="block font-bold text-gray-800 text-sm hover:text-nike-orange transition-colors truncate mt-1"><%= rel.title %></a>
              </div>
              <div class="flex justify-between items-center pt-2.5 border-t border-gray-50">
                <span class="font-extrabold text-sm text-nike-black"><%= formatPrice(rel.price) %></span>
                <button onclick="window.location.href='/products/<%= rel.id %>'" class="bg-nike-black hover:bg-nike-orange text-white text-[10px] font-bold px-3.5 py-1.5 rounded-full uppercase tracking-wider transition-colors duration-200">Xem</button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Page Interactivity Scripts -->
  <script>
    let selectedSize = '<%= (product.sizes || "39").split(",")[0].trim() %>';
    let selectedColor = '<%= (product.color || "Trắng").split(",")[0].trim() %>';
    let selectedQty = 1;
    let currentFormRating = 5;

    const productData = <%- JSON.stringify(product) %>;

    // Prefill form if user is logged in
    document.addEventListener('DOMContentLoaded', function() {
      const userStr = localStorage.getItem('nike_user');
      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          document.getElementById('reviewAuthor').value = user.username;
          document.getElementById('reviewAuthor').readOnly = true;
          document.getElementById('reviewAuthor').classList.add('bg-gray-100', 'cursor-not-allowed');
        } catch (e) {}
      }
    });

    function setFormRating(rating) {
      currentFormRating = rating;
      document.getElementById('reviewRatingVal').value = rating;
      
      // Update star colors visually
      document.querySelectorAll('.rating-star-btn').forEach(btn => {
        const starVal = parseInt(btn.getAttribute('data-star'));
        if (starVal <= rating) {
          btn.classList.add('text-yellow-400');
          btn.classList.remove('text-gray-300');
        } else {
          btn.classList.remove('text-yellow-400');
          btn.classList.add('text-gray-300');
        }
      });
    }

    // Handle review submission via AJAX
    document.getElementById('reviewSubmitForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const author = document.getElementById('reviewAuthor').value.trim();
      const comment = document.getElementById('reviewComment').value.trim();
      const rating = currentFormRating;
      
      if (!comment) return;
      
      const userStr = localStorage.getItem('nike_user');
      let userId = null;
      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          userId = user.id;
        } catch (e) {}
      }
      
      try {
        const response = await fetch(`/api/products/${productData.id}/reviews`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            username: author,
            rating: rating,
            comment: comment,
            user_id: userId
          })
        });
        
        const result = await response.json();
        if (result.status === 'success') {
          // Alert user and reload to display new review
          alert('Cảm ơn bạn! Đánh giá đã được gửi lên hệ thống.');
          window.location.reload();
        } else {
          alert('Lỗi: ' + result.message);
        }
      } catch (err) {
        alert('Lỗi kết nối máy chủ, không thể gửi nhận xét.');
      }
    });

    function selectSize(size, element) {
      selectedSize = size;
      document.getElementById('selectedSizeLabel').textContent = size;
      
      // Update styling
      document.querySelectorAll('.size-btn').forEach(btn => {
        btn.className = "size-btn px-4 py-2.5 rounded-xl border-2 text-xs font-bold uppercase transition-all duration-200 focus:outline-none border-gray-200 text-gray-600 hover:border-nike-black hover:text-nike-black bg-white";
      });
      
      element.className = "size-btn px-4 py-2.5 rounded-xl border-2 text-xs font-bold uppercase transition-all duration-200 focus:outline-none bg-nike-black border-nike-black text-white";
    }

    function selectColor(color, element) {
      selectedColor = color;
      document.getElementById('selectedColorLabel').textContent = color;

      // Update styling
      document.querySelectorAll('.color-btn').forEach(btn => {
        btn.classList.add('border-transparent');
        btn.classList.remove('border-nike-black');
      });

      element.classList.remove('border-transparent');
      element.classList.add('border-nike-black');
    }

    function adjustQty(amount) {
      selectedQty += amount;
      if (selectedQty < 1) selectedQty = 1;
      // Cap at stock
      if (selectedQty > productData.stock) {
        selectedQty = productData.stock;
      }
      document.getElementById('productQty').textContent = selectedQty;
    }

    function triggerAddToCart() {
      addToCart(productData, selectedSize, selectedColor, selectedQty);
    }
  </script>

