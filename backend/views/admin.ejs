              <option value="apparel">Quần áo (XS, S, M, L, XL, XXL, 3XL)</option>
              <option value="accessories">Phụ kiện & Khác (Free Size, One Size, N/A)</option>
            </select>
          </div>

          <!-- Sizes list -->
          <div class="space-y-2">
            <label class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Chọn kích cỡ (Sizes) *</label>
            <input type="hidden" id="prodSizes" value="38,39,40,41,42">
