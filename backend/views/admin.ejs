            <div class="flex flex-wrap gap-2.5 py-1" id="colorChipsContainer">
              <!-- Rendered by JS -->
            </div>
          </div>

          <!-- Description -->
          <div class="space-y-1">
            <label for="prodDescription" class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Mô tả
              sản phẩm</label>
            <textarea id="prodDescription" rows="4" placeholder="Mô tả chất liệu, cảm giác đi..."
