      }
    }

    async function deleteVoucher(id) {
      if (!confirm('Bạn có chắc chắn muốn XÓA mã giảm giá này? Hành động này không thể hoàn tác!')) return;

      try {
        const response = await fetch(`/api/admin/vouchers/${id}`, { method: 'DELETE' });
        const result = await response.json();

        if (result.status === 'success') {
          alert('Xóa mã giảm giá thành công!');
          window.location.reload();
        } else {
          alert('Xóa thất bại: ' + result.message);
        }
      } catch (e) {
        alert('Lỗi kết nối máy chủ.');
      }
    }

    // Initial check
    verifyAdminAccess();

    // Auto-clear logic to prevent image collision between URL and File upload
    document.getElementById('prodImageFile').addEventListener('change', function() {
      if (this.files.length > 0) {
        document.getElementById('prodImage').value = '';
      }
    });

    document.getElementById('prodImage').addEventListener('input', function() {
      if (this.value.trim() !== '') {
        document.getElementById('prodImageFile').value = '';
      }
    });
  </script>

