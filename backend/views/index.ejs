<!-- ========================================== -->
<!-- POPULAR / FEATURED PRODUCTS WITH TABS      -->
<!-- ========================================== -->
<div id="popular-products" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 scroll-mt-24">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end mb-10 gap-6 border-b border-gray-100 pb-6">
    <div class="text-center sm:text-left">
      <span class="text-nike-orange font-bold text-xs uppercase tracking-widest">Sản phẩm chất lượng</span>
      <h2 class="text-3xl font-extrabold tracking-tight uppercase mt-1">Sản Phẩm Của Cửa Hàng</h2>
    </div>
    
    <!-- Premium Interactive Tab Buttons (Client-side) -->
    <div class="flex bg-gray-100/80 p-1 rounded-full items-center justify-center max-w-md mx-auto sm:mx-0">
      <button onclick="filterProducts('all', this)" class="product-tab-btn px-5 py-2 rounded-full text-xs uppercase font-extrabold tracking-wider transition-all duration-300 bg-nike-black text-white shadow-sm">
        Tất cả
      </button>
      <button onclick="filterProducts('new', this)" class="product-tab-btn px-5 py-2 rounded-full text-xs uppercase font-extrabold tracking-wider transition-all duration-300 text-gray-500 hover:text-nike-black">
        Hàng Mới
      </button>
      <button onclick="filterProducts('sale', this)" class="product-tab-btn px-5 py-2 rounded-full text-xs uppercase font-extrabold tracking-wider transition-all duration-300 text-gray-500 hover:text-nike-black">
        Khuyến Mãi
      </button>
    </div>
  </div>

  <!-- Product Cards Grid -->
  <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 transition-all duration-500">
    <% if (typeof products !== 'undefined' && products.length > 0) { %>
      <% products.forEach(product => { %>
        <!-- Product card container with data attributes for fast client-side filtering -->
        <div class="product-card-node group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl border border-gray-100 hover:border-nike-orange/10 transition-all duration-500 flex flex-col relative"
             data-new="<%= product.is_new ? 'true' : 'false' %>"
             data-sale="<%= product.discount_percent > 0 ? 'true' : 'false' %>">
          
          <!-- Badges (New / Discount) -->
          <div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
            <% if (product.is_new) { %>
              <span class="bg-red-500 text-white font-extrabold text-[9px] uppercase tracking-widest px-3 py-1 rounded-full shadow-md">NEW</span>
            <% } %>
            <% if (product.discount_percent > 0) { %>
              <span class="bg-nike-orange text-white font-extrabold text-[9px] uppercase tracking-widest px-3 py-1 rounded-full shadow-md">SALE -<%= product.discount_percent %>%</span>
            <% } %>
          </div>

          <!-- Like / Wishlist Toggle -->
          <button onclick="toggleWishlist(JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(product)) %>')))" class="absolute top-4 right-4 z-20 w-9 h-9 rounded-full bg-white/90 hover:bg-red-50 hover:text-red-500 border border-gray-100 flex items-center justify-center text-gray-500 shadow-md transition-all duration-300 focus:outline-none hover:scale-105 active:scale-95">
            <svg class="w-4.5 h-4.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
          </button>

          <!-- Image Panel (Gradients and hover effects) -->
          <div class="h-64 bg-gradient-to-b from-gray-50/50 to-white flex items-center justify-center overflow-hidden p-6 relative">
            <a href="/products/<%= product.id %>" class="w-full h-full flex items-center justify-center">
              <img src="<%= product.image %>" alt="<%= product.title %>" class="max-w-[85%] max-h-full object-contain transform group-hover:scale-110 group-hover:rotate-[-5deg] transition-all duration-500 ease-out z-10" onerror="this.src='/nike.png'">
            </a>
            
            <!-- Quick Action Hover Bar -->
            <div class="absolute bottom-4 left-4 right-4 flex justify-center gap-3 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-3 group-hover:translate-y-0 transform">
              <!-- Quick View Button -->
              <button onclick="openQuickView(JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(product)) %>')))" 
                      class="px-4 py-2 bg-nike-black text-white hover:bg-nike-orange rounded-full text-xs font-bold shadow-lg uppercase tracking-wider flex items-center gap-1.5 transition-colors focus:outline-none">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                Xem nhanh
              </button>
            </div>
            
            <div class="absolute bottom-3 left-4 right-4 flex justify-between text-[10px] text-gray-400 font-medium z-10 group-hover:opacity-0 transition-opacity">
              <span><%= product.color %></span>
              <span><%= (product.sizes && product.sizes !== 'N/A' && product.sizes !== '') ? 'Size: ' + product.sizes : (translateItemType(product.item_type) || '') %></span>
            </div>
          </div>

          <!-- Content Card Info -->
          <div class="p-6 flex-1 flex flex-col justify-between space-y-4 border-t border-gray-50/50">
            <div>
              <span class="text-[9px] uppercase font-black text-nike-orange bg-orange-50 px-2 py-0.5 rounded-full inline-block"><%= product.category === 'men' ? 'Nam' : product.category === 'women' ? 'Nữ' : 'Trẻ Em' %> &bull; <%= translateItemType(product.item_type) %></span>
              <a href="/products/<%= product.id %>" class="block font-bold text-gray-800 text-sm hover:text-nike-orange transition-colors truncate mt-2"><%= product.title %></a>
              
              <!-- Ratings -->
              <div class="flex items-center gap-1 mt-1.5">
                <div class="flex text-yellow-400">
                  <% for(let i=0; i<5; i++) { %>
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                  <% } %>
                </div>
                <span class="text-[10px] text-gray-400 font-bold ml-1">(<%= product.rating || '4.5' %>)</span>
              </div>
            </div>

            <!-- Price & Checkout options -->
            <div class="flex justify-between items-center pt-3 border-t border-gray-50">
              <div class="flex flex-col">
                <% if (product.discount_percent > 0) { %>
                  <% 
                    let numPrice = parseFloat(product.price);
                    let discountedPrice = numPrice * (1 - product.discount_percent / 100);
                  %>
                  <span class="text-[10px] text-gray-400 line-through"><%= formatPrice(product.price) %></span>
                  <span class="font-black text-sm text-nike-orange"><%= formatPrice(discountedPrice) %></span>
                <% } else { %>
                  <span class="font-black text-sm text-nike-black"><%= formatPrice(product.price) %></span>
                <% } %>
              </div>
              
              <!-- Quick Add to Cart Button -->
              <button onclick="addToCart(JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(product)) %>')), '39', 'Trắng', 1); showToast('Đã thêm sản phẩm vào giỏ hàng!')" 
                      class="bg-nike-black hover:bg-nike-orange text-white p-3 rounded-full transition-all duration-300 hover:rotate-90 shadow-md focus:outline-none glow-dark hover:glow-orange hover:scale-105 active:scale-95">
                <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-span-full py-16 text-center text-gray-500">
        <p class="font-bold text-lg">Không có sản phẩm nào có sẵn!</p>
        <p class="text-sm mt-1">Vui lòng kiểm tra lại kết nối Cơ sở dữ liệu.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ========================================== -->
<!-- INNOVATION SNEAKER TECH (HOTSPOTS SECTION) -->
<!-- ========================================== -->
<!-- Requirement: Image of a sneaker showcasing tech details at /assets/zoomx-vaporfly.png (transparent PNG) -->
<div id="nike-innovation" class="bg-gradient-to-r from-neutral-900 to-zinc-950 text-white py-20 my-16 overflow-hidden relative">
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-0">
    <h1 class="text-[18vw] font-black text-white/[0.01] uppercase tracking-tighter">LIMITLESS</h1>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <span class="text-nike-orange font-bold text-xs uppercase tracking-widest">Tính năng đột phá</span>
      <h2 class="text-3xl sm:text-5xl font-black uppercase tracking-tight mt-2">NIKE ZOOM-X VAPORFLY</h2>
      <p class="text-xs sm:text-sm text-gray-400 mt-2 max-w-lg mx-auto leading-relaxed">Nhấp chuột vào các điểm nóng (Hotspots) trên giày để khám phá cấu tạo chi tiết.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Interactive Hotspot Image Wrapper (Col: 7) -->
      <div class="lg:col-span-7 flex justify-center items-center relative py-12">
        <div class="absolute w-80 h-80 bg-sky-500/10 rounded-full blur-3xl opacity-40 z-0"></div>
        
        <!-- Interactive Layout -->
        <div class="relative w-full max-w-lg">
          <!-- Main Shoe -->
          <img src="/assets/zoomx-vaporfly.png" alt="Nike Technology Shoe" 
               class="w-full h-auto transform rotate-[-8deg] z-10 pointer-events-none filter drop-shadow-[0_20px_30px_rgba(255,84,0,0.15)]" 
               onerror="this.src='/assets/products/misc/sneaker.png'">

          <!-- Hotspot 1 (Carbon Plate) -->
          <div class="absolute top-[48%] left-[45%] z-20 group">
            <span class="flex h-6 w-6 items-center justify-center relative cursor-pointer">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-sky-400"></span>
            </span>
