      function editVoucher(element) {
        let voucher = JSON.parse(decodeURIComponent(element.getAttribute('data-voucher')));
        document.getElementById('voucherDrawerTitle').textContent = "Cập nhật Mã: " + voucher.code;
        document.getElementById('voucherFormId').value = voucher.id;

        document.getElementById('voucherCode').value = voucher.code;
        document.getElementById('voucherDescription').value = voucher.description || '';
        document.getElementById('voucherCategory').value = voucher.category;
        document.getElementById('voucherDiscountType').value = voucher.discount_type;
        document.getElementById('voucherDiscountValue').value = voucher.discount_value;
        document.getElementById('voucherMaxDiscount').value = voucher.max_discount || '';
        document.getElementById('voucherMinOrder').value = voucher.min_order_value;
        document.getElementById('voucherUsageLimit').value = voucher.usage_limit;
        document.getElementById('voucherLimitPerUser').value = voucher.limit_per_user || 1;
        document.getElementById('voucherApplyScope').value = voucher.apply_scope || 'all';

        // Handle checkboxes
        const checkboxes = document.querySelectorAll('#voucherCategoryCheckboxes input[type="checkbox"]');
        checkboxes.forEach(cb => cb.checked = false);
        if (voucher.apply_scope === 'category' && voucher.scope_value) {
          const scopes = voucher.scope_value.split(',');
          checkboxes.forEach(cb => {
            if (scopes.includes(cb.value)) cb.checked = true;
          });
        }

        toggleScopeValueField();
        toggleMaxDiscountField();

        // Format Date for input type=date (YYYY-MM-DD)
        if (voucher.expires_at) {
          let d = new Date(voucher.expires_at);
          let month = '' + (d.getMonth() + 1), day = '' + d.getDate(), year = d.getFullYear();
          if (month.length < 2) month = '0' + month;
          if (day.length < 2) day = '0' + day;
          document.getElementById('voucherExpiresAt').value = [year, month, day].join('-');
        }

        if (voucher.start_date) {
          let d = new Date(voucher.start_date);
          let month = '' + (d.getMonth() + 1), day = '' + d.getDate(), year = d.getFullYear();
          if (month.length < 2) month = '0' + month;
          if (day.length < 2) day = '0' + day;
          document.getElementById('voucherStartDate').value = [year, month, day].join('-');
        } else {
          document.getElementById('voucherStartDate').value = '';
        }

        const overlay = document.getElementById('voucherDrawerOverlay');
        const drawer = document.getElementById('voucherDrawer');

        overlay.classList.remove('hidden');
        setTimeout(() => {
          overlay.classList.add('opacity-100');
          drawer.classList.remove('translate-x-full');
        }, 50);
      }

      async function handleVoucherSubmit(event) {
