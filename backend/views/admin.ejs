            <input type="text" id="prodTitle" required placeholder="Nike Air Force 1 Platinum"
              class="w-full bg-gray-50 border-0 rounded-2xl py-3 px-4 text-xs font-semibold text-gray-800 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 transition-all">
