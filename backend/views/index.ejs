<%- include('partials/header', { title: 'Nike Store - Premium Footwear & Sportswear' }) %>

<% 
  // Helper to format price in EJS
  function formatPrice(number) {
    let cleanVal = parseFloat(String(number).replace(/[^0-9.-]+/g,""));
    if (isNaN(cleanVal)) return number;
    if (cleanVal < 100000) {
      cleanVal = cleanVal * 1000;
    }
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cleanVal);
  }
%>

<!-- ========================================== -->
<!-- HERO SECTION (MODERN SPLIT & INTERACTIVE)  -->
<!-- ========================================== -->
<div class="relative min-h-[90vh] bg-gradient-to-br from-zinc-950 via-neutral-900 to-slate-950 text-white flex items-center overflow-hidden py-16 px-4 sm:px-6 lg:px-8">
  <!-- Immersive background video/animation -->
  <div class="absolute inset-0 pointer-events-none select-none z-0">
    <!-- Video background placeholder. Users can put a video file at /assets/video/nike-hero-bg.mp4 -->
    <!-- Requirement: Video .mp4, length 10-15s, loop, mute, compressed size < 5MB -->
    <video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-15 mix-blend-screen" onerror="this.style.display='none'">
      <source src="/assets/video/nike-hero-bg.mp4" type="video/mp4">
    </video>
  </div>

  <!-- Background Large Graphic Text -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-0">
    <h1 class="text-[14vw] font-black text-white/[0.02] uppercase tracking-tighter select-none font-sans">JUST DO IT</h1>
  </div>
  
  <!-- Glowing neon ambient lights -->
  <div id="hero-glow-1" class="absolute top-1/4 left-1/4 w-[350px] h-[350px] bg-nike-orange/15 rounded-full blur-[120px] pointer-events-none transition-all duration-1000"></div>
  <div id="hero-glow-2" class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-sky-500/10 rounded-full blur-[120px] pointer-events-none transition-all duration-1000"></div>

  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
    <!-- Text Content (Col: 7) -->
    <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
      <span class="bg-gradient-to-r from-nike-orange to-red-500 text-white text-[10px] font-extrabold uppercase px-4 py-1.5 rounded-full tracking-widest shadow-lg shadow-nike-orange/20 inline-block animate-pulse">
        Bộ Sưu Tập Premium 2026
      </span>
      
      <h1 class="text-4xl sm:text-6xl lg:text-8xl font-black tracking-tighter uppercase leading-[0.9] select-none">
        BỨT PHÁ <br>
        <span id="hero-title-accent" class="text-transparent bg-clip-text bg-gradient-to-r from-nike-orange via-orange-400 to-sky-400 transition-all duration-500">MỌI GIỚI HẠN</span>
      </h1>
      
      <p class="text-sm sm:text-base text-gray-400 max-w-lg mx-auto lg:mx-0 font-light leading-relaxed">
        Trải nghiệm sự khác biệt vượt trội cùng các dòng sản phẩm tối tân nhất từ Nike Store. Sự pha trộn hoàn hảo giữa công nghệ hiệu suất cao và ngôn ngữ thiết kế tương lai.
      </p>

      <!-- Interactive Colorway Swatches -->
      <div class="flex flex-col items-center lg:items-start gap-3 py-2">
        <span class="text-xs uppercase font-extrabold tracking-wider text-gray-500">Chọn phối màu phối cảnh:</span>
        <div class="flex gap-4">
          <!-- Orange Swatch -->
          <button onclick="changeHeroColorway('orange', '/assets/hero-orange.png', 'from-nike-orange/20 to-red-600/35', 'bg-nike-orange', 'text-nike-orange', 'from-nike-orange via-orange-400 to-red-500')" 
                  class="colorway-btn w-9 h-9 rounded-full bg-nike-orange border-2 border-white ring-2 ring-nike-orange/50 transition-all duration-300 scale-110 relative"
                  title="Cam Mặt Trời (Mặc Định)"></button>
          <!-- Black Swatch -->
          <!-- Requirement: Image of a black Nike sneaker at /assets/hero-black.png (transparent PNG) -->
          <button onclick="changeHeroColorway('black', '/assets/hero-black.png', 'from-zinc-800/30 to-zinc-950/45', 'bg-neutral-800', 'text-white', 'from-neutral-300 via-neutral-500 to-zinc-700')" 
                  class="colorway-btn w-9 h-9 rounded-full bg-neutral-900 border-2 border-transparent hover:border-white transition-all duration-300 relative"
                  title="Đen Huyền Bí"></button>
          <!-- Volt Swatch -->
          <!-- Requirement: Image of a neon/lime green Nike sneaker at /assets/hero-volt.png (transparent PNG) -->
          <button onclick="changeHeroColorway('volt', '/assets/hero-volt.png', 'from-lime-400/20 to-emerald-600/35', 'bg-lime-400', 'text-lime-400', 'from-lime-400 via-emerald-400 to-green-500')" 
                  class="colorway-btn w-9 h-9 rounded-full bg-lime-400 border-2 border-transparent hover:border-white transition-all duration-300 relative"
                  title="Xanh Volt Điện Tử"></button>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-center pt-2">
        <a href="#popular-products" class="w-full sm:w-auto bg-white hover:bg-nike-orange hover:text-white text-nike-black font-extrabold px-8 py-4 rounded-full uppercase tracking-wider text-xs shadow-lg transition-all duration-300 transform hover:scale-105 hover:-translate-y-0.5 glow-dark hover:glow-orange text-center">
          Khám Phá Sản Phẩm
        </a>
        <a href="/new" class="w-full sm:w-auto border-2 border-white/20 hover:border-white hover:bg-white/10 text-white font-extrabold px-8 py-4 rounded-full uppercase tracking-wider text-xs transition-all duration-300 text-center flex items-center justify-center gap-2">
          Bộ Sưu Tập Mới
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-3 gap-6 pt-8 border-t border-white/10 mt-8 max-w-md mx-auto lg:mx-0">
        <div>
          <h4 class="text-2xl sm:text-3xl font-black text-white">25K+</h4>
          <p class="text-[9px] text-gray-500 uppercase font-bold tracking-wider">Khách hàng hài lòng</p>
        </div>
        <div>
          <h4 class="text-2xl sm:text-3xl font-black text-white">99.8%</h4>
          <p class="text-[9px] text-gray-500 uppercase font-bold tracking-wider">Đánh giá 5 sao</p>
        </div>
        <div>
          <h4 class="text-2xl sm:text-3xl font-black text-white">Free</h4>
          <p class="text-[9px] text-gray-500 uppercase font-bold tracking-wider">Giao hàng & Đổi trả</p>
        </div>
      </div>
    </div>

    <!-- Image Column (Col: 5) -->
    <div class="lg:col-span-5 flex justify-center items-center relative py-12 lg:py-0">
      <!-- Background circular orbit glow -->
      <div class="absolute w-[280px] sm:w-[420px] h-[280px] sm:h-[420px] border border-white/5 rounded-full flex items-center justify-center z-0">
        <div class="w-[200px] sm:w-[320px] h-[200px] sm:h-[320px] border border-white/10 border-dashed rounded-full"></div>
      </div>
      
      <!-- Big Circle background with dynamic gradients -->
      <div id="hero-glow-ring" class="absolute w-56 sm:w-80 h-56 sm:h-80 bg-gradient-to-tr from-nike-orange/25 to-red-600/35 rounded-full blur-3xl opacity-60 z-0 transition-all duration-1000"></div>

      <!-- Hero Shoe -->
      <!-- Fallback is set to product1 if hero.png fails, but hero.png is present in workspace! -->
      <img id="hero-shoe-image" src="/assets/hero.png" alt="Nike Hero Sneaker" 
           class="w-[85%] sm:w-[100%] h-auto floating-shoe relative z-10 pointer-events-none transition-all duration-500 ease-out transform"
           onerror="this.src='/assets/products/misc/product1.png'">
    </div>
  </div>
</div>

