      function fmtM(v) {
        var n = parseFloat(v) || 0;
        if (n >= 1e9) return (n / 1e9).toFixed(1) + ' tỷ';
        if (n >= 1e6) return (n / 1e6).toFixed(1) + ' tr';
        if (n >= 1e3) return Math.round(n / 1e3) + 'K';
        return n.toLocaleString('vi-VN');
      }

