      async function handleProductSubmit(event) {
        event.preventDefault();

        const id = document.getElementById('prodFormId').value;
        const title = document.getElementById('prodTitle').value.trim();
        const price = document.getElementById('prodPrice').value.trim();
        const image = document.getElementById('prodImage').value.trim();
        const category = document.getElementById('prodCategory').value;
        const item_type = document.getElementById('prodItemType').value.trim() || 'shoes';
        const stock = parseInt(document.getElementById('prodStock').value) || 100;
        const discount_percent = parseInt(document.getElementById('prodDiscount').value) || 0;
        const is_new = document.getElementById('prodIsNew').checked ? 1 : 0;
        const sizes = document.getElementById('prodSizes').value.trim() || '38,39,40,41,42';
        const color = document.getElementById('prodColor').value.trim() || 'Trắng';
        const description = document.getElementById('prodDescription').value.trim();

        const fileInput = document.getElementById('prodImageFile');

        // Validation: Prevent both URL and upload file from being submitted simultaneously
        if (image && fileInput.files.length > 0) {
          alert('Bạn chỉ được chọn MỘT phương thức: Tải ảnh từ máy tính HOẶC Dán Link URL ảnh. Vui lòng để trống phương thức còn lại để tránh chèn ép nhau!');
          return;
        }

        // Validation: Must either upload a file or write a URL when creating new products
        if (!id && !image && fileInput.files.length === 0) {
          alert('Vui lòng nhập Link ảnh URL hoặc chọn tệp ảnh từ máy tính của bạn!');
          return;
        }

        // Create FormData to support binary file upload via Multer
        const formData = new FormData();
        formData.append('title', title);
        formData.append('price', price);
        formData.append('image', image);
        formData.append('category', category);
        formData.append('item_type', item_type);
        formData.append('stock', stock);
        formData.append('discount_percent', discount_percent);
        formData.append('is_new', is_new);
        formData.append('sizes', sizes);
        formData.append('color', color);
        formData.append('description', description);

        if (fileInput.files.length > 0) {
          formData.append('imageFile', fileInput.files[0]);
        }

        const url = id ? `/api/products/${id}` : '/api/products';
        const method = id ? 'PUT' : 'POST';

        try {
          const response = await fetch(url, {
            method: method,
            body: formData // Browser will automatically set boundary and multipart header
          });

          const result = await response.json();
          if (result.status === 'success') {
            alert('Đã lưu sản phẩm thành công!');
            window.location.reload();
          } else {
            alert('Lỗi lưu sản phẩm: ' + result.message);
          }
        } catch (e) {
          alert('Lỗi kết nối máy chủ.');
        }
      }

