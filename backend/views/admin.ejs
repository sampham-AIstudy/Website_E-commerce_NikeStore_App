<%- include('partials/header', { title: 'Nike Store - Trang Quản Trị Hệ Thống' }) %>

  <% 
    // Helper to format price in EJS
    function formatPrice(number) { 
      let cleanVal = parseFloat(String(number).replace(/[^0-9.-]+/g,"")); 
      if (isNaN(cleanVal)) return number; 
      return new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND' }).format(cleanVal); 
    } 
  %>

    <!-- Admin Verification (Pre-renders blank if unauthorized, JS handles redirection) -->
    <div id="adminPanelLoading" class="min-h-[60vh] flex flex-col items-center justify-center space-y-4">
      <div class="w-12 h-12 border-4 border-nike-black border-t-nike-orange rounded-full animate-spin"></div>
      <p class="text-xs text-gray-500 font-bold uppercase tracking-wider">Đang kiểm tra quyền truy cập Quản trị viên...
      </p>
    </div>

    <div id="adminPanelContent" class="hidden">
      <!-- ========================================== -->
      <!-- PANEL HEADER                               -->
      <!-- ========================================== -->
      <div class="bg-gradient-to-r from-zinc-900 to-sky-950 text-white py-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(255,84,0,0.1),transparent)]"></div>
        <div
          class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col sm:flex-row justify-between items-center gap-6">
          <div class="space-y-2 text-center sm:text-left">
            <span class="text-nike-orange font-extrabold text-xs uppercase tracking-widest block">Quản trị viên</span>
            <h1 class="text-3xl font-black uppercase tracking-tight">Hệ Thống Quản Trị Nike Store</h1>
            <p class="text-xs text-gray-400 font-light max-w-md">
              Quản lý và vận hành toàn bộ cửa hàng: sản phẩm, tài khoản khách hàng, theo dõi và xử lý chi tiết các đơn
              hàng của khách.
            </p>
          </div>
          <div class="flex items-center gap-3">
            <button onclick="logout()"
              class="bg-red-500 hover:bg-red-600 text-white font-bold text-xs px-4 py-3 rounded-full uppercase tracking-wider transition-colors shadow-lg shadow-red-500/20">Đăng
              xuất</button>
            <a href="/"
              class="bg-white hover:bg-gray-100 text-nike-black font-bold text-xs px-4 py-3 rounded-full uppercase tracking-wider transition-colors shadow-md">Xem
              cửa hàng</a>
          </div>
        </div>
      </div>

      <!-- ========================================== -->
      <!-- TABS NAVIGATION                            -->
      <!-- ========================================== -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

        <!-- Tab selectors -->
        <div class="flex border-b border-gray-200 gap-8 mb-8 overflow-x-auto pb-1">
          <button onclick="switchAdminTab('orders')" id="tabBtn-orders"
            class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-nike-orange text-nike-orange">
            Đơn Hàng (<%= orders.length %>)
          </button>
          <button onclick="switchAdminTab('products')" id="tabBtn-products"
            class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black">
            Sản Phẩm (<%= products.length %>)
          </button>
          <button onclick="switchAdminTab('users')" id="tabBtn-users"
            class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black">
            Khách Hàng (<%= users.length %>)
          </button>
          <button onclick="switchAdminTab('vouchers')" id="tabBtn-vouchers"
            class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black">
            Mã Giảm Giá (<%= typeof vouchers !=='undefined' ? vouchers.length : 0 %>)
          </button>
          <button onclick="switchAdminTab('analytics')" id="tabBtn-analytics"
            class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black">
            Thống Kê
          </button>
          <button onclick="switchAdminTab('livechat')" id="tabBtn-livechat"
            class="admin-tab-btn font-extrabold text-xs uppercase pb-4 tracking-wider transition-all border-b-2 border-transparent text-gray-400 hover:text-nike-black relative">
            Live Chat
            <span id="adminLiveChatBadge"
              class="hidden absolute -top-1 -right-2 min-w-[18px] h-[18px] bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center px-1">0</span>
          </button>
        </div>


        <!-- ========================================== -->
        <!-- TAB CONTENT: ORDERS                        -->
        <!-- ========================================== -->
        <div id="tabContent-orders" class="admin-tab-content space-y-6">

          <!-- Control Bar -->
          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-5 space-y-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
              <h3 class="font-bold text-base text-nike-black uppercase tracking-wide">Quản lý Đơn hàng</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <!-- Search -->
              <div class="col-span-1 md:col-span-2 relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                </div>
                <input type="text" id="orderSearchInput" oninput="renderAdminOrders()"
                  placeholder="Tìm theo Mã đơn, Tên, Số điện thoại..."
                  class="w-full bg-gray-50 border-0 rounded-2xl py-3 pl-10 pr-4 text-xs font-semibold text-gray-800 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 transition-all placeholder-gray-400">
              </div>

              <!-- Date Filter -->
              <div class="space-y-2">
                <select id="orderDateFilter" onchange="toggleCustomDate(); renderAdminOrders()"
                  class="w-full bg-gray-50 border-0 rounded-2xl py-3 px-4 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 transition-all cursor-pointer">
                  <option value="all">Tất cả thời gian</option>
                  <option value="today">Hôm nay</option>
                  <option value="7days">7 ngày gần đây</option>
                  <option value="30days">30 ngày gần đây</option>
                  <option value="custom">Tùy chọn khoảng ngày...</option>
                </select>
                <div id="customDateRange" class="hidden flex items-center gap-2 mt-2">
                  <input type="date" id="orderDateFrom" onchange="renderAdminOrders()"
                    class="w-1/2 bg-gray-50 border-0 rounded-xl py-2 px-2 text-[10px] font-bold text-gray-600 focus:outline-none focus:ring-1 focus:ring-nike-orange">
                  <span class="text-gray-400 text-xs">-</span>
                  <input type="date" id="orderDateTo" onchange="renderAdminOrders()"
                    class="w-1/2 bg-gray-50 border-0 rounded-xl py-2 px-2 text-[10px] font-bold text-gray-600 focus:outline-none focus:ring-1 focus:ring-nike-orange">
                </div>
              </div>

              <!-- Sort -->
              <div>
                <select id="orderSortFilter" onchange="renderAdminOrders()"
                  class="w-full bg-gray-50 border-0 rounded-2xl py-3 px-4 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 transition-all cursor-pointer">
                  <option value="newest">Sắp xếp: Mới nhất</option>
                  <option value="oldest">Sắp xếp: Cũ nhất</option>
                  <option value="price_desc">Giá trị: Cao -> Thấp</option>
                  <option value="price_asc">Giá trị: Thấp -> Cao</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Orders Table Area -->
          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">

            <!-- TABS -->
            <div class="flex overflow-x-auto border-b border-gray-100 hide-scrollbar bg-gray-50/50">
              <button onclick="switchOrderStatusTab('all')" id="btnTab-all"
                class="order-status-tab relative px-6 py-4 text-[11px] font-extrabold uppercase tracking-wider text-nike-orange border-b-2 border-nike-orange whitespace-nowrap transition-colors">
                Tất cả <span id="count-all"
                  class="ml-1 bg-gray-200 text-gray-600 px-1.5 py-0.5 rounded-full text-[9px]">0</span>
              </button>
              <button onclick="switchOrderStatusTab('pending')" id="btnTab-pending"
                class="order-status-tab relative px-6 py-4 text-[11px] font-extrabold uppercase tracking-wider text-gray-400 hover:text-nike-black border-b-2 border-transparent whitespace-nowrap transition-colors">
                Chờ duyệt <span id="count-pending"
                  class="ml-1 bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full text-[9px]">0</span>
                <span id="dot-pending"
                  class="hidden absolute top-3 right-3 w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
              </button>
              <button onclick="switchOrderStatusTab('processing')" id="btnTab-processing"
                class="order-status-tab relative px-6 py-4 text-[11px] font-extrabold uppercase tracking-wider text-gray-400 hover:text-nike-black border-b-2 border-transparent whitespace-nowrap transition-colors">
                Chờ lấy hàng <span id="count-processing"
                  class="ml-1 bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full text-[9px]">0</span>
              </button>
              <button onclick="switchOrderStatusTab('shipped')" id="btnTab-shipped"
                class="order-status-tab relative px-6 py-4 text-[11px] font-extrabold uppercase tracking-wider text-gray-400 hover:text-nike-black border-b-2 border-transparent whitespace-nowrap transition-colors">
                Đang giao <span id="count-shipped"
                  class="ml-1 bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full text-[9px]">0</span>
              </button>
              <button onclick="switchOrderStatusTab('delivered')" id="btnTab-delivered"
                class="order-status-tab relative px-6 py-4 text-[11px] font-extrabold uppercase tracking-wider text-gray-400 hover:text-nike-black border-b-2 border-transparent whitespace-nowrap transition-colors">
                Hoàn thành <span id="count-delivered"
                  class="ml-1 bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full text-[9px]">0</span>
              </button>
              <button onclick="switchOrderStatusTab('returned')" id="btnTab-returned"
                class="order-status-tab relative px-6 py-4 text-[11px] font-extrabold uppercase tracking-wider text-gray-400 hover:text-nike-black border-b-2 border-transparent whitespace-nowrap transition-colors">
                Trả hàng <span id="count-returned"
                  class="ml-1 bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full text-[9px]">0</span>
              </button>
              <button onclick="switchOrderStatusTab('cancelled')" id="btnTab-cancelled"
                class="order-status-tab relative px-6 py-4 text-[11px] font-extrabold uppercase tracking-wider text-gray-400 hover:text-nike-black border-b-2 border-transparent whitespace-nowrap transition-colors">
                Đã hủy <span id="count-cancelled"
                  class="ml-1 bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-full text-[9px]">0</span>
              </button>
            </div>

            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs border-collapse">
                <thead>
                  <tr
                    class="bg-gray-50 text-gray-400 font-bold uppercase tracking-wider border-b border-gray-100 text-[10px]">
                    <th class="p-4">Mã Đơn</th>
                    <th class="p-4">Khách Hàng</th>
                    <th class="p-4">Trạng Thái</th>
                    <th class="p-4">Thanh Toán</th>
                    <th class="p-4">Tổng Tiền</th>
                    <th class="p-4">Ngày Đặt</th>
                    <th class="p-4 text-center">Thao Tác</th>
                  </tr>
                </thead>
                <tbody id="adminOrdersTableBody" class="divide-y divide-gray-50">
                  <!-- JS RENDER HERE -->
                </tbody>
              </table>
            </div>

            <!-- Empty State -->
            <div id="adminOrdersEmptyState" class="hidden p-12 flex flex-col items-center justify-center text-center">
              <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2">
                  </path>
                </svg>
              </div>
              <p class="text-gray-400 font-bold uppercase tracking-wider text-xs">Không tìm thấy đơn hàng nào!</p>
            </div>
          </div>
        </div>

        <!-- ========================================== -->
        <!-- TAB CONTENT: PRODUCTS                      -->
        <!-- ========================================== -->
        <div id="tabContent-products" class="admin-tab-content space-y-6 hidden">

          <!-- Toolbar: Search + Filter + Add Button -->
          <div class="flex flex-col sm:flex-row justify-between items-center gap-3 relative">
            <!-- Left: Search and Filter Toggle -->
            <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
              <div class="relative w-full sm:w-72">
                <input type="text" id="adminProductSearch" placeholder="Tìm theo tên, loại, danh mục..."
                  oninput="adminFilterProducts()"
                  class="bg-white border border-gray-200 rounded-full py-2.5 pl-4 pr-10 text-xs font-medium focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full text-gray-700 shadow-sm">
                <svg class="w-4 h-4 text-gray-400 absolute right-3.5 top-2.5" fill="none" stroke="currentColor"
                  viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>

              <button onclick="document.getElementById('adminFilterPanel').classList.toggle('hidden')"
                class="bg-white border border-gray-200 hover:border-nike-orange text-gray-700 hover:text-nike-orange font-bold text-xs px-4 py-2.5 rounded-full flex items-center justify-center gap-2 transition-all shadow-sm focus:outline-none w-full sm:w-auto">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z">
                  </path>
                </svg>
                Lọc
              </button>
            </div>

            <!-- Admin Filter Panel -->
            <div id="adminFilterPanel"
              class="hidden absolute top-[110%] left-0 mt-2 w-full sm:w-[350px] bg-white rounded-3xl border border-gray-100 shadow-2xl p-5 z-[100]">
              <div class="flex justify-between items-center mb-4 border-b border-gray-50 pb-2">
                <h3 class="font-extrabold text-sm uppercase tracking-wider text-nike-black">Lọc Sản Phẩm</h3>
                <button onclick="document.getElementById('adminFilterPanel').classList.add('hidden')"
                  class="text-gray-400 hover:text-nike-orange focus:outline-none">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                    </path>
                  </svg>
                </button>
              </div>

              <div class="space-y-4">
                <div class="space-y-2">
                  <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Danh mục (Giới
                    tính)</span>
                  <select id="adminCategoryFilter"
                    class="bg-gray-50 border-0 rounded-xl py-2.5 px-3 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
                    <option value="">Tất cả danh mục</option>
                    <option value="men">Nam</option>
                    <option value="women">Nữ</option>
                    <option value="kids">Trẻ em</option>
                  </select>
                </div>

                <div class="space-y-2">
                  <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Tình trạng Kho</span>
                  <select id="adminStockFilter"
                    class="bg-gray-50 border-0 rounded-xl py-2.5 px-3 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
                    <option value="">Tất cả tình trạng</option>
                    <option value="instock">Còn hàng (Stock > 0)</option>
                    <option value="outstock">Hết hàng (Stock = 0)</option>
                  </select>
                </div>

                <div class="space-y-2">
                  <span class="text-xs text-gray-500 font-bold uppercase tracking-wider block">Loại sản phẩm</span>
                  <select id="adminTypeFilter"
                    class="bg-gray-50 border-0 rounded-xl py-2.5 px-3 text-xs font-semibold text-gray-700 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 w-full">
                    <option value="">Tất cả loại</option>
                    <option value="shoes">Giày</option>
                    <option value="clothing">Quần áo</option>
                    <option value="accessories">Phụ kiện</option>
                  </select>
                </div>
              </div>

              <div class="mt-4 pt-4 border-t border-gray-50 flex justify-end">
                <button
                  onclick="adminFilterProducts(); document.getElementById('adminFilterPanel').classList.add('hidden')"
                  class="bg-nike-black hover:bg-gray-800 text-white font-bold text-xs px-5 py-2.5 rounded-full uppercase tracking-wider transition-all shadow-md w-full">
                  Áp dụng
                </button>
              </div>
            </div>

            <!-- Right side: count + add button -->
            <div class="flex items-center justify-end gap-3 w-full sm:w-auto">
              <span id="adminProductCount" class="text-xs text-gray-400 font-bold whitespace-nowrap"></span>
              <button onclick="openProductDrawer()"
                class="bg-nike-black hover:bg-nike-orange text-white font-bold text-xs px-5 py-3 rounded-full uppercase tracking-wider transition-colors shadow-md flex items-center gap-1.5 glow-dark hover:glow-orange whitespace-nowrap">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Thêm mới
              </button>
            </div>
          </div>

          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs border-collapse">
                <thead>
                  <tr class="bg-gray-100/50 text-gray-500 font-bold uppercase tracking-wider border-b border-gray-100">
                    <th class="p-4">Mã</th>
                    <th class="p-4">Hình</th>
                    <th class="p-4">Tên sản phẩm</th>
                    <th class="p-4">Phân loại</th>
                    <th class="p-4">Giá gốc</th>
                    <th class="p-4">Màu sắc</th>
                    <th class="p-4">Kho</th>
                    <th class="p-4 text-center">Thao tác</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <% if(products.length> 0) { %>
                    <% products.forEach(prod=> { %>
                      <tr class="hover:bg-gray-50/30 transition-colors" data-product-row="1"
                        data-category="<%= prod.category %>" data-type="<%= prod.item_type || '' %>"
                        data-stock="<%= prod.stock %>"
                        data-search-text="<%= (prod.title + ' ' + prod.category + ' ' + (prod.item_type||'') + ' ' + (prod.color||'')).toLowerCase() %>">
                        <td class="p-4 font-bold text-gray-400">#<%= prod.id %>
                        </td>
                        <td class="p-4">
                          <div
                            class="w-10 h-10 bg-gray-50 border border-gray-100 rounded-lg flex items-center justify-center p-1 overflow-hidden">
                            <img src="<%= prod.image %>" alt="<%= prod.title %>" class="w-full h-auto object-contain"
                              onerror="this.src='/nike.png'">
                          </div>
                        </td>
                        <td class="p-4 font-bold text-gray-800 max-w-[200px] truncate">
                          <%= prod.title %>
                        </td>
                        <td class="p-4">
                          <span
                            class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-700">
                            <%= prod.category==='men' ? 'Nam' : prod.category==='women' ? 'Nữ' : 'Trẻ em' %>
                          </span>
                        </td>
                        <td class="p-4 font-bold text-nike-orange">
                          <%= formatPrice(prod.price) %>
                        </td>
                        <td class="p-4 font-semibold text-gray-600">
                          <%= prod.color || 'Trắng' %>
                        </td>
                        <td class="p-4 font-bold text-gray-600">
                          <%= prod.stock %> chiếc
                        </td>
                        <td class="p-4 text-center">
                          <div class="flex gap-2 justify-center">
                            <button onclick="editProduct(this)"
                              data-product="<%= encodeURIComponent(JSON.stringify(prod)) %>"
                              class="border-2 border-gray-200 hover:border-nike-orange text-gray-500 hover:text-nike-orange text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Sửa</button>
                            <button onclick="deleteProduct(this)" data-id="<%= prod.id %>"
                              class="border-2 border-gray-200 hover:border-red-500 text-gray-500 hover:text-red-500 text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Xóa</button>
                          </div>
                        </td>
                      </tr>
                      <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="8" class="p-8 text-center text-gray-400 font-bold">Chưa có sản phẩm nào!</td>
                          </tr>
                          <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Admin Products Pagination Bar -->
          <div id="adminProductPagination" class="flex items-center justify-center gap-2 mt-4 flex-wrap"></div>
        </div>

        <!-- ========================================== -->
        <!-- TAB CONTENT: USERS                         -->
        <!-- ========================================== -->
        <div id="tabContent-users" class="admin-tab-content space-y-6 hidden">
          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100">
              <h3 class="font-bold text-base text-nike-black uppercase tracking-wide">Tài khoản thành viên</h3>
            </div>

            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs border-collapse">
                <thead>
                  <tr class="bg-gray-100/50 text-gray-500 font-bold uppercase tracking-wider border-b border-gray-100">
                    <th class="p-4">ID</th>
                    <th class="p-4">Tên đăng nhập</th>
                    <th class="p-4">Vai trò</th>
                    <th class="p-4">Ngày tạo</th>
                    <th class="p-4 text-center">Xóa tài khoản</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <% if(users.length> 0) { %>
                    <% users.forEach(user=> { %>
                      <tr class="hover:bg-gray-50/30 transition-colors">
                        <td class="p-4 font-bold text-gray-400">#<%= user.id %>
                        </td>
                        <td class="p-4 font-semibold text-gray-800">
                          <%= user.username %>
                        </td>
                        <td class="p-4">
                          <span
                            class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                          <%= user.role === 'admin' ? 'bg-purple-100 text-purple-800' : 'bg-gray-100 text-gray-700' %>">
                            <%= user.role==='admin' ? 'Quản trị' : 'Thành viên' %>
                          </span>
                        </td>
                        <td class="p-4 text-gray-400 font-medium">
                          <%= new Date(user.created_at).toLocaleDateString('vi-VN') %>
                        </td>
                        <td class="p-4 text-center">
                          <% if(user.username !=='admin' ) { %>
                            <button onclick="deleteUser(this)" data-id="<%= user.id %>"
                              class="border-2 border-gray-100 hover:border-red-500 text-gray-400 hover:text-red-500 text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Xóa</button>
                            <% } else { %>
                              <span class="text-gray-300 font-bold text-[10px] uppercase">Hệ thống</span>
                              <% } %>
                        </td>
                      </tr>
                      <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="5" class="p-8 text-center text-gray-400 font-bold">Chưa có người dùng nào!</td>
                          </tr>
                          <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ========================================== -->
        <!-- TAB CONTENT: VOUCHERS                      -->
        <!-- ========================================== -->
        <div id="tabContent-vouchers" class="admin-tab-content space-y-6 hidden">
          <% let totalVouchers=typeof vouchers !=='undefined' ? vouchers.length : 0; let activeVouchers=0; let
            expiringSoon=0; let expiredVouchers=0; let now=new Date(); if (totalVouchers> 0) {
            vouchers.forEach(v => {
            let expDate = new Date(v.expires_at);
            let startDate = v.start_date ? new Date(v.start_date) : null;
            let isExpired = expDate < now; let isNotStarted=startDate && startDate> now;
              let isOutOfStock = v.used_count >= v.usage_limit;

              let daysToExpiry = Math.ceil((expDate - now) / (1000 * 60 * 60 * 24));

              if (v.is_active && !isExpired && !isNotStarted && !isOutOfStock) activeVouchers++;
              if (isExpired) expiredVouchers++;
              if (!isExpired && daysToExpiry <= 3 && daysToExpiry> 0) expiringSoon++;

                v.statusText = 'Đang hoạt động';
                v.statusClass = 'text-green-500 bg-green-50';
                if (!v.is_active) { v.statusText = 'Đã vô hiệu hóa'; v.statusClass = 'text-gray-500 bg-gray-100'; }
                else if (isExpired) { v.statusText = 'Đã hết hạn'; v.statusClass = 'text-red-500 bg-red-50'; }
                else if (isOutOfStock) { v.statusText = 'Đã dùng hết'; v.statusClass = 'text-orange-500 bg-orange-50'; }
                else if (isNotStarted) { v.statusText = 'Chưa bắt đầu'; v.statusClass = 'text-blue-500 bg-blue-50'; }

                v.warning = '';
                if (v.statusText === 'Đang hoạt động') {
                if (daysToExpiry <= 3) v.warning=`⚠️ Hết hạn sau ${daysToExpiry} ngày`; if (v.usage_limit - v.used_count
                  <=10) v.warning=`⚠️ Còn ${v.usage_limit - v.used_count} lượt`; } }); } %>

                  <!-- Dashboard Thống Kê -->
                  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                    <div
                      class="bg-white p-5 rounded-3xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                      <span class="text-3xl font-black text-gray-800">
                        <%= totalVouchers %>
                      </span>
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mt-1">Tổng mã giảm
                        giá</span>
                    </div>
                    <div
                      class="bg-white p-5 rounded-3xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                      <span class="text-3xl font-black text-green-500">
                        <%= activeVouchers %>
                      </span>
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mt-1">Đang hoạt
                        động</span>
                    </div>
                    <div
                      class="bg-white p-5 rounded-3xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                      <span class="text-3xl font-black text-orange-500">
                        <%= expiringSoon %>
                      </span>
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mt-1">Sắp hết hạn</span>
                    </div>
                    <div
                      class="bg-white p-5 rounded-3xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                      <span class="text-3xl font-black text-red-500">
                        <%= expiredVouchers %>
                      </span>
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mt-1">Đã hết hạn</span>
                    </div>
                  </div>

                  <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
                    <h3 class="font-extrabold text-lg text-nike-black uppercase tracking-wide">Quản lý Mã Giảm Giá</h3>
                    <div class="flex gap-2">
                      <!-- Thao tác hàng loạt -->
                      <select id="bulkVoucherAction"
                        class="bg-white border border-gray-200 rounded-full px-4 py-2 text-xs font-bold text-gray-600 focus:outline-none focus:border-nike-orange hidden">
                        <option value="">-- Thao tác hàng loạt --</option>
                        <option value="activate">Kích hoạt mã</option>
                        <option value="deactivate">Vô hiệu hóa</option>
                        <option value="delete">Xóa mã</option>
                      </select>
                      <button id="applyBulkVoucherBtn" onclick="applyBulkVoucherActions()"
                        class="bg-gray-800 hover:bg-gray-900 text-white font-bold text-xs px-4 py-2 rounded-full uppercase tracking-wider transition-colors hidden">
                        Áp dụng
                      </button>
                      <button onclick="openVoucherDrawer()"
                        class="bg-nike-black hover:bg-nike-orange text-white font-bold text-xs px-5 py-3 rounded-full uppercase tracking-wider transition-colors shadow-md flex items-center gap-1.5 glow-dark hover:glow-orange">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4">
                          </path>
                        </svg>
                        Tạo Mã Mới
                      </button>
                    </div>
                  </div>

                  <!-- Bộ lọc & Tìm kiếm -->
                  <div
                    class="bg-white rounded-3xl p-4 border border-gray-100 shadow-sm flex flex-col lg:flex-row gap-4 items-center justify-between">
                    <div class="relative w-full lg:w-1/3">
                      <input type="text" id="voucherSearchInput" placeholder="🔍 Tìm mã code hoặc tên..."
                        oninput="filterVouchers()"
                        class="w-full bg-gray-50 border-0 rounded-full py-2.5 pl-4 pr-10 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-nike-orange/50">
                    </div>
                    <div class="flex flex-wrap gap-2 w-full lg:w-auto">
                      <select id="voucherStatusFilter" onchange="filterVouchers()"
                        class="bg-gray-50 border-0 rounded-full py-2.5 px-4 text-xs font-semibold text-gray-600 focus:outline-none focus:ring-2 focus:ring-nike-orange/50">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Đang hoạt động">Đang hoạt động</option>
                        <option value="Chưa bắt đầu">Chưa bắt đầu</option>
                        <option value="Đã hết hạn">Đã hết hạn</option>
                        <option value="Đã vô hiệu hóa">Đã vô hiệu hóa</option>
                        <option value="Đã dùng hết">Đã dùng hết</option>
                      </select>
                      <select id="voucherTypeFilter" onchange="filterVouchers()"
                        class="bg-gray-50 border-0 rounded-full py-2.5 px-4 text-xs font-semibold text-gray-600 focus:outline-none focus:ring-2 focus:ring-nike-orange/50">
                        <option value="">Tất cả loại giảm</option>
                        <option value="percent">Phần trăm (%)</option>
                        <option value="fixed">Số tiền cố định</option>
                      </select>
                    </div>
                  </div>

                  <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="overflow-x-auto">
                      <table class="w-full text-left text-xs border-collapse" id="voucherTable">
                        <thead>
                          <tr
                            class="bg-gray-100/50 text-gray-500 font-bold uppercase tracking-wider border-b border-gray-100">
                            <th class="p-4 w-10 text-center"><input type="checkbox" id="selectAllVouchers"
                                onclick="toggleAllVouchers(this)"
                                class="w-4 h-4 accent-nike-orange cursor-pointer rounded border-gray-300"></th>
                            <th class="p-4">Mã Code</th>
                            <th class="p-4">Mức Giảm</th>
                            <th class="p-4 hidden md:table-cell">Điều kiện & Tối đa</th>
                            <th class="p-4 text-center hidden sm:table-cell">Đã dùng / Tổng</th>
                            <th class="p-4 hidden lg:table-cell">Hạn SD</th>
                            <th class="p-4 text-center">Trạng thái</th>
                            <th class="p-4 text-center">Thao tác</th>
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50" id="voucherTbody">
                          <% if(totalVouchers> 0) { %>
                            <% vouchers.forEach(v=> { %>
                              <tr class="hover:bg-gray-50/30 transition-colors voucher-row"
                                data-search="<%= (v.code + ' ' + (v.name||'')).toLowerCase() %>"
                                data-status="<%= v.statusText %>" data-type="<%= v.discount_type %>">
                                <td class="p-4 text-center">
                                  <input type="checkbox"
                                    class="voucher-cb w-4 h-4 accent-nike-orange cursor-pointer rounded border-gray-300"
                                    value="<%= v.id %>" onchange="checkVoucherSelections()">
                                </td>
                                <td class="p-4">
                                  <div class="font-extrabold text-gray-800 text-sm">
                                    <%= v.code %>
                                  </div>
                                  <% if (v.name && v.name !==v.code) { %>
                                    <div class="text-[10px] text-gray-400 mt-0.5">
                                      <%= v.name %>
                                    </div>
                                    <% } %>
                                      <% if (v.warning) { %>
                                        <div class="text-[9px] font-bold text-orange-500 mt-1">
                                          <%= v.warning %>
                                        </div>
                                        <% } %>
                                </td>
                                <td class="p-4 font-bold text-nike-orange whitespace-nowrap">
                                  <%= v.discount_type==='percent' ? v.discount_value + '%' :
                                    formatPrice(v.discount_value) %>
                                    <% if(v.category==='shipping' ) { %>
                                      <span class="block text-[9px] text-gray-400 uppercase mt-0.5">Freeship</span>
                                      <% } %>
                                </td>
                                <td
                                  class="p-4 text-gray-500 font-medium hidden md:table-cell text-[10px] leading-tight">
                                  <span class="block">Min: <strong class="text-gray-700">
                                      <%= formatPrice(v.min_order_value) %>
                                    </strong></span>
                                  <% if (v.discount_type==='percent' && v.max_discount) { %>
                                    <span class="block mt-0.5">Max: <strong class="text-gray-700">
                                        <%= formatPrice(v.max_discount) %>
                                      </strong></span>
                                    <% } %>
                                </td>
                                <td class="p-4 text-center font-bold text-gray-600 hidden sm:table-cell">
                                  <span class="<%= v.used_count >= v.usage_limit ? 'text-red-500' : '' %>">
                                    <%= v.used_count %>
                                  </span> / <%= v.usage_limit %>
                                </td>
                                <td
                                  class="p-4 text-gray-500 font-medium whitespace-nowrap hidden lg:table-cell text-[10px]">
                                  <% if(v.start_date) { %>
                                    <div class="mb-0.5"><span class="text-gray-400">Từ:</span>
                                      <%= new Date(v.start_date).toLocaleDateString('vi-VN') %>
                                    </div>
                                    <% } %>
                                      <div><span class="text-gray-400">Đến:</span>
                                        <%= new Date(v.expires_at).toLocaleDateString('vi-VN') %>
                                      </div>
                                </td>
                                <td class="p-4 text-center">
                                  <span
                                    class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase tracking-wider <%= v.statusClass %> inline-block text-center w-28">
                                    <%= v.statusText %>
                                  </span>
                                </td>
                                <td class="p-4 text-center">
                                  <div class="flex gap-2 justify-center">
                                    <button onclick="viewVoucherStats(this)"
                                      data-voucher="<%= encodeURIComponent(JSON.stringify(v)) %>"
                                      class="bg-gray-100 hover:bg-nike-black text-gray-600 hover:text-white text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Xem</button>
                                    <button onclick="editVoucher(this)"
                                      data-voucher="<%= encodeURIComponent(JSON.stringify(v)) %>"
                                      class="border border-gray-200 hover:border-nike-orange text-gray-500 hover:text-nike-orange text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider transition-colors focus:outline-none">Sửa</button>
                                  </div>
                                </td>
                              </tr>
                              <% }) %>
                                <% } else { %>
                                  <tr id="emptyVoucherRow">
                                    <td colspan="8" class="p-8 text-center text-gray-400 font-bold">Chưa có mã giảm giá
                                      nào!</td>
                                  </tr>
                                  <% } %>
                        </tbody>
                      </table>
                    </div>
                    <!-- Phân trang Voucher -->
                    <div class="px-4 py-3 border-t border-gray-100 bg-gray-50/50 flex justify-end items-center"
                      id="voucherPagination">
                      <div class="flex gap-1 text-xs" id="voucherPageControls">
                        <!-- Rendered by JS -->
                      </div>
                    </div>
                  </div>
        </div>

        <!-- ================================================ -->
        <!-- TAB CONTENT: ANALYTICS                           -->
        <!-- ================================================ -->
        <div id="tabContent-analytics" class="admin-tab-content space-y-8 hidden">
          <div id="analyticsWrapper" class="relative">

            <!-- Lớp phủ Loading -->
            <div id="analyticsLoading"
              class="absolute inset-0 bg-white/80 z-50 flex flex-col items-center justify-center backdrop-blur-sm hidden rounded-3xl">
              <div class="w-10 h-10 border-4 border-gray-200 border-t-nike-orange rounded-full animate-spin"></div>
              <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mt-4">Đang tải dữ liệu...</p>
            </div>

            <div id="analyticsContent" class="space-y-8">

              <!-- ─── Header & Action Bar ────────────────────────────────────── -->
              <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                  <h2 class="font-black text-2xl text-nike-black uppercase tracking-wide">Phân Tích Kinh Doanh</h2>
                  <p class="text-xs text-gray-400 mt-1">Báo cáo doanh thu, sản phẩm và khách hàng theo thời gian thực.
                  </p>
                </div>
                <div class="flex items-center gap-3">
                  <select id="analyticsTimeFilter" onchange="fetchAnalytics()"
                    class="bg-gray-50 border border-gray-200 text-nike-black text-xs font-bold rounded-full px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-nike-orange/50 uppercase tracking-wider">
                    <option value="today">Hôm nay</option>
                    <option value="7d">7 Ngày Qua</option>
                    <option value="30d" selected>30 Ngày Qua</option>
                    <option value="this_month">Tháng Này</option>
                    <option value="this_year">Năm Nay</option>
                    <option value="all">Tất Cả Thời Gian</option>
                  </select>
                  <button onclick="exportAnalyticsPDF()"
                    class="bg-[#111] hover:bg-gray-800 text-white text-[10px] font-bold px-4 py-2.5 rounded-full uppercase tracking-wider transition-colors shadow-sm flex items-center justify-center gap-1.5 focus:outline-none">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Xuất PDF
                  </button>
                </div>
              </div>

              <!-- ─── AI Smart Insights ──────────────────────────────────────── -->
              <div
                class="bg-gradient-to-r from-blue-900 via-indigo-900 to-purple-900 rounded-3xl p-6 shadow-xl relative overflow-hidden">
                <!-- Decorative background -->
                <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-3xl -mr-20 -mt-20"></div>

                <div class="flex items-start gap-4 relative z-10">
                  <div
                    class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
                    <span class="text-2xl">✨</span>
                  </div>
                  <div class="flex-1">
                    <h3 class="font-black text-white uppercase tracking-wide text-sm mb-3">Gợi Ý Kinh Doanh Thông Minh
                    </h3>
                    <div id="smartInsightsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                      <!-- JS sẽ điền insights vào đây -->
                    </div>
                  </div>
                </div>
              </div>

              <!-- ─── KPI Cards ─────────────────────────────────────────────── -->
              <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                <div
                  class="bg-white rounded-3xl p-5 border border-gray-100 shadow-sm relative overflow-hidden group hover:border-orange-200 transition-colors">
                  <div
                    class="absolute -right-4 -top-4 w-16 h-16 bg-orange-50 rounded-full group-hover:scale-150 transition-transform duration-500">
                  </div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1 relative z-10">Doanh Thu
                    Thuần</p>
